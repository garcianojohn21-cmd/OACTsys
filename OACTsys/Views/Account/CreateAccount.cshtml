@section Scripts {
    <script>
        // ── Step navigation ──────────────────────────────────
        function goToStep(n) {
            document.querySelectorAll('.step-panel').forEach((p, i) =>
                p.classList.toggle('active', i + 1 === n));

            [1, 2, 3].forEach(i => {
                const sc = document.getElementById('sc' + i);
                const sl = document.getElementById('sl' + i);
                sc.classList.remove('active', 'done');
                sl.classList.remove('active', 'done');
                if (i < n)  { sc.classList.add('done');   sl.classList.add('done');   sc.textContent = '✓'; }
                if (i === n){ sc.classList.add('active');  sl.classList.add('active'); sc.textContent = i; }
                if (i > n)  { sc.textContent = i; }
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ── PIN input ────────────────────────────────────────
        const pins = Array.from(document.querySelectorAll('.pin-digit'));

        pins.forEach((el, idx) => {
            el.addEventListener('input', e => {
                const v = e.target.value.replace(/\D/g, '');
                e.target.value = v;
                e.target.classList.toggle('filled', !!v);
                if (v && idx < 5) pins[idx + 1].focus();
                syncVerifyBtn();
            });

            el.addEventListener('keydown', e => {
                if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                    pins[idx - 1].value = '';
                    pins[idx - 1].classList.remove('filled');
                    pins[idx - 1].focus();
                    syncVerifyBtn();
                }
            });

            el.addEventListener('paste', e => {
                const txt = (e.clipboardData || window.clipboardData)
                    .getData('text').replace(/\D/g, '').slice(0, 6);
                if (txt.length === 6) {
                    e.preventDefault();
                    txt.split('').forEach((c, i) => { pins[i].value = c; pins[i].classList.add('filled'); });
                    pins[5].focus();
                    syncVerifyBtn();
                }
            });
        });

        function syncVerifyBtn() {
            document.getElementById('verifyBtn').disabled =
                pins.map(p => p.value).join('').length !== 6;
        }

        function getPin() { return pins.map(p => p.value).join(''); }

        // ── Verify PIN ───────────────────────────────────────
        async function verifyPin() {
            const pin = getPin();
            if (pin.length !== 6) return;

            const btn  = document.getElementById('verifyBtn');
            const txt  = document.getElementById('verifyTxt');
            const spin = document.getElementById('verifySpin');

            btn.disabled = true;
            txt.textContent = 'Verifying…';
            spin.style.display = 'inline-block';
            hideAlert('pinAlert');

            try {
                const res  = await fetch('/Account/VerifyPin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pin })
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('hiddenPin').value        = pin;
                    document.getElementById('hiddenStudentId').value  = data.studentId;
                    document.getElementById('bannerName').textContent = data.fullName || data.studentNumber;
                    document.getElementById('bannerSub').textContent  =
                        (data.studentNumber || '') + ' · ' + (data.program || '') + ' · ' +
                        ({ 1:'1st Year', 2:'2nd Year', 3:'3rd Year', 4:'4th Year' }[data.yearLevel] || data.yearLevel + 'th Year');

                    if (data.email) document.getElementById('emailField').value = data.email;

                    const grid = document.getElementById('prefillGrid');
                    grid.innerHTML = '';
                    addCard(grid, 'Student No.',  data.studentNumber || '—');
                    addCard(grid, 'Program',      data.program       || '—');
                    addCard(grid, 'Year Level',   ({ 1:'1st Year', 2:'2nd Year', 3:'3rd Year', 4:'4th Year' }[data.yearLevel] || '—'));
                    addCard(grid, 'Student Type', data.studentType   || '—');

                    const skipKeys  = ['full_name','email_address','student_number','program',
                                       'year_level','student_type','academic_year','semester',
                                       'course_year','applicant_type','signature_date',
                                       'signature_over_printed_name'];
                    const skipTypes = ['email'];

                    (data.personalFields || []).forEach(f => {
                        if (skipKeys.includes((f.key  || '').toLowerCase())) return;
                        if (skipTypes.includes((f.fieldType || '').toLowerCase())) return;
                        addCard(grid, f.label, f.value || '—');
                    });

                    showAlert('pinAlert', 'success',
                        '<i class="bi bi-check-circle-fill"></i>&nbsp;PIN verified! Setting up your credentials…');
                    setTimeout(() => goToStep(2), 800);

                } else {
                    showAlert('pinAlert', 'danger',
                        '<i class="bi bi-x-circle-fill"></i>&nbsp;' + (data.message || 'Invalid PIN.'));
                    pins.forEach(p => { p.classList.add('error'); setTimeout(() => p.classList.remove('error'), 700); });
                }

            } catch {
                showAlert('pinAlert', 'danger',
                    '<i class="bi bi-x-circle-fill"></i>&nbsp;Network error. Please try again.');
            } finally {
                btn.disabled = false;
                txt.textContent = 'Verify PIN';
                spin.style.display = 'none';
            }
        }

        function formatDate(val) {
            if (!val) return val;
            const m = String(val).match(/^(\d{4})-(\d{2})-(\d{2})/);
            if (!m) return val;
            const months = ['January','February','March','April','May','June',
                            'July','August','September','October','November','December'];
            return months[parseInt(m[2],10)-1] + ' ' + parseInt(m[3],10) + ', ' + m[1];
        }

        function addCard(grid, label, value) {
            const d = document.createElement('div');
            d.className = 'info-card';
            d.innerHTML = '<div class="ic-label">' + esc(label) + '</div><div class="ic-value">' + esc(formatDate(value)) + '</div>';
            grid.appendChild(d);
        }

        function esc(s) {
            return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }

        // ── Password ─────────────────────────────────────────
        function togglePw(id, btn) {
            const f = document.getElementById(id);
            const show = f.type === 'password';
            f.type = show ? 'text' : 'password';
            btn.innerHTML = show ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
        }

        function checkPw(v) {
            let s = 0;
            if (v.length >= 8)          s++;
            if (/[A-Z]/.test(v))        s++;
            if (/[0-9]/.test(v))        s++;
            if (/[^A-Za-z0-9]/.test(v)) s++;
            const m = [{p:0,c:'#e2e8f0',t:''},{p:25,c:'#dc2626',t:'Weak'},
                       {p:50,c:'#f59e0b',t:'Fair'},{p:75,c:'#0ea5e9',t:'Good'},
                       {p:100,c:'#16a34a',t:'Strong'}][s];
            document.getElementById('pwBar').style.width      = m.p + '%';
            document.getElementById('pwBar').style.background = m.c;
            const lbl = document.getElementById('pwLabel');
            lbl.textContent = m.t;
            lbl.style.color = m.c;
        }

        // ── Validation ────────────────────────────────────────
        function validateForm() {
            const pw  = document.getElementById('passwordField').value;
            const cpw = document.getElementById('confirmField').value;
            if (pw.length < 8) {
                showAlert('formAlert','danger','<i class="bi bi-x-circle-fill"></i>&nbsp;Password must be at least 8 characters.');
                return false;
            }
            if (pw !== cpw) {
                showAlert('formAlert','danger','<i class="bi bi-x-circle-fill"></i>&nbsp;Passwords do not match.');
                return false;
            }
            if (!document.getElementById('agreeTerms').checked) {
                showAlert('formAlert','danger','<i class="bi bi-x-circle-fill"></i>&nbsp;Please accept the terms and conditions.');
                return false;
            }
            return true;
        }

        // ── Alert helpers ─────────────────────────────────────
        function showAlert(id, type, html) {
            const el = document.getElementById(id);
            el.innerHTML = html;
            el.className = 'ca-alert ' + type + ' show';
        }

        function hideAlert(id) {
            document.getElementById(id).className = 'ca-alert';
        }

        // ── Auto-focus ────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => pins[0].focus());
    </script>
}
