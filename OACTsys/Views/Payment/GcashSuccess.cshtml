@{
    ViewData["Title"] = "Payment Successful";
    Layout = null;
    int paymentId = ViewBag.PaymentId ?? 0;
    decimal amount = ViewBag.Amount ?? 0m;
    string payType = ViewBag.PaymentType ?? "Payment";
    string refNo = ViewBag.ReferenceNo ?? "—";
    string approvedBy = ViewBag.ApprovedBy ?? "Admin";
    string approvedAt = ViewBag.ApprovedAt ?? DateTime.Now.ToString("MMM dd, yyyy hh:mm tt");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>Payment Successful</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --green: #16A34A;
            --green-bg: #F0FDF4;
            --green-mid: #22C55E;
            --blue: #007AFF;
            --blue-pale: #EBF4FF;
            --text: #0F172A;
            --mid: #475569;
            --light: #94A3B8;
            --border: #E2E8F0;
        }

        body {
            font-family: 'Plus Jakarta Sans',sans-serif;
            background: #F1F5F9;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .header {
            width: 100%;
            background: linear-gradient(135deg,#166534,#22C55E);
            padding: 1.4rem 1rem 5.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .header::before {
                content: '';
                position: absolute;
                top: -60px;
                right: -60px;
                width: 220px;
                height: 220px;
                background: rgba(255,255,255,.07);
                border-radius: 50%;
            }

            .header::after {
                content: '';
                position: absolute;
                bottom: -40px;
                left: -50px;
                width: 160px;
                height: 160px;
                background: rgba(255,255,255,.05);
                border-radius: 50%;
            }

        .header-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            color: #fff;
            font-size: 1.45rem;
            font-weight: 800;
            position: relative;
            z-index: 1;
        }

        .logo-icon {
            width: 34px;
            height: 34px;
            background: #fff;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #fff;
            border-radius: 20px;
            width: calc(100% - 2rem);
            max-width: 460px;
            margin: -3.5rem auto 1.5rem;
            box-shadow: 0 8px 40px rgba(0,0,0,.12);
            overflow: hidden;
            position: relative;
            z-index: 2;
        }

        /* Confetti strip */
        .confetti-strip {
            background: linear-gradient(90deg,#166534,#16A34A,#22C55E,#16A34A,#166534);
            height: 5px;
        }

        /* Progress - all done */
        .progress-steps {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.2rem 1.4rem .6rem;
        }

        .prog-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .25rem;
            flex: 1;
        }

        .prog-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .65rem;
            font-weight: 800;
        }

            .prog-dot.done {
                background: var(--green);
                color: #fff;
            }

        .prog-label {
            font-size: .6rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: var(--green);
            text-align: center;
        }

        .prog-line {
            height: 2px;
            flex: 1;
            background: var(--green);
            margin-bottom: 1.1rem;
        }

        .body {
            padding: 1.5rem 1.4rem;
            text-align: center;
        }

        /* Big success icon */
        .success-circle {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: var(--green-bg);
            border: 3px solid #BBF7D0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.1rem;
            animation: pop-in .5s cubic-bezier(.34,1.56,.64,1) both;
        }

        @@keyframes pop-in {
            from {
                transform: scale(0);
                opacity: 0
            }

            to {
                transform: scale(1);
                opacity: 1
            }
        }

        .check-svg {
            animation: draw-check .4s .3s ease both;
        }

        @@keyframes draw-check {
            from {
                stroke-dashoffset: 50
            }

            to {
                stroke-dashoffset: 0
            }
        }

        .check-path {
            stroke-dasharray: 50;
            stroke-dashoffset: 50;
        }

        .success-title {
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--text);
            margin-bottom: .3rem;
            animation: fade-up .4s .5s ease both;
        }

        .success-sub {
            font-size: .82rem;
            color: var(--mid);
            line-height: 1.6;
            margin-bottom: 1.5rem;
            animation: fade-up .4s .6s ease both;
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(10px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* Receipt */
        .receipt {
            background: #FAFBFC;
            border: 1.5px dashed var(--border);
            border-radius: 16px;
            margin-bottom: 1.4rem;
            overflow: hidden;
            animation: fade-up .4s .7s ease both;
        }

        .receipt-header {
            background: var(--green-bg);
            padding: .6rem 1.1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .receipt-header span {
                font-size: .7rem;
                font-weight: 800;
                color: var(--green);
                text-transform: uppercase;
                letter-spacing: .6px;
            }

            .receipt-header .badge {
                background: var(--green);
                color: #fff;
                font-size: .65rem;
                font-weight: 800;
                padding: .2rem .6rem;
                border-radius: 50px;
            }

        .receipt-rows {
            padding: .75rem 1.1rem;
        }

        .receipt-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .38rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .82rem;
        }

            .receipt-row:last-child {
                border-bottom: none;
            }

            .receipt-row label {
                color: var(--light);
            }

            .receipt-row .rv {
                font-weight: 700;
                color: var(--text);
                text-align: right;
            }

                .receipt-row .rv.green {
                    color: var(--green);
                }

                .receipt-row .rv.big {
                    font-size: 1.05rem;
                    color: var(--blue);
                }

        .stamp {
            display: inline-block;
            border: 3px solid var(--green);
            border-radius: 8px;
            color: var(--green);
            font-size: .75rem;
            font-weight: 800;
            letter-spacing: 2px;
            padding: .3rem .9rem;
            text-transform: uppercase;
            margin: .75rem 0 .25rem;
            transform: rotate(-3deg);
            opacity: .8;
        }

        .next-box {
            background: var(--blue-pale);
            border-radius: 12px;
            padding: .9rem 1.1rem;
            margin-bottom: 1.25rem;
            text-align: left;
            animation: fade-up .4s .8s ease both;
        }

        .next-title {
            font-size: .72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--blue);
            margin-bottom: .5rem;
        }

        .next-item {
            display: flex;
            gap: .5rem;
            align-items: flex-start;
            font-size: .8rem;
            color: var(--text);
            line-height: 1.45;
            margin-bottom: .3rem;
        }

        .btn-primary {
            display: block;
            width: 100%;
            padding: .85rem;
            background: linear-gradient(135deg,#16A34A,#22C55E);
            color: #fff;
            border: none;
            border-radius: 50px;
            font-size: .9rem;
            font-weight: 800;
            cursor: pointer;
            letter-spacing: .4px;
            animation: fade-up .4s .9s ease both;
        }

        .btn-secondary {
            display: block;
            width: 100%;
            padding: .8rem;
            background: #F1F5F9;
            color: var(--mid);
            border: none;
            border-radius: 50px;
            font-size: .85rem;
            font-weight: 700;
            cursor: pointer;
            margin-top: .75rem;
            animation: fade-up .4s 1s ease both;
        }

        .footer {
            font-size: .68rem;
            color: var(--light);
            text-align: center;
            padding: .75rem 1rem 2rem;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="header-logo">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24" fill="none" width="22" height="22"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 4.5c2.071 0 3.9.948 5.12 2.438H13v1.5h5.82c.117.5.18 1.022.18 1.562H13v1.5h6c0 3.314-2.686 6-6 6s-6-2.686-6-6 2.686-6 6-6z" fill="#22C55E" /></svg>
            </div>
            Payment Verified ✓
        </div>
    </div>

    <div class="card">
        <div class="confetti-strip"></div>

        <!-- All steps done -->
        <div class="progress-steps">
            <div class="prog-step"><div class="prog-dot done">✓</div><div class="prog-label">Details</div></div>
            <div class="prog-line"></div>
            <div class="prog-step"><div class="prog-dot done">✓</div><div class="prog-label">Sent</div></div>
            <div class="prog-line"></div>
            <div class="prog-step"><div class="prog-dot done">✓</div><div class="prog-label">Proof</div></div>
            <div class="prog-line"></div>
            <div class="prog-step"><div class="prog-dot done">✓</div><div class="prog-label">Done!</div></div>
        </div>

        <div class="body">
            <div class="success-circle">
                <svg class="check-svg" width="44" height="44" viewBox="0 0 44 44" fill="none">
                    <path class="check-path" d="M10 22l9 9 15-16" stroke="#16A34A" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>

            <p class="success-title">Payment Successful! 🎉</p>
            <p class="success-sub">
                Your GCash payment has been verified and confirmed by the admin.
                Your enrollment record is now updated.
            </p>

            <!-- Receipt -->
            <div class="receipt">
                <div class="receipt-header">
                    <span>📄 Payment Receipt</span>
                    <span class="badge">✓ VERIFIED</span>
                </div>
                <div class="receipt-rows">
                    <div class="receipt-row"><label>Payment ID</label><div class="rv">#@paymentId</div></div>
                    <div class="receipt-row"><label>Purpose</label><div class="rv">@payType</div></div>
                    <div class="receipt-row"><label>Reference No.</label><div class="rv">@refNo</div></div>
                    <div class="receipt-row"><label>Amount Paid</label><div class="rv big">PHP @amount.ToString("N2")</div></div>
                    <div class="receipt-row"><label>Method</label><div class="rv">GCash</div></div>
                    <div class="receipt-row"><label>Verified By</label><div class="rv green">@approvedBy</div></div>
                    <div class="receipt-row"><label>Verified At</label><div class="rv">@approvedAt</div></div>
                    <div class="receipt-row"><label>Status</label><div class="rv green">✅ Approved</div></div>
                </div>
                <div style="text-align:center;padding:.25rem 0 1rem;">
                    <div class="stamp">PAID</div>
                </div>
            </div>

            <div class="next-box">
                <div class="next-title">📋 What's Next</div>
                <div class="next-item">✅ Your payment is recorded in the registrar's system.</div>
                <div class="next-item">📋 You may check your enrollment status in the student portal.</div>
                <div class="next-item">🔒 Keep this page as reference or take a screenshot.</div>
            </div>

            <button class="btn-primary" onclick="window.location.href='/'">🏠 Back to Home</button>
            <button class="btn-secondary" onclick="window.print()">🖨️ Print Receipt</button>
        </div>
    </div>

    <div class="footer">Secured GCash Payment · OACT Registrar Office</div>

</body>
</html>
