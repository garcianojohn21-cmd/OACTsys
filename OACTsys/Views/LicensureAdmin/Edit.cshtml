@{
    ViewBag.Title = "Edit Student Application";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - OACT Admin</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy-blue: #001f3f;
            --light-navy: #0a2463;
            --text-dark: #2c3e50;
            --border-color: #dee2e6;
        }

        body {
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            background: #ffffff;
            color: var(--navy-blue);
            min-height: 100vh;
            padding: 20px;
        }

        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-header {
            background: white;
            border: 2px solid var(--navy-blue);
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 30px;
        }

            .page-header h1 {
                color: var(--navy-blue);
                font-weight: 700;
                margin: 0;
                font-size: 2rem;
            }

                .page-header h1 i {
                    margin-right: 15px;
                }

            .page-header p {
                color: var(--text-dark);
                margin: 10px 0 0 0;
                font-size: 1rem;
            }

        .content-card {
            background: white;
            border: 2px solid var(--navy-blue);
            border-radius: 8px;
            padding: 30px;
            margin-bottom: 30px;
        }

        .form-control, .form-select {
            border: 2px solid var(--border-color);
            border-radius: 6px;
            padding: 10px 15px;
            color: var(--navy-blue);
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--navy-blue);
                box-shadow: 0 0 0 0.2rem rgba(0, 31, 63, 0.25);
            }

            .form-control:read-only {
                background-color: #e9ecef;
            }

        .form-label {
            color: var(--navy-blue);
            font-weight: 600;
            margin-bottom: 8px;
        }

        .btn-navy {
            background: var(--navy-blue);
            color: white;
            border: 2px solid var(--navy-blue);
            padding: 10px 20px;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.3s;
        }

            .btn-navy:hover {
                background: white;
                color: var(--navy-blue);
            }

        .btn-outline-navy {
            background: white;
            color: var(--navy-blue);
            border: 2px solid var(--navy-blue);
            padding: 10px 20px;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.3s;
        }

            .btn-outline-navy:hover {
                background: var(--navy-blue);
                color: white;
            }

        @@media (max-width: 768px) {
            .page-header h1 {
                font-size: 1.5rem;
            }

            .d-flex.justify-content-between {
                flex-direction: column;
                gap: 10px;
            }

                .d-flex.justify-content-between .btn {
                    width: 100%;
                }
        }
    </style>
</head>

<body>
    <div class="admin-container">
        <div class="page-header">
            <h1><i class="fas fa-user-edit"></i>Edit Student Application</h1>
            <p>Update student licensure examination details</p>
        </div>

        <div class="content-card">
            <form method="post">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Application ID</label>
                        <input type="text" class="form-control" value="LIC-2024-001" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Student Name</label>
                        <input type="text" class="form-control" value="Juan Dela Cruz" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="juan.delacruz@email.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Venue</label>
                        <select class="form-select">
                            <option selected>Main Office - Navotas</option>
                            <option>Regional Center - Cebu</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Exam Date</label>
                        <input type="date" class="form-control" value="2026-02-10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Pending</option>
                            <option>Approved</option>
                            <option selected>Scheduled</option>
                            <option>Completed</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("Licensure", "Admin")" class="btn btn-outline-navy">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                    <button type="submit" class="btn btn-navy">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
