@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Document Request";
}

<div class="container-fluid">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 card-oact-form">
                <div class="card-body p-4">
                    <h5 class="text-admiral fw-bold mb-4"><i class="bi bi-file-earmark-plus me-2"></i>NEW REQUEST</h5>

                    @if (TempData["RequestSuccess"] != null)
                    {
                        <div class="alert alert-success small">
                            <i class="bi bi-check-circle me-2"></i> @TempData["RequestSuccess"]
                        </div>
                    }

                    <form asp-action="SubmitDocumentRequest" method="post">
                        <div class="mb-3">
                            <label class="small fw-bold text-admiral">SELECT DOCUMENT</label>
                            <select name="DocumentType" class="form-select border-admiral" required>
                                <option value="" selected disabled>-- Choose Document --</option>
                                <option value="Official Transcript of Records (OTR)">Official Transcript of Records (OTR)</option>
                                <option value="Certificate of Registration (COR)">Certificate of Registration (COR)</option>
                                <option value="Honorable Dismissal / Transfer Credentials">Honorable Dismissal / Transfer Credentials</option>
                                <option value="Certificate of Enrollment">Certificate of Enrollment</option>
                                <option value="Certificate of Grades (COG)">Certificate of Grades (COG)</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="small fw-bold text-admiral">REASON FOR REQUEST</label>
                            <textarea name="Reason" class="form-control border-admiral" rows="4"
                                      placeholder="e.g. For employment, scholarship, or personal file" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-admiral w-100 py-2">SUBMIT REQUEST</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="text-admiral fw-bold mb-0">REQUEST STATUS</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="bg-light">
                                <tr class="small text-admiral">
                                    <th class="ps-3">Date</th>
                                    <th>Document</th>
                                    <th>Status</th>
                                    <th class="text-end pe-3">Action</th>
                                </tr>
                            </thead>
                            <tbody class="small">
                                <tr>
                                    <td class="ps-3">Feb 04, 2026</td>
                                    <td>Certificate of Enrollment</td>
                                    <td><span class="badge bg-warning">Processing</span></td>
                                    <td class="text-end pe-3"><button class="btn btn-sm btn-outline-secondary">View</button></td>
                                </tr>
                                <tr>
                                    <td class="ps-3">Jan 12, 2026</td>
                                    <td>Official Transcript (OTR)</td>
                                    <td><span class="badge bg-success">Ready for Pickup</span></td>
                                    <td class="text-end pe-3"><button class="btn btn-sm btn-outline-secondary">View</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-center py-5 d-none">
                        <i class="bi bi-folder2-open display-4 text-muted"></i>
                        <p class="text-muted">No recent requests found.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-admiral {
        border: 1px solid #051094;
    }

    .card-oact-form {
        border-top: 5px solid #051094;
    }

    .form-select:focus, .form-control:focus {
        border-color: #051094;
        box-shadow: 0 0 0 0.25rem rgba(5, 16, 148, 0.1);
    }
</style>