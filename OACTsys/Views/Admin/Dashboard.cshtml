@{
    ViewBag.Title = "Student Processing Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-navy: #051094;
        --soft-gray: #f8f9fa;
        --border-color: #e2e8f0;
        --accent-orange: #f59e0b;
    }

    .dash-container {
        background-color: var(--soft-gray);
        font-family: 'Inter', sans-serif;
        color: #1e293b;
        padding: 20px;
    }

    .dash-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        height: 100%;
    }

    .big-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--primary-navy);
        line-height: 1;
    }

    /* Table Styling */
    .table-container {
        margin-top: 24px;
        background: white;
        border-radius: 16px;
        border: 1px solid var(--border-color);
        overflow: hidden;
    }

    .custom-table th {
        background: #f1f5f9;
        font-weight: 600;
        padding: 16px;
    }

    .status-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }
</style>

<div class="dash-container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold m-0" style="color: var(--primary-navy);">Registration & Licensure Tracking</h2>
            <p class="text-muted">Monitoring enrollment completions and licensure intent.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="dash-card">
                <div class="icon-circle bg-primary text-white"><i class="bi bi-person-check"></i></div>
                <h6 class="text-muted fw-bold">ENROLLMENT COMPLETION</h6>
                <div class="big-number mt-2" id="totalEnrolled">285</div>
                <p class="small text-muted mt-2">Students officially enrolled in current term</p>

                <div class="mt-4 pt-2 border-top">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span>Paid & Confirmed</span>
                        <span class="fw-bold">210 / 285</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar" style="width: 74%; background: var(--primary-navy);"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dash-card">
                <h6 class="text-muted fw-bold mb-3">ENROLLMENT BY DATE</h6>
                <canvas id="enrollmentTrendChart" height="180"></canvas>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dash-card">
                <div class="icon-circle bg-warning text-white"><i class="bi bi-file-earmark-medical"></i></div>
                <h6 class="text-muted fw-bold">LICENSURE EXAM INTENT</h6>
                <div class="big-number mt-2" style="color: var(--accent-orange);">154</div>
                <p class="small text-muted mt-2">Students wanting to take the exam</p>

                <div class="d-flex gap-3 mt-4">
                    <div class="p-2 flex-fill border rounded text-center">
                        <div class="fw-bold">120</div>
                        <small class="text-muted">Registered</small>
                    </div>
                    <div class="p-2 flex-fill border rounded text-center">
                        <div class="fw-bold">34</div>
                        <small class="text-muted">In-Process</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-container shadow-sm mt-4">
        <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
            <h5 class="fw-bold m-0">Student Records Detail</h5>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width: 150px;">
                    <option>All Courses</option>
                    <option>Nursing</option>
                    <option>Engineering</option>
                </select>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table custom-table m-0">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Course</th>
                        <th>Enrollment Date</th>
                        <th>Payment Status</th>
                        <th>Licensure Intent</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="studentTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Enrollment Trend Chart
        const trendCtx = document.getElementById('enrollmentTrendChart').getContext('2d');
        new Chart(trendCtx, {
            type: 'bar',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                datasets: [{
                    label: 'New Enrollees',
                    data: [45, 80, 120, 40],
                    backgroundColor: '#051094',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });

        // Student Data
        const students = [
            { name: "Anya Sharma", course: "Nursing", date: "2025-01-15", status: "Paid", intent: "Yes" },
            { name: "Chen Li", course: "Business Mgmt", date: "2025-01-20", status: "Paid", intent: "No" },
            { name: "Dante Padacana", course: "Engineering", date: "2025-02-01", status: "Unpaid", intent: "Yes" },
            { name: "Sayan Chan", course: "Architecture", date: "2025-02-03", status: "Paid", intent: "Yes" }
        ];

        const tbody = document.getElementById('studentTableBody');
        students.forEach(s => {
            const intentBadge = s.intent === 'Yes' ? 'bg-primary' : 'bg-secondary';
            const statusClass = s.status === 'Paid' ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger';

            tbody.innerHTML += `
                <tr>
                    <td><strong>${s.name}</strong></td>
                    <td>${s.course}</td>
                    <td>${s.date}</td>
                    <td><span class="status-pill ${statusClass}">${s.status}</span></td>
                    <td><span class="badge ${intentBadge}">${s.intent}</span></td>
                    <td><button class="btn btn-sm btn-outline-primary py-0">Details</button></td>
                </tr>`;
        });
    });
</script>