@{
    ViewBag.Title = "Create New Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    :root {
        --navy:        #051094;
        --navy-deep:   #030b72;
        --navy-mid:    #0a1fa8;
        --navy-soft:   #1a3fd4;
        --navy-tint:   #e8ebff;
        --navy-pale:   #f0f3ff;
        --accent:      #3b82f6;
        --accent-glow: rgba(59,130,246,.18);
        --green:       #16a34a;
        --green-bg:    #dcfce7;
        --amber:       #d97706;
        --amber-bg:    #fef3c7;
        --red:         #dc2626;
        --red-bg:      #fee2e2;
        --white:       #ffffff;
        --surface:     #f5f7ff;
        --border:      #e2e7ff;
        --text-1:      #0d1b4b;
        --text-2:      #4a5b8a;
        --text-3:      #8a97c0;
        --shadow-sm:   0 1px 3px rgba(5,16,148,.08);
        --shadow-md:   0 4px 16px rgba(5,16,148,.10);
        --shadow-lg:   0 12px 40px rgba(5,16,148,.14);
        --radius:      14px;
        --radius-sm:   9px;
        --radius-xs:   6px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--surface); }

    /* ── HERO ── */
    .ca-hero {
        background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 50%, var(--navy-soft) 100%);
        padding: 2rem 2rem 3.8rem; position: relative; overflow: hidden;
    }
    .ca-hero::before {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background:
            radial-gradient(ellipse 55% 70% at 85% -5%, rgba(59,130,246,.25) 0%, transparent 55%),
            radial-gradient(ellipse 35% 55% at -5% 105%, rgba(255,255,255,.07) 0%, transparent 50%);
    }
    .ca-hero::after {
        content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 44px;
        background: var(--surface); clip-path: ellipse(55% 100% at 50% 100%);
    }
    .ca-hero-inner {
        position: relative; z-index: 2;
        display: flex; align-items: flex-start; justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
    }
    .ca-hero-title {
        font-size: clamp(1.55rem, 3vw, 2.2rem); font-weight: 800;
        color: #fff; letter-spacing: -.5px; margin: 0 0 .3rem; line-height: 1.15;
    }
    .ca-hero-sub {
        font-size: .81rem; color: rgba(255,255,255,.62); margin: 0;
        font-weight: 500; line-height: 1.55; max-width: 480px;
    }
    .ca-hero-sub strong { color: rgba(255,255,255,.9); }
    .ca-hero-actions { display: flex; gap: .65rem; flex-wrap: wrap; align-items: flex-start; }
    .btn-back {
        background: rgba(255,255,255,.13); color: #fff;
        border: 1.5px solid rgba(255,255,255,.28);
        border-radius: var(--radius-sm); padding: .62rem 1.1rem;
        font-size: .81rem; font-weight: 700; font-family: inherit;
        display: inline-flex; align-items: center; gap: .45rem;
        text-decoration: none; cursor: pointer; white-space: nowrap; transition: background .2s;
    }
    .btn-back:hover { background: rgba(255,255,255,.23); color: #fff; }

    /* ── CONTENT ── */
    .ca-content { padding: 1.75rem 2rem 3rem; }

    /* ── FORM CARD ── */
    .form-card {
        background: var(--white); border: 1.5px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    /* Section header inside card */
    .section-head {
        display: flex; align-items: center; gap: .65rem;
        padding: 1.1rem 1.5rem; border-bottom: 1.5px solid var(--border);
        background: var(--navy-pale);
    }
    .section-head-icon {
        width: 32px; height: 32px; border-radius: var(--radius-xs);
        background: var(--navy); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: .82rem; flex-shrink: 0;
    }
    .section-head-title { font-size: .88rem; font-weight: 800; color: var(--text-1); margin: 0; }
    .section-head-sub   { font-size: .72rem; color: var(--text-3); margin: 0; }

    .form-body { padding: 1.5rem; }

    /* ── FIELD STYLES ── */
    .field-group { margin-bottom: 1.1rem; }
    .field-label {
        display: block; font-size: .77rem; font-weight: 700;
        color: var(--text-2); margin-bottom: .38rem; letter-spacing: .2px;
    }
    .field-label .req { color: var(--red); margin-left: 2px; }
    .field-input {
        width: 100%; padding: .62rem .9rem;
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        font-family: inherit; font-size: .83rem; color: var(--text-1);
        background: var(--surface); outline: none;
        transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .field-input:focus {
        border-color: var(--navy); background: #fff;
        box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .field-input::placeholder { color: var(--text-3); }
    .field-hint { font-size: .71rem; color: var(--text-3); margin-top: .3rem; }

    /* Input group for password */
    .input-group-custom { display: flex; gap: 0; }
    .input-group-custom .field-input {
        border-radius: var(--radius-sm) 0 0 var(--radius-sm);
        border-right: none; flex: 1;
    }
    .input-group-custom .field-input:focus { z-index: 2; }
    .ig-btn {
        background: var(--white); border: 1.5px solid var(--border);
        color: var(--text-2); padding: 0 .75rem; cursor: pointer;
        font-size: .82rem; display: flex; align-items: center;
        transition: background .18s, color .18s; white-space: nowrap;
        border-left: none;
    }
    .ig-btn:hover { background: var(--navy-pale); color: var(--navy); }
    .ig-btn:last-child { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }

    /* ── DIVIDER ── */
    .form-divider {
        border: none; border-top: 1.5px solid var(--border); margin: 1.35rem 0;
    }

    /* ── PERMISSIONS ── */
    .perms-toolbar {
        display: flex; gap: .5rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center;
    }
    .perm-search-wrap { position: relative; flex: 1; min-width: 160px; max-width: 260px; }
    .perm-search-wrap i { position: absolute; left: .72rem; top: 50%; transform: translateY(-50%); color: var(--text-3); font-size: .8rem; pointer-events: none; }
    .perm-search {
        width: 100%; padding: .48rem .8rem .48rem 2.1rem;
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        font-family: inherit; font-size: .78rem; color: var(--text-1);
        background: var(--surface); outline: none; transition: border-color .2s, box-shadow .2s;
    }
    .perm-search:focus { border-color: var(--navy); box-shadow: 0 0 0 3px var(--accent-glow); background: #fff; }
    .btn-perm {
        border: 1.5px solid var(--border); background: var(--white);
        color: var(--text-2); border-radius: var(--radius-xs);
        padding: .42rem .85rem; font-size: .74rem; font-weight: 700;
        font-family: inherit; cursor: pointer; display: flex; align-items: center;
        gap: .35rem; transition: all .18s; white-space: nowrap;
    }
    .btn-perm:hover { border-color: var(--navy); color: var(--navy); background: var(--navy-pale); }
    .btn-perm.deselect:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }

    .perms-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: .55rem;
    }
    .perm-item {
        display: flex; align-items: center; gap: .55rem;
        padding: .55rem .75rem; border: 1.5px solid var(--border);
        border-radius: var(--radius-xs); cursor: pointer;
        transition: all .18s; background: var(--surface); user-select: none;
    }
    .perm-item:hover { border-color: var(--navy); background: var(--navy-pale); }
    .perm-item.checked { border-color: var(--navy); background: var(--navy-tint); }
    .perm-item input { width: 15px; height: 15px; accent-color: var(--navy); cursor: pointer; flex-shrink: 0; }
    .perm-label { font-size: .75rem; font-weight: 600; color: var(--text-1); line-height: 1.3; }
    .perm-item.hidden { display: none; }

    /* Selected count badge */
    .perm-count-badge {
        font-size: .72rem; font-weight: 700; color: var(--navy);
        background: var(--navy-tint); border: 1px solid var(--border);
        border-radius: 50px; padding: .18rem .65rem; margin-left: auto;
        white-space: nowrap;
    }

    /* ── FORM ACTIONS ── */
    .form-actions {
        padding: 1.1rem 1.5rem; border-top: 1.5px solid var(--border);
        background: var(--navy-pale); display: flex;
        justify-content: flex-end; gap: .6rem; flex-wrap: wrap;
    }
    .btn-cancel {
        background: var(--white); color: var(--text-2);
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        padding: .62rem 1.15rem; font-size: .82rem; font-weight: 700;
        font-family: inherit; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .18s;
    }
    .btn-cancel:hover { border-color: var(--text-2); color: var(--text-1); }
    .btn-clear {
        background: var(--white); color: var(--text-3);
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        padding: .62rem 1.15rem; font-size: .82rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .18s;
    }
    .btn-clear:hover { border-color: var(--amber); color: var(--amber); background: var(--amber-bg); }
    .btn-submit {
        background: var(--navy); color: #fff; border: none;
        border-radius: var(--radius-sm); padding: .62rem 1.5rem;
        font-size: .82rem; font-weight: 800; font-family: inherit;
        cursor: pointer; display: inline-flex; align-items: center; gap: .45rem;
        box-shadow: 0 4px 14px rgba(5,16,148,.3);
        transition: background .2s, transform .2s, box-shadow .2s;
    }
    .btn-submit:hover { background: var(--navy-deep); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(5,16,148,.35); }

    /* ── ALERT ── */
    .ca-alert {
        display: flex; align-items: flex-start; gap: .7rem;
        background: var(--red-bg); border: 1.5px solid #fca5a5;
        border-radius: var(--radius-sm); padding: .9rem 1.1rem;
        font-size: .81rem; color: var(--red); font-weight: 600; margin-bottom: 1.25rem;
    }
    .ca-alert i { font-size: 1rem; flex-shrink: 0; margin-top: .05rem; }

    /* ── RESPONSIVE ── */
    @@media (max-width: 768px) {
        .ca-hero { padding: 1.5rem 1.25rem 3.5rem; }
        .ca-content { padding: 1.5rem 1.25rem 3rem; }
        .ca-hero-inner { flex-direction: column; }
        .perms-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 480px) {
        .perms-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- ── HERO ── -->
<div class="ca-hero">
    <div class="ca-hero-inner">
        <div>
            <h1 class="ca-hero-title">
                <i class="bi bi-shield-lock-fill me-2" style="font-size:.8em;opacity:.75"></i>
                Create New Admin
            </h1>
            <p class="ca-hero-sub">
                Fill in the admin's details and assign <strong>permissions</strong> below &bull;
                A temporary password will be sent to the admin on first login
            </p>
        </div>
        <div class="ca-hero-actions">
            <a href="@Url.Action("AdminList")" class="btn-back">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>

<!-- ── CONTENT ── -->
<div class="ca-content">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="ca-alert">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span>@Html.Raw(TempData["ErrorMessage"])</span>
        </div>
    }

    <form method="post" asp-action="CreateAdmin">
        @Html.AntiForgeryToken()

        <div class="form-card">

            <!-- ── BASIC INFO ── -->
            <div class="section-head">
                <div class="section-head-icon"><i class="bi bi-person-fill"></i></div>
                <div>
                    <p class="section-head-title">Basic Information</p>
                    <p class="section-head-sub">Name, username, and login credentials</p>
                </div>
            </div>
            <div class="form-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="field-group">
                            <label class="field-label">Full Name <span class="req">*</span></label>
                            <input type="text" class="field-input" placeholder="Enter full name"
                                   name="FullName" value="@ViewBag.FullName" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="field-group">
                            <label class="field-label">Username <span class="req">*</span></label>
                            <input type="text" class="field-input" placeholder="Enter username"
                                   name="Username" value="@ViewBag.Username" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="field-group">
                            <label class="field-label">Email Address <span class="req">*</span></label>
                            <input type="email" class="field-input" placeholder="Enter email"
                                   name="Email" value="@ViewBag.Email" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="field-group">
                            <label class="field-label">Temporary Password <span class="req">*</span></label>
                            <div class="input-group-custom">
                                <input type="password" class="field-input" id="passwordInput"
                                       placeholder="Auto-generated or manual" name="Password"
                                       value="@ViewBag.GeneratedPassword" required />
                                <button class="ig-btn" type="button" id="togglePassword" title="Show/hide">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                                <button class="ig-btn" type="button" id="generatePassword" title="Generate password">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                            <p class="field-hint">Click <i class="bi bi-arrow-clockwise"></i> to auto-generate a secure password.</p>
                        </div>
                    </div>
                </div>

                <hr class="form-divider">

                <!-- ROLE -->
                <div class="field-group" style="max-width: 480px;">
                    <label class="field-label">
                        <i class="bi bi-tag-fill me-1" style="color:var(--navy);font-size:.8rem"></i>
                        Admin Role Name <span class="req">*</span>
                    </label>
                    <input type="text" class="field-input"
                           placeholder="e.g. Registrar, Accounting, Exam Officer"
                           name="RoleName" value="@ViewBag.RoleName" required />
                    <p class="field-hint">You can define a custom role name for this admin account.</p>
                </div>
            </div>

            <!-- ── PERMISSIONS ── -->
            <div class="section-head" style="border-top: 1.5px solid var(--border);">
                <div class="section-head-icon"><i class="bi bi-key-fill"></i></div>
                <div style="flex:1">
                    <p class="section-head-title">Assign Permissions</p>
                    <p class="section-head-sub">Choose what this admin can access</p>
                </div>
                <span class="perm-count-badge" id="permCountBadge">0 selected</span>
            </div>
            <div class="form-body">
                <div class="perms-toolbar">
                    <div class="perm-search-wrap">
                        <i class="bi bi-search"></i>
                        <input type="text" class="perm-search" id="permSearch" placeholder="Filter permissions…">
                    </div>
                    <button type="button" class="btn-perm" id="selectAll">
                        <i class="bi bi-check-all"></i> Select All
                    </button>
                    <button type="button" class="btn-perm deselect" id="deselectAll">
                        <i class="bi bi-x-circle"></i> Deselect All
                    </button>
                </div>

                <div class="perms-grid" id="permsGrid">
                    @{
                        var selectedPerms = ViewBag.SelectedPermissions as List<string> ?? new List<string>();
                        var allPermissions = ViewBag.AllPermissions as List<string>;
                        if (allPermissions != null)
                        {
                            for (int i = 0; i < allPermissions.Count; i++)
                            {
                                var permission = allPermissions[i];
                                var isChecked = selectedPerms.Contains(permission);
                                <label class="perm-item @(isChecked ? "checked" : "")" data-perm="@permission.ToLower()">
                                    <input class="permission-checkbox" type="checkbox"
                                           name="Permissions" value="@permission"
                                           @(isChecked ? "checked" : "")
                                           onchange="syncPermItem(this)">
                                    <span class="perm-label">@permission</span>
                                </label>
                            }
                        }
                    }
                </div>
            </div>

            <!-- ── ACTIONS ── -->
            <div class="form-actions">
                <a href="@Url.Action("AdminList")" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="reset" class="btn-clear" onclick="onReset()">
                    <i class="bi bi-eraser"></i> Clear
                </button>
                <button type="submit" class="btn-submit">
                    <i class="bi bi-shield-check"></i> Create Admin
                </button>
            </div>

        </div>
    </form>
</div>

@section Scripts {
<script>
    // ── Password toggle
    document.getElementById('togglePassword').addEventListener('click', function () {
        const inp  = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        const show = inp.type === 'password';
        inp.type = show ? 'text' : 'password';
        icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
    });

    // ── Generate password
    document.getElementById('generatePassword').addEventListener('click', function () {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@@#$%';
        let pw = '';
        for (let i = 0; i < 12; i++) pw += chars[Math.floor(Math.random() * chars.length)];
        const inp  = document.getElementById('passwordInput');
        inp.value  = pw;
        inp.type   = 'text';
        document.getElementById('eyeIcon').className = 'bi bi-eye-slash';
    });

    // ── Permissions
    function updatePermCount() {
        const n = document.querySelectorAll('.permission-checkbox:checked').length;
        document.getElementById('permCountBadge').textContent = `${n} selected`;
    }

    function syncPermItem(cb) {
        cb.closest('.perm-item').classList.toggle('checked', cb.checked);
        updatePermCount();
    }

    document.getElementById('selectAll').addEventListener('click', function () {
        document.querySelectorAll('.perm-item:not(.hidden) .permission-checkbox').forEach(cb => {
            cb.checked = true; cb.closest('.perm-item').classList.add('checked');
        });
        updatePermCount();
    });

    document.getElementById('deselectAll').addEventListener('click', function () {
        document.querySelectorAll('.permission-checkbox').forEach(cb => {
            cb.checked = false; cb.closest('.perm-item').classList.remove('checked');
        });
        updatePermCount();
    });

    // ── Permission search filter
    document.getElementById('permSearch').addEventListener('input', function () {
        const q = this.value.trim().toLowerCase();
        document.querySelectorAll('.perm-item').forEach(item => {
            item.classList.toggle('hidden', q && !item.dataset.perm.includes(q));
        });
    });

    // ── Clear resets permission highlights
    function onReset() {
        setTimeout(() => {
            document.querySelectorAll('.perm-item').forEach(item => item.classList.remove('checked'));
            updatePermCount();
        }, 10);
    }

    // Init count
    updatePermCount();
</script>
}
