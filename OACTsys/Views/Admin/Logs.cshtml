@{
    ViewBag.Title = "Student Activity Logs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="color:#051094;" class="mb-1">
                <i class="bi bi-journal-text"></i> Student Activity Logs
            </h3>
            <p class="text-muted small">Monitoring real-time interactions and security access</p>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-download"></i> Export CSV
            </button>
            <button class="btn btn-outline-danger btn-sm" onclick="clearLogs()">
                <i class="bi bi-trash"></i> Clear Older Logs
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search by Student Name or ID...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm">
                        <option selected>All Activities</option>
                        <option>Login</option>
                        <option>File Upload</option>
                        <option>Profile Update</option>
                        <option>View Report</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100">Apply Filter</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Timestamp</th>
                            <th>Student</th>
                            <th>Activity</th>
                            <th>IP Address</th>
                            <th>Device / User Agent</th>
                            <th class="text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4">
                                <span class="d-block fw-bold">Feb 04, 2026</span>
                                <small class="text-muted">10:45:22 AM</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">Juan Dela Cruz</div>
                                <small class="text-muted">ID: 2024-0012</small>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-blue-light text-primary border border-primary">
                                    Login Success
                                </span>
                            </td>
                            <td><code>192.168.1.45</code></td>
                            <td>
                                <i class="bi bi-phone me-1"></i> iPhone 15 (iOS 17.2)
                                <div class="text-muted" style="font-size: 0.75rem;">Safari Mobile</div>
                            </td>
                            <td class="text-end pe-4">
                                <i class="bi bi-circle-fill text-success small"></i>
                            </td>
                        </tr>

                        <tr>
                            <td class="ps-4">
                                <span class="d-block fw-bold">Feb 04, 2026</span>
                                <small class="text-muted">09:12:05 AM</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">Maria Santos</div>
                                <small class="text-muted">ID: 2024-0588</small>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-light text-dark border">
                                    Downloaded Report
                                </span>
                                <div class="small text-muted">Licensure_Summary.pdf</div>
                            </td>
                            <td><code>112.204.15.121</code></td>
                            <td>
                                <i class="bi bi-laptop me-1"></i> Windows 11
                                <div class="text-muted" style="font-size: 0.75rem;">Chrome v121.0</div>
                            </td>
                            <td class="text-end pe-4">
                                <i class="bi bi-circle-fill text-success small"></i>
                            </td>
                        </tr>

                        <tr>
                            <td class="ps-4">
                                <span class="d-block fw-bold">Feb 03, 2026</span>
                                <small class="text-muted">11:58:00 PM</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">Unknown Student</div>
                                <small class="text-muted">Attempted ID: 2021-9999</small>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-danger-light text-danger border border-danger">
                                    Failed Login
                                </span>
                            </td>
                            <td><code>45.12.88.2</code></td>
                            <td>
                                <i class="bi bi-robot me-1"></i> Linux x86_64
                                <div class="text-muted" style="font-size: 0.75rem;">Unknown Browser</div>
                            </td>
                            <td class="text-end pe-4">
                                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0 justify-content-center">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    .bg-blue-light {
        background-color: #e7f0ff;
    }

    .bg-danger-light {
        background-color: #ffe7e7;
    }

    code {
        color: #d63384;
        font-size: 85%;
    }

    .table-hover tbody tr:hover {
        background-color: #fbfbfb;
    }
</style>

@section Scripts {
    <script>
        function clearLogs() {
            if(confirm("Are you sure you want to clear logs older than 30 days? This action cannot be undone.")) {
                // Logic to call backend delete
                alert("Older logs cleared successfully.");
            }
        }
    </script>
}