@section Scripts {
<script>
    let _pid = null, _name = '', _reason = '';
    let allVerified = [], allPending = [], allArchived = [];
    let currentTab = 'tab-verified';

    // ── Tab switching ────────────────────────────────────────────────
    function switchTab(el) {
        document.querySelectorAll('.tab-pill').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-section').forEach(s => s.style.display = 'none');
        el.classList.add('active');
        currentTab = el.dataset.tab;
        document.getElementById(currentTab).style.display = 'block';
        applySearch();
    }

    // ── Search ───────────────────────────────────────────────────────
    let searchTimer;
    document.getElementById('paySearch').addEventListener('input', function () {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(applySearch, 250);
    });
    function applySearch() {
        const q = document.getElementById('paySearch').value.toLowerCase().trim();
        if (currentTab === 'tab-verified') filterAndRender(allVerified, q, renderVerifiedRows);
        if (currentTab === 'tab-pending')  filterAndRenderPending(allPending, q);
        if (currentTab === 'tab-archived') filterAndRender(allArchived, q, renderArchivedRows);
    }
    function filterAndRender(data, q, renderFn) {
        const filtered = q ? data.filter(r => searchMatch(r, q)) : data;
        document.getElementById('resultCount').textContent = filtered.length;
        renderFn(filtered);
    }
    function filterAndRenderPending(data, q) {
        const filtered = q ? data.filter(r => searchMatch(r, q)) : data;
        const gcash   = filtered.filter(r => (r.paymentMethod||'').toLowerCase() !== 'on-site');
        const onsite  = filtered.filter(r => (r.paymentMethod||'').toLowerCase() === 'on-site');
        document.getElementById('resultCount').textContent = filtered.length;
        renderGcashRows(gcash);
        renderOnsiteRows(onsite);
    }
    function searchMatch(r, q) {
        return (r.studentName||'').toLowerCase().includes(q) ||
               (r.studentNumber||'').toLowerCase().includes(q) ||
               (r.referenceNumber||'').toLowerCase().includes(q) ||
               (r.paymentType||'').toLowerCase().includes(q);
    }

    // ── Load all — runs 3 fetch calls in parallel ─────────────────────
    async function loadAll() {
        // Show per-tab spinners while loading
        ['bodyVerified','bodyGcash','bodyOnsite','bodyArchived'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:1.5rem;color:var(--text-3);"><span class="spinner-border spinner-border-sm me-2"></span>Loading…</td></tr>`;
        });

        const [verified, pending, archived] = await Promise.all([
            fetchPayments('Verified'),
            fetchPayments('Pending'),
            fetchPayments('Rejected')
        ]);

        allVerified = verified;
        allPending  = pending;
        allArchived = archived;

        const gcash  = pending.filter(r => (r.paymentMethod||'').toLowerCase() !== 'on-site');
        const onsite = pending.filter(r => (r.paymentMethod||'').toLowerCase() === 'on-site');

        renderVerifiedRows(allVerified);
        renderGcashRows(gcash);
        renderOnsiteRows(onsite);
        renderArchivedRows(allArchived);

        // Tab counts
        document.getElementById('tc-verified').textContent  = allVerified.length;
        document.getElementById('tc-pending').textContent   = allPending.length;
        document.getElementById('tc-archived').textContent  = allArchived.length;

        // Hero stats
        const total = allVerified.reduce((s, r) => s + (r.amount || 0), 0);
        document.getElementById('statVerifiedCount').textContent = allVerified.length;
        document.getElementById('statVerifiedAmt').textContent   = '₱' + total.toLocaleString('en-PH');
        document.getElementById('statPendingCount').textContent  = gcash.length;
        document.getElementById('statOnsiteCount').textContent   = onsite.length;
        document.getElementById('statArchivedCount').textContent = allArchived.length;

        const wp = gcash.filter(r => r.proofOfPaymentPath).length;
        document.getElementById('proofCount').textContent = wp ? `${wp} with proof` : '';
        document.getElementById('resultCount').textContent = allVerified.length;
    }

    async function fetchPayments(status) {
        try {
            const r = await fetch(`/PaymentAdmin/GetPayments?status=${status}`);
            const d = await r.json();
            return d.success ? d.data : [];
        } catch { return []; }
    }

    // ── Helpers ──────────────────────────────────────────────────────
    function proofCell(r, canAct) {
        const fn = `openProof(${r.paymentId},'${jse(r.proofOfPaymentPath)}','${jse(r.studentName)}','${jse(r.referenceNumber||'')}',${r.amount},'${jse(r.paymentType)}','${jse(r.paymentDate)}',${canAct})`;
        if (!r.proofOfPaymentPath)
            return `<button class="btn-preview awaiting" disabled><i class="bi bi-hourglass-split"></i> ${canAct ? 'Awaiting' : 'N/A'}</button>`;
        return `<div class="proof-cell">
            <button class="btn-preview" onclick="${fn}"><i class="bi bi-image"></i> Preview</button>
            <a class="btn-view-proof" href="/PaymentAdmin/PaymentProof?id=${r.paymentId}" target="_blank"><i class="bi bi-file-earmark-text"></i> View Proof</a>
        </div>`;
    }
    function refChip(ref, copy = true) {
        if (!ref) return '<span style="font-size:.75rem;color:var(--text-3);">—</span>';
        const click = copy ? `onclick="copyRef('${jse(ref)}',this)" title="Click to copy"` : '';
        return `<span class="ref-chip" ${click}><i class="bi bi-hash"></i>${esc(ref)}${copy ? '<i class="bi bi-clipboard"></i>' : ''}</span>`;
    }
    function emptyState(cols, icon, msg) {
        return `<tr class="empty-row"><td colspan="${cols}"><div class="empty-icon-wrap"><i class="bi bi-${icon}"></i></div>${msg}</td></tr>`;
    }
    function methodBadge(m) {
        return m === 'On-Site'
            ? `<span class="method-badge-onsite">${esc(m)}</span>`
            : `<span class="method-badge">${esc(m)}</span>`;
    }

    // ── Render: Verified ─────────────────────────────────────────────
    function renderVerifiedRows(rows) {
        const tb = document.getElementById('bodyVerified');
        if (!rows.length) { tb.innerHTML = emptyState(9, 'check-circle', 'No verified payments yet.'); return; }
        tb.innerHTML = rows.map(r => `
            <tr id="vr-${r.paymentId}">
                <td><div class="student-name">${esc(r.studentName)}</div><div class="student-snum">${esc(r.studentNumber||'')}</div></td>
                <td><span class="type-badge">${esc(r.paymentType)}</span></td>
                <td>${methodBadge(r.paymentMethod)}</td>
                <td><span class="amount-val">₱${Number(r.amount).toLocaleString()}</span></td>
                <td>${refChip(r.referenceNumber)}</td>
                <td style="font-size:.75rem;color:var(--text-2);">${r.paymentDate}</td>
                <td><span class="verified-by">${esc(r.verifiedBy||'—')}</span></td>
                <td>${proofCell(r, false)}</td>
                <td><button class="btn-archive" onclick="archivePayment(${r.paymentId},'${jse(r.studentName)}')"><i class="bi bi-archive"></i> Archive</button></td>
            </tr>`).join('');
    }

    // ── Render: GCash Pending ────────────────────────────────────────
    function renderGcashRows(rows) {
        const tb = document.getElementById('bodyGcash');
        if (!rows.length) {
            tb.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:1.5rem 2rem;color:var(--text-3);font-size:.82rem;"><i class="bi bi-phone" style="margin-right:.4rem;"></i>No pending GCash payments.</td></tr>`;
            return;
        }
        tb.innerHTML = rows.map(r => `
            <tr id="pr-${r.paymentId}" class="${r.proofOfPaymentPath ? 'has-proof' : ''}">
                <td><div class="student-name">${esc(r.studentName)}</div><div class="student-snum">${esc(r.studentNumber||'')}</div></td>
                <td><span class="type-badge">${esc(r.paymentType)}</span></td>
                <td><span class="amount-val">₱${Number(r.amount).toLocaleString()}</span></td>
                <td>${refChip(r.referenceNumber)}</td>
                <td style="font-size:.75rem;color:var(--text-2);">${r.paymentDate}</td>
                <td>${proofCell(r, true)}</td>
            </tr>`).join('');
    }

    // ── Render: On-Site Pending ──────────────────────────────────────
    function renderOnsiteRows(rows) {
        const tb    = document.getElementById('bodyOnsite');
        const count = document.getElementById('onsiteDividerCount');
        count.textContent = rows.length;
        if (!rows.length) {
            tb.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:1.5rem 2rem;color:var(--orange);font-size:.82rem;background:#fffbf7;"><i class="bi bi-building" style="margin-right:.4rem;"></i>No on-site payments pending.</td></tr>`;
            return;
        }
        tb.innerHTML = rows.map(r => `
            <tr id="os-${r.paymentId}" class="is-onsite">
                <td><div class="student-name">${esc(r.studentName)}</div><div class="student-snum">${esc(r.studentNumber||'')}</div></td>
                <td><span class="type-badge">${esc(r.paymentType)}</span></td>
                <td><span class="amount-val">₱${Number(r.amount).toLocaleString()}</span></td>
                <td>${refChip(r.referenceNumber)}</td>
                <td style="font-size:.75rem;color:var(--text-2);">${r.paymentDate}</td>
                <td style="display:flex;gap:.35rem;flex-wrap:wrap;">
                    <button class="btn-convert" onclick="openConvertModal(${r.paymentId},'${jse(r.studentName)}')">
                        <i class="bi bi-check-circle-fill"></i> Mark as Paid
                    </button>
                    <button class="btn-archive" onclick="archivePayment(${r.paymentId},'${jse(r.studentName)}')">
                        <i class="bi bi-archive"></i>
                    </button>
                </td>
            </tr>`).join('');
    }

    // ── Render: Archived ─────────────────────────────────────────────
    function renderArchivedRows(rows) {
        const tb = document.getElementById('bodyArchived');
        if (!rows.length) { tb.innerHTML = emptyState(8, 'archive', 'No archived records.'); return; }
        tb.innerHTML = rows.map(r => `
            <tr>
                <td><div class="student-name">${esc(r.studentName)}</div><div class="student-snum">${esc(r.studentNumber||'')}</div></td>
                <td><span class="type-badge">${esc(r.paymentType)}</span></td>
                <td><span class="amount-val amount-red">₱${Number(r.amount).toLocaleString()}</span></td>
                <td>${methodBadge(r.paymentMethod)}</td>
                <td>${refChip(r.referenceNumber, false)}</td>
                <td style="font-size:.75rem;color:var(--text-2);">${r.paymentDate}</td>
                <td><span class="reason-badge">${esc(r.remarks||'Declined')}</span></td>
                <td><button class="btn-restore" onclick="restorePayment(${r.paymentId},'${jse(r.studentName)}')"><i class="bi bi-arrow-counterclockwise"></i> Restore</button></td>
            </tr>`).join('');
    }

    // ── Convert On-Site → Verified (calls VerifyOnsitePayment) ───────
    function openConvertModal(paymentId, studentName) {
        _pid = paymentId; _name = studentName;
        document.getElementById('convertStudentName').textContent = studentName;
        document.getElementById('convertOR').value = '';
        document.getElementById('convertRemarks').value = '';
        document.getElementById('convertAlert').style.display = 'none';
        document.getElementById('convertEmailStatus').style.display = 'none';
        document.getElementById('convertSubmitBtn').disabled = false;
        document.getElementById('convertCancelBtn').disabled = false;
        new bootstrap.Modal(document.getElementById('convertModal')).show();
    }

    async function submitConvert() {
        const or      = document.getElementById('convertOR').value.trim();
        const remarks = document.getElementById('convertRemarks').value.trim();

        if (!or) { showConvertAlert('Please enter the OR number.', 'warning'); return; }

        // Lock buttons while saving
        document.getElementById('convertSubmitBtn').disabled = true;
        document.getElementById('convertCancelBtn').disabled = true;
        document.getElementById('convertSubmitBtn').innerHTML =
            '<span class="spinner-border spinner-border-sm me-1"></span>Saving…';

        const row = document.getElementById(`os-${_pid}`);
        if (row) row.classList.add('flash-green');

        try {
            // ── Call the dedicated VerifyOnsitePayment endpoint ────────
            // This saves the OR number, marks Verified, updates student
            // PaymentStatus to "Paid", and sends the confirmation email.
            const r = await fetch('/PaymentAdmin/VerifyOnsitePayment', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    paymentId:             _pid,
                    officialReceiptNumber: or,
                    remarks:               remarks
                })
            });
            const d = await r.json();

            document.getElementById('convertSubmitBtn').disabled = false;
            document.getElementById('convertCancelBtn').disabled = false;
            document.getElementById('convertSubmitBtn').innerHTML =
                '<i class="bi bi-check-lg me-1"></i>Confirm &amp; Mark Paid';

            if (d.success) {
                // Show email status inside the modal before closing
                const emailEl = document.getElementById('convertEmailStatus');
                if (d.emailSent) {
                    emailEl.className = 'alert border-0 py-2 small mt-2';
                    emailEl.style.cssText = 'display:block;background:#dcfce7;color:#15803d;';
                    emailEl.innerHTML = '<i class="bi bi-envelope-check-fill me-1"></i>' + esc(d.message);
                } else {
                    emailEl.className = 'alert border-0 py-2 small mt-2';
                    emailEl.style.cssText = 'display:block;background:#fef3c7;color:#92400e;';
                    emailEl.innerHTML = '<i class="bi bi-envelope-exclamation me-1"></i>' + esc(d.message);
                }

                toast(`On-site payment verified — ${_name}`, 'success');

                // Close after a brief moment so admin can see the email status
                setTimeout(() => {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('convertModal'));
                    if (modal) modal.hide();
                    loadAll();
                }, 1800);
            } else {
                showConvertAlert(d.message || 'Error.', 'danger');
            }
        } catch (e) {
            document.getElementById('convertSubmitBtn').disabled = false;
            document.getElementById('convertCancelBtn').disabled = false;
            document.getElementById('convertSubmitBtn').innerHTML =
                '<i class="bi bi-check-lg me-1"></i>Confirm &amp; Mark Paid';
            showConvertAlert('Network error: ' + e.message, 'danger');
        }
    }

    function showConvertAlert(msg, type) {
        const el = document.getElementById('convertAlert');
        el.className = `alert alert-${type} mt-2`; el.textContent = msg; el.style.display = 'block';
    }

    // ── Proof modal ──────────────────────────────────────────────────
    function openProof(paymentId, path, student, ref, amount, purpose, date, canAct) {
        _pid = paymentId; _name = student;
        document.getElementById('proofModalSub').textContent = student;
        document.getElementById('pmStudent').textContent     = student;
        document.getElementById('pmRef').textContent         = ref || '—';
        document.getElementById('pmAmount').textContent      = '₱' + Number(amount).toLocaleString();
        document.getElementById('pmPurpose').textContent     = purpose;
        document.getElementById('pmDate').textContent        = date;
        document.getElementById('modalApproveBtn').style.display = canAct ? 'inline-flex' : 'none';
        document.getElementById('modalDeclineBtn').style.display = canAct ? 'inline-flex' : 'none';
        document.getElementById('proofPageLink').href = `/PaymentAdmin/PaymentProof?id=${paymentId}`;
        const imgSrc = path.startsWith('http') ? path : (path.startsWith('/') ? path : '/' + path);
        document.getElementById('proofOpenFull').href = imgSrc;
        document.getElementById('proofStateLoading').style.display = 'block';
        document.getElementById('proofStateError').style.display   = 'none';
        document.getElementById('proofStateImage').style.display   = 'none';
        const img = document.getElementById('proofImg');
        img.onload  = () => { document.getElementById('proofStateLoading').style.display = 'none'; document.getElementById('proofStateImage').style.display = 'block'; };
        img.onerror = () => { document.getElementById('proofStateLoading').style.display = 'none'; document.getElementById('proofStateError').style.display = 'block'; document.getElementById('proofErrPath').textContent = imgSrc; document.getElementById('proofErrLink').href = imgSrc; };
        img.src = ''; img.src = imgSrc;
        new bootstrap.Modal(document.getElementById('proofViewModal')).show();
    }
    function approveFromModal() { bootstrap.Modal.getInstance(document.getElementById('proofViewModal')).hide(); setTimeout(() => approvePayment(_pid, _name), 300); }
    function declineFromModal()  { bootstrap.Modal.getInstance(document.getElementById('proofViewModal')).hide(); setTimeout(() => openDeclineModal(_pid, _name), 300); }

    async function approvePayment(paymentId, studentName) {
        if (!confirm(`Approve payment for ${studentName}?`)) return;
        const row = document.getElementById(`pr-${paymentId}`);
        if (row) row.classList.add('flash-green');
        try {
            const r = await fetch('/PaymentAdmin/UpdatePaymentStatus', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({paymentId, status:'Verified', remarks:''}) });
            const d = await r.json();
            if (d.success) { toast(`Payment approved — ${studentName}`, 'success'); setTimeout(loadAll, 700); }
            else toast(d.message || 'Error.', 'danger');
        } catch { toast('Network error.', 'danger'); }
    }
    async function archivePayment(paymentId, studentName) {
        if (!confirm(`Archive payment for ${studentName}?`)) return;
        const row = document.getElementById(`vr-${paymentId}`) || document.getElementById(`os-${paymentId}`);
        if (row) row.classList.add('flash-red');
        try {
            const r = await fetch('/PaymentAdmin/UpdatePaymentStatus', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({paymentId, status:'Rejected', remarks:'Archived by admin'}) });
            const d = await r.json();
            if (d.success) { toast(`Archived — ${studentName}`, 'warning'); setTimeout(loadAll, 700); }
            else toast(d.message || 'Error.', 'danger');
        } catch { toast('Network error.', 'danger'); }
    }
    function openDeclineModal(paymentId, studentName) {
        _pid = paymentId; _name = studentName; _reason = '';
        document.getElementById('declineStudentName').textContent = studentName;
        document.querySelectorAll('.reject-reason-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('customReasonBox').style.display = 'none';
        document.getElementById('customReason').value = '';
        document.getElementById('declineAlert').style.display = 'none';
        new bootstrap.Modal(document.getElementById('declineModal')).show();
    }
    function pickReason(btn, reason) {
        document.querySelectorAll('.reject-reason-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active'); _reason = reason;
        document.getElementById('customReasonBox').style.display = reason === 'Other' ? 'block' : 'none';
    }
    async function submitDecline() {
        const reason = _reason === 'Other' ? document.getElementById('customReason').value.trim() : _reason;
        if (!reason) { showDeclineAlert('Please select or enter a reason.', 'warning'); return; }
        const row = document.getElementById(`pr-${_pid}`);
        if (row) row.classList.add('flash-red');
        try {
            const r = await fetch('/PaymentAdmin/UpdatePaymentStatus', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({paymentId:_pid, status:'Rejected', remarks:reason}) });
            const d = await r.json();
            if (d.success) { bootstrap.Modal.getInstance(document.getElementById('declineModal')).hide(); toast(`Payment declined — ${_name}`, 'warning'); setTimeout(loadAll, 700); }
            else showDeclineAlert(d.message || 'Error.', 'danger');
        } catch { showDeclineAlert('Network error.', 'danger'); }
    }
    function showDeclineAlert(msg, type) {
        const el = document.getElementById('declineAlert');
        el.className = `alert alert-${type} mt-3`; el.textContent = msg; el.style.display = 'block';
    }
    async function restorePayment(paymentId, studentName) {
        if (!confirm(`Restore payment for ${studentName} back to Pending?`)) return;
        try {
            const r = await fetch('/PaymentAdmin/UpdatePaymentStatus', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({paymentId, status:'Pending', remarks:''}) });
            const d = await r.json();
            if (d.success) { toast(`Restored — ${studentName}`, 'success'); setTimeout(loadAll, 700); }
            else toast(d.message || 'Error.', 'danger');
        } catch { toast('Network error.', 'danger'); }
    }

    // ── GCash Banner ─────────────────────────────────────────────────
    async function loadGCashBanner() {
        try {
            const r = await fetch('/PaymentAdmin/GetGCashConfig');
            const d = await r.json();
            if (d.success) {
                document.getElementById('gcashBannerName').textContent   = d.accountName;
                document.getElementById('gcashBannerNumber').textContent = fmtPhone(d.gcashNumber);
                document.getElementById('gcashBannerDesc').textContent   = d.paymentDescription || '';
            } else {
                document.getElementById('gcashBannerName').textContent = 'GCash not configured yet';
                document.getElementById('gcashBannerNumber').textContent = '';
                document.getElementById('gcashBannerDesc').textContent = 'Configure via GCash Setup';
            }
        } catch {}
    }
    function fmtPhone(n) { n = (n||'').replace(/\D/g,''); return n.replace(/(\d{4})(\d{3})(\d{4})/, '$1-$2-$3'); }
    function copyRef(ref, el) {
        navigator.clipboard.writeText(ref).then(() => {
            const orig = el.innerHTML;
            el.innerHTML = `<i class="bi bi-check-lg" style="color:var(--green)"></i>&nbsp;Copied!`;
            setTimeout(() => el.innerHTML = orig, 1600);
        });
    }
    function toast(msg, type = 'info') {
        const rack  = document.getElementById('toast-rack');
        const icons = { success:'bi-check-circle-fill', danger:'bi-x-circle-fill', warning:'bi-exclamation-circle-fill', info:'bi-info-circle-fill' };
        const el    = document.createElement('div');
        el.className = `toast-item ${type}`;
        el.innerHTML = `<i class="bi ${icons[type]||icons.info}"></i>${esc(msg)}`;
        rack.appendChild(el);
        setTimeout(() => el.style.opacity = '0', 3200);
        setTimeout(() => el.remove(), 3600);
    }
    function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function jse(s) { return (s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

    // ══════════════════════════════════════════════════════════════════
    // MANUAL PAYMENT
    // ══════════════════════════════════════════════════════════════════
    function openManualModal() {
        ['mpStudentId','mpStudentName','mpAmount','mpOR'].forEach(id => {
            const el = document.getElementById(id);
            el.value = '';
            if (el.dataset) el.dataset.resolvedId = '';
        });
        document.getElementById('mpPurpose').value  = '';
        document.getElementById('mpLocation').value = "Cashier's Office, Second Floor";
        hideMpMsg();
        document.getElementById('manualPayOverlay').classList.add('open');
    }
    function closeManualModal() {
        document.getElementById('manualPayOverlay').classList.remove('open');
    }
    document.getElementById('manualPayOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeManualModal();
    });

    let lookupTimer;
    function lookupStudent(val) {
        clearTimeout(lookupTimer);
        const nameEl  = document.getElementById('mpStudentName');
        const spinner = document.getElementById('lookupSpinner');
        nameEl.value  = '';
        nameEl.classList.remove('auto-filled');
        document.getElementById('mpStudentId').dataset.resolvedId = '';

        if (!val || val.trim().length < 2) { spinner.style.display = 'none'; return; }
        spinner.style.display = 'block';

        lookupTimer = setTimeout(async () => {
            try {
                const r = await fetch(`/Admin/GetStudentByNumber?studentNumber=${encodeURIComponent(val.trim())}`);
                const d = await r.json();
                spinner.style.display = 'none';
                if (d.success) {
                    nameEl.value = d.fullName || `Student ${val}`;
                    nameEl.classList.add('auto-filled');
                    document.getElementById('mpStudentId').dataset.resolvedId = d.studentId;
                } else {
                    nameEl.value = 'Student not found';
                    nameEl.classList.remove('auto-filled');
                }
            } catch {
                spinner.style.display = 'none';
                nameEl.value = 'Lookup failed — check connection';
            }
        }, 500);
    }

    function showMpMsg(msg, type) {
        const el = document.getElementById('mpMsg');
        const styles = { success:'background:var(--green-bg);color:var(--green)', danger:'background:var(--red-bg);color:var(--red)', info:'background:var(--navy-pale);color:var(--text-2)' };
        el.style.cssText = `display:block;font-size:.77rem;font-weight:700;padding:.42rem .7rem;border-radius:var(--radius-xs);margin-bottom:.75rem;${styles[type]||styles.info}`;
        el.textContent = msg;
    }
    function hideMpMsg() { document.getElementById('mpMsg').style.display = 'none'; }

    async function submitManualPayment() {
        const studentNumber = document.getElementById('mpStudentId').value.trim();
        const sid    = parseInt(document.getElementById('mpStudentId').dataset.resolvedId || '0') || 0;
        const type   = document.getElementById('mpPurpose').value;
        const amount = parseFloat(document.getElementById('mpAmount').value);
        const or     = document.getElementById('mpOR').value.trim();
        const loc    = document.getElementById('mpLocation').value;
        const name   = document.getElementById('mpStudentName').value;

        if (!studentNumber)     { showMpMsg('Enter a student number.', 'danger'); return; }
        if (!sid)               { showMpMsg('Student not found. Please check the number.', 'danger'); return; }
        if (name === 'Student not found' || name === 'Lookup failed — check connection')
                                { showMpMsg('Student not found. Please check the number.', 'danger'); return; }
        if (!type)              { showMpMsg('Select a payment purpose.', 'danger'); return; }
        if (!amount||amount<=0) { showMpMsg('Enter a valid amount.', 'danger'); return; }
        if (!or)                { showMpMsg('Enter the OR number.', 'danger'); return; }
        if (!loc)               { showMpMsg('Select a payment office.', 'danger'); return; }

        showMpMsg('Recording payment…', 'info');
        try {
            const r = await fetch('/PaymentAdmin/RecordManualPayment', {
                method: 'POST', headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ studentId: sid, paymentType: type, amount, receiptNumber: or, paymentLocation: loc })
            });
            const d = await r.json();
            if (d.success) { toast('Manual payment recorded successfully.', 'success'); closeManualModal(); loadAll(); }
            else showMpMsg(d.message || 'Failed to record payment.', 'danger');
        } catch { showMpMsg('Network error. Please try again.', 'danger'); }
    }

    // ── Init ─────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => { loadGCashBanner(); loadAll(); });
</script>
}
