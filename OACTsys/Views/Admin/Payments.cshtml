@{
    ViewBag.Title = "Payment Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    :root {
        --navy:        #051094;
        --navy-deep:   #030b72;
        --navy-soft:   #1a3fd4;
        --navy-tint:   #e8ebff;
        --navy-pale:   #f0f3ff;
        --accent-glow: rgba(59,130,246,.18);
        --green:       #16a34a;
        --green-bg:    #dcfce7;
        --amber:       #d97706;
        --amber-bg:    #fef3c7;
        --red:         #dc2626;
        --red-bg:      #fee2e2;
        --sky:         #0284c7;
        --sky-bg:      #e0f2fe;
        --orange:      #ea580c;
        --orange-bg:   #fff7ed;
        --white:       #ffffff;
        --surface:     #f5f7ff;
        --border:      #e2e7ff;
        --text-1:      #0d1b4b;
        --text-2:      #4a5b8a;
        --text-3:      #8a97c0;
        --shadow-sm:   0 1px 3px rgba(5,16,148,.08);
        --shadow-md:   0 4px 16px rgba(5,16,148,.10);
        --shadow-lg:   0 12px 40px rgba(5,16,148,.14);
        --radius:      14px;
        --radius-sm:   9px;
        --radius-xs:   6px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--surface); }

    .pm-hero {
        background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 50%, var(--navy-soft) 100%);
        padding: 2rem 2rem 3.8rem; position: relative; overflow: hidden;
    }
    .pm-hero::before {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background:
            radial-gradient(ellipse 55% 70% at 85% -5%, rgba(59,130,246,.25) 0%, transparent 55%),
            radial-gradient(ellipse 35% 55% at -5% 105%, rgba(255,255,255,.07) 0%, transparent 50%);
    }
    .pm-hero::after {
        content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 44px;
        background: var(--surface); clip-path: ellipse(55% 100% at 50% 100%);
    }
    .pm-hero-inner { position: relative; z-index: 2; display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; }
    .pm-hero-title { font-size: clamp(1.55rem, 3vw, 2.2rem); font-weight: 800; color: #fff; letter-spacing: -.5px; margin: 0 0 .3rem; line-height: 1.15; }
    .pm-hero-sub { font-size: .81rem; color: rgba(255,255,255,.62); margin: 0; font-weight: 500; line-height: 1.55; max-width: 480px; }
    .pm-hero-sub strong { color: rgba(255,255,255,.9); }
    .pm-stats-row { display: flex; gap: .65rem; flex-wrap: wrap; margin-top: 1.35rem; }
    .pm-stat-pill { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.18); backdrop-filter: blur(6px); border-radius: 50px; padding: .33rem .9rem; display: flex; align-items: center; gap: .45rem; font-size: .75rem; font-weight: 700; color: rgba(255,255,255,.88); white-space: nowrap; user-select: none; }
    .pm-stat-pill .pill-count { background: rgba(255,255,255,.22); border-radius: 50px; padding: .08rem .48rem; font-size: .68rem; font-weight: 800; min-width: 20px; text-align: center; }
    .stat-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .btn-refresh { background: rgba(255,255,255,.13); color: #fff; border: 1.5px solid rgba(255,255,255,.28); border-radius: var(--radius-sm); padding: .62rem 1rem; font-size: .81rem; font-weight: 700; font-family: inherit; display: inline-flex; align-items: center; gap: .45rem; cursor: pointer; white-space: nowrap; transition: background .2s; }
    .btn-refresh:hover { background: rgba(255,255,255,.23); }
    .btn-gcash-setup-hero { background: #fff; color: var(--navy); border: none; border-radius: var(--radius-sm); padding: .62rem 1.2rem; font-size: .81rem; font-weight: 800; font-family: inherit; display: inline-flex; align-items: center; gap: .45rem; text-decoration: none; white-space: nowrap; cursor: pointer; box-shadow: 0 4px 18px rgba(0,0,0,.22); transition: transform .2s, box-shadow .2s; }
    .btn-gcash-setup-hero:hover { color: var(--navy-deep); transform: translateY(-2px); box-shadow: 0 8px 26px rgba(0,0,0,.28); }

    .gcash-banner { background: linear-gradient(135deg, var(--navy-deep), #1a3a5c); margin: 0 1.5rem; border-radius: var(--radius); padding: 1.1rem 1.4rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; box-shadow: var(--shadow-md); position: relative; z-index: 5; margin-top: -1.6rem; }
    .gcash-banner-info { display: flex; align-items: center; gap: .9rem; }
    .gcash-icon-box { width: 42px; height: 42px; background: rgba(255,255,255,.1); border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .gcash-name   { color: #fff; font-size: .88rem; font-weight: 800; margin: 0 0 1px; }
    .gcash-number { color: #00d4aa; font-size: .85rem; font-weight: 700; font-family: monospace; }
    .gcash-desc   { color: rgba(255,255,255,.45); font-size: .71rem; margin: 0; }

    .pm-toolbar { background: var(--white); border-bottom: 1px solid var(--border); padding: .65rem 1.5rem; display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; position: sticky; top: 0; z-index: 50; box-shadow: var(--shadow-sm); margin-top: 1.4rem; }
    .toolbar-div { width: 1px; height: 26px; background: var(--border); flex-shrink: 0; }
    .tab-pills { display: flex; gap: .4rem; }
    .tab-pill { background: var(--surface); border: 1.5px solid var(--border); border-radius: 50px; padding: .38rem 1rem; font-size: .77rem; font-weight: 700; color: var(--text-2); cursor: pointer; display: flex; align-items: center; gap: .45rem; transition: all .18s; white-space: nowrap; user-select: none; }
    .tab-pill:hover { border-color: var(--navy); color: var(--navy); }
    .tab-pill.active { background: var(--navy); color: #fff; border-color: var(--navy); box-shadow: 0 2px 10px rgba(5,16,148,.28); }
    .tab-pill .tc { background: rgba(255,255,255,.25); border-radius: 50px; padding: .06rem .42rem; font-size: .66rem; font-weight: 800; min-width: 18px; text-align: center; }
    .tab-pill:not(.active) .tc { background: var(--border); color: var(--text-2); }
    .search-wrap { position: relative; flex: 1; min-width: 180px; max-width: 280px; }
    .search-wrap i { position: absolute; left: .82rem; top: 50%; transform: translateY(-50%); color: var(--text-3); font-size: .85rem; pointer-events: none; }
    .search-input { width: 100%; padding: .55rem .9rem .55rem 2.35rem; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: inherit; font-size: .82rem; color: var(--text-1); background: var(--surface); outline: none; transition: border-color .2s, box-shadow .2s; }
    .search-input:focus { border-color: var(--navy); background: #fff; box-shadow: 0 0 0 3px var(--accent-glow); }
    .search-input::placeholder { color: var(--text-3); }
    .result-badge { font-size: .74rem; font-weight: 700; color: var(--text-2); background: var(--navy-pale); border: 1px solid var(--border); border-radius: 50px; padding: .22rem .72rem; white-space: nowrap; }

    .pm-content { padding: 1rem 1.5rem 3rem; }
    .table-card { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); }

    .section-divider { display: flex; align-items: center; gap: .75rem; padding: .6rem 1.25rem; border-top: 1.5px solid var(--border); border-bottom: 1.5px solid var(--border); background: var(--surface); }
    .section-divider-label { font-size: .68rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; white-space: nowrap; }
    .section-divider-line { flex: 1; height: 1px; background: var(--border); }
    .section-divider-count { font-size: .65rem; font-weight: 700; border-radius: 50px; padding: .1rem .55rem; }
    .section-divider.onsite-divider { background: var(--orange-bg); border-color: #fdba74; }
    .section-divider.onsite-divider .section-divider-label { color: var(--orange); }
    .section-divider.onsite-divider .section-divider-count { background: #fff7ed; color: var(--orange); border: 1px solid #fdba74; }
    .section-divider.onsite-divider .section-divider-line  { background: #fdba74; }

    .pm-table tbody tr.is-onsite { background: #fffbf7; border-left: 3px solid var(--orange); }
    .pm-table tbody tr.is-onsite:hover { background: var(--orange-bg); }

    .pending-notice { display: flex; align-items: center; gap: .65rem; background: var(--amber-bg); border-bottom: 1.5px solid #fcd34d; padding: .65rem 1.25rem; font-size: .78rem; font-weight: 600; color: var(--amber); }
    .pending-notice i { flex-shrink: 0; }
    .proof-badge { margin-left: auto; background: #fbbf24; color: #fff; border-radius: 50px; padding: .1rem .6rem; font-size: .68rem; font-weight: 800; }

    .pm-table { width: 100%; border-collapse: collapse; table-layout: auto; }
    .pm-table thead th { background: var(--navy); color: #fff; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; padding: .6rem .75rem; border: none; white-space: nowrap; }
    .pm-table thead th:first-child { padding-left: 1.1rem; }
    .pm-table tbody tr { border-bottom: 1px solid var(--border); transition: background .15s; }
    .pm-table tbody tr:last-child { border-bottom: none; }
    .pm-table tbody tr:hover { background: var(--navy-pale); }
    .pm-table tbody tr.has-proof { border-left: 3px solid var(--amber); }
    .pm-table td { padding: .6rem .75rem; font-size: .78rem; color: var(--text-1); vertical-align: middle; }
    .pm-table td:first-child { padding-left: 1.1rem; }

    .student-name { font-weight: 700; color: var(--text-1); line-height: 1.2; font-size: .78rem; }
    .student-snum { font-size: .67rem; color: var(--text-3); }
    .type-badge   { font-size: .62rem; font-weight: 800; letter-spacing: .3px; text-transform: uppercase; padding: .16rem .5rem; border-radius: 50px; background: var(--sky-bg); color: var(--sky); white-space: nowrap; }
    .method-badge { font-size: .62rem; font-weight: 800; padding: .16rem .5rem; border-radius: 50px; background: var(--green-bg); color: var(--green); white-space: nowrap; }
    .method-badge-onsite { font-size: .62rem; font-weight: 800; padding: .16rem .5rem; border-radius: 50px; background: var(--orange-bg); color: var(--orange); white-space: nowrap; border: 1px solid #fdba74; }
    .amount-val { font-weight: 800; color: var(--text-1); font-size: .78rem; }
    .amount-red { color: var(--red); }
    .verified-by { font-size: .72rem; font-weight: 700; color: var(--navy); }

    .ref-chip { display: inline-flex; align-items: center; gap: .28rem; background: var(--navy-pale); border: 1px solid var(--border); border-radius: var(--radius-xs); padding: .18rem .5rem; font-family: monospace; font-size: .72rem; font-weight: 700; color: var(--navy); cursor: pointer; transition: background .15s; user-select: none; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ref-chip:hover { background: var(--navy-tint); }
    .ref-chip i { color: var(--text-3); font-size: .62rem; flex-shrink: 0; }
    .reason-badge { display: inline-block; background: var(--red-bg); color: var(--red); border-radius: var(--radius-xs); padding: .2rem .6rem; font-size: .7rem; font-weight: 700; max-width: 170px; white-space: normal; line-height: 1.4; }

    .btn-preview, .btn-view-proof { display: inline-flex; align-items: center; justify-content: center; gap: .28rem; width: 100px; padding: .32rem .4rem; border-radius: var(--radius-xs); font-size: .7rem; font-weight: 700; font-family: inherit; white-space: nowrap; transition: all .18s; text-decoration: none; box-sizing: border-box; }
    .btn-preview { background: var(--navy); color: #fff; border: none; cursor: pointer; }
    .btn-preview:hover { background: var(--navy-deep); }
    .btn-preview.awaiting { background: var(--surface); color: var(--text-3); border: 1.5px solid var(--border); cursor: default; pointer-events: none; }
    .btn-view-proof { background: transparent; color: var(--sky); border: 1.5px solid var(--sky); }
    .btn-view-proof:hover { background: var(--sky); color: #fff; }
    .proof-cell { display: flex; flex-direction: column; gap: .3rem; align-items: flex-start; }

    .btn-convert { display: inline-flex; align-items: center; gap: .28rem; padding: .32rem .7rem; border-radius: var(--radius-xs); font-size: .7rem; font-weight: 700; font-family: inherit; background: var(--green); color: #fff; border: none; cursor: pointer; transition: background .15s; white-space: nowrap; }
    .btn-convert:hover { background: #15803d; }
    .btn-archive { display: inline-flex; align-items: center; gap: .28rem; padding: .28rem .6rem; border-radius: var(--radius-xs); font-size: .7rem; font-weight: 700; font-family: inherit; background: transparent; color: var(--text-3); border: 1.5px solid var(--border); cursor: pointer; transition: all .15s; white-space: nowrap; }
    .btn-archive:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }
    .btn-restore { display: inline-flex; align-items: center; gap: .28rem; padding: .28rem .6rem; border-radius: var(--radius-xs); font-size: .7rem; font-weight: 700; font-family: inherit; background: transparent; color: var(--green); border: 1.5px solid var(--green); cursor: pointer; transition: all .15s; white-space: nowrap; }
    .btn-restore:hover { background: var(--green); color: #fff; }

    .empty-row td { text-align: center; padding: 3.5rem 2rem; color: var(--text-3); font-size: .85rem; }
    .empty-icon-wrap { width: 56px; height: 56px; border-radius: 50%; background: var(--navy-pale); border: 2px dashed var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--text-3); margin: 0 auto .75rem; }

    @@keyframes flash-green { 0%,100%{background:transparent} 50%{background:#dcfce7} }
    @@keyframes flash-red   { 0%,100%{background:transparent} 50%{background:#fee2e2} }
    .flash-green { animation: flash-green .7s ease; }
    .flash-red   { animation: flash-red .7s ease; }

    #proofViewModal .modal-content { background: #0f172a; border: none; border-radius: var(--radius); overflow: hidden; }
    #proofViewModal .modal-header  { background: rgba(255,255,255,.05); border-bottom: 1px solid rgba(255,255,255,.1); padding: 1rem 1.25rem; }
    #proofViewModal .modal-body    { background: #0f172a; padding: 1.25rem; }
    #proofViewModal .modal-footer  { background: rgba(255,255,255,.04); border-top: 1px solid rgba(255,255,255,.1); padding: .75rem 1.25rem; gap: .5rem; }
    .proof-meta { background: rgba(255,255,255,.06); border-radius: 10px; padding: .85rem 1rem; margin-top: 1rem; }
    .proof-meta-row { display: flex; justify-content: space-between; font-size: .8rem; padding: .28rem 0; border-bottom: 1px solid rgba(255,255,255,.05); }
    .proof-meta-row:last-child { border-bottom: none; }
    .proof-meta-row label { color: #64748b; }
    .proof-meta-row .pv { color: #f1f5f9; font-weight: 600; text-align: right; max-width: 65%; word-break: break-all; }
    .proof-meta-row .pv.teal { color: #00d4aa; font-family: monospace; }
    @@keyframes spin { to{transform:rotate(360deg)} }
    .spinner-ring { width: 38px; height: 38px; border: 3px solid #1e3a5f; border-top-color: #7dd3fc; border-radius: 50%; animation: spin .7s linear infinite; margin: 0 auto 1rem; }
    .btn-modal-approve { display: inline-flex; align-items: center; gap: .35rem; background: var(--green); color: #fff; border: none; border-radius: var(--radius-xs); padding: .42rem 1rem; font-size: .8rem; font-weight: 700; font-family: inherit; cursor: pointer; transition: background .15s; }
    .btn-modal-approve:hover { background: #15803d; }
    .btn-modal-decline { display: inline-flex; align-items: center; gap: .35rem; background: transparent; color: #ef4444; border: 1.5px solid #ef4444; border-radius: var(--radius-xs); padding: .4rem .95rem; font-size: .8rem; font-weight: 700; font-family: inherit; cursor: pointer; transition: all .15s; }
    .btn-modal-decline:hover { background: var(--red); color: #fff; border-color: var(--red); }

    #declineModal .modal-content { border-radius: var(--radius); border: none; }
    #declineModal .modal-header  { background: var(--red-bg); border-bottom: 1px solid #fecaca; }
    .reject-reason-btn { width: 100%; text-align: left; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: .55rem .9rem; font-size: .84rem; background: #fff; cursor: pointer; transition: all .15s; margin-bottom: .4rem; font-family: inherit; }
    .reject-reason-btn:hover, .reject-reason-btn.active { border-color: var(--red); background: var(--red-bg); color: var(--red); font-weight: 600; }

    #convertModal .modal-content { border-radius: var(--radius); border: none; }
    #convertModal .modal-header  { background: var(--green-bg); border-bottom: 1px solid #a7f3d0; }

    .btn-manual { background: var(--green); color: #fff; border: none; border-radius: var(--radius-sm); padding: .52rem 1rem; font-size: .78rem; font-weight: 800; font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: .4rem; white-space: nowrap; transition: background .2s, transform .18s; box-shadow: 0 2px 10px rgba(22,163,74,.28); }
    .btn-manual:hover { background: #15803d; transform: translateY(-1px); }
    .mp-overlay { display: none; position: fixed; inset: 0; background: rgba(5,16,148,.18); backdrop-filter: blur(4px); z-index: 1050; align-items: center; justify-content: center; }
    .mp-overlay.open { display: flex; }
    .mp-box { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); width: 100%; max-width: 480px; max-height: 92vh; overflow-y: auto; box-shadow: var(--shadow-lg); animation: mpIn .22s ease; }
    @@keyframes mpIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:none} }
    .mp-head { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.35rem; border-bottom: 1.5px solid var(--border); background: var(--navy-pale); }
    .mp-head-left { display: flex; align-items: center; gap: .55rem; }
    .mp-head-icon { width: 30px; height: 30px; border-radius: var(--radius-xs); background: var(--green); color: #fff; font-size: .78rem; display: flex; align-items: center; justify-content: center; }
    .mp-head-title { font-size: .88rem; font-weight: 800; color: var(--text-1); margin: 0; }
    .mp-close { background: none; border: none; color: var(--text-3); font-size: 1.1rem; cursor: pointer; line-height: 1; }
    .mp-close:hover { color: var(--red); }
    .mp-body { padding: 1.35rem; }
    .mp-field { margin-bottom: 1rem; }
    .mp-label { display: block; font-size: .75rem; font-weight: 700; color: var(--text-2); margin-bottom: .32rem; }
    .mp-label-hint { font-size: .68rem; font-weight: 500; color: var(--text-3); }
    .mp-input { width: 100%; padding: .58rem .9rem; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: inherit; font-size: .82rem; color: var(--text-1); background: var(--surface); outline: none; transition: border-color .2s, box-shadow .2s; }
    .mp-input:focus { border-color: var(--navy); background: #fff; box-shadow: 0 0 0 3px var(--accent-glow); }
    .mp-input::placeholder { color: var(--text-3); }
    .mp-input[readonly] { background: #f1f5f9; color: var(--text-2); cursor: default; }
    .mp-input.auto-filled { background: #f0fdf4; border-color: #86efac; color: var(--green); font-weight: 700; }
    .mp-msg { display: none; font-size: .77rem; font-weight: 700; padding: .42rem .7rem; border-radius: var(--radius-xs); margin-bottom: .75rem; }
    .mp-foot { padding: .85rem 1.35rem; border-top: 1.5px solid var(--border); background: var(--navy-pale); display: flex; gap: .55rem; justify-content: flex-end; }
    .btn-mp-cancel { background: var(--white); color: var(--text-2); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: .55rem 1.1rem; font-size: .8rem; font-weight: 700; font-family: inherit; cursor: pointer; transition: all .18s; }
    .btn-mp-cancel:hover { border-color: var(--text-2); color: var(--text-1); }
    .btn-mp-submit { background: var(--green); color: #fff; border: none; border-radius: var(--radius-sm); padding: .58rem 1.3rem; font-size: .8rem; font-weight: 800; font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: .4rem; box-shadow: 0 3px 10px rgba(22,163,74,.28); transition: background .18s, transform .15s; }
    .btn-mp-submit:hover { background: #15803d; transform: translateY(-1px); }

    .lookup-wrap { position: relative; }
    .lookup-spinner { position: absolute; right: .7rem; top: 50%; transform: translateY(-50%); }

    #toast-rack { position: fixed; bottom: 1.4rem; right: 1.4rem; z-index: 9999; display: flex; flex-direction: column; gap: .45rem; }
    .toast-item { background: var(--white); border-radius: var(--radius-sm); padding: .72rem 1rem; font-size: .81rem; font-weight: 600; box-shadow: var(--shadow-lg); border-left: 4px solid var(--navy); display: flex; align-items: center; gap: .55rem; min-width: 235px; color: var(--text-1); animation: toastIn .22s ease; transition: opacity .35s; }
    .toast-item.success { border-color: var(--green); }
    .toast-item.danger  { border-color: var(--red); }
    .toast-item.warning { border-color: var(--amber); }
    .toast-item i { font-size: .9rem; flex-shrink: 0; }
    .toast-item.success i { color: var(--green); }
    .toast-item.danger  i { color: var(--red); }
    .toast-item.warning i { color: var(--amber); }
    .toast-item.info    i { color: var(--navy); }
    @@keyframes toastIn { from{opacity:0;transform:translateX(14px)} to{opacity:1;transform:none} }

    @@media (max-width: 768px) {
        .pm-hero { padding: 1.5rem 1.25rem 3.5rem; }
        .pm-toolbar, .pm-content { padding-left: 1.25rem; padding-right: 1.25rem; }
        .gcash-banner { margin-left: 1rem; margin-right: 1rem; }
        .pm-hero-inner { flex-direction: column; }
        .tab-pills { overflow-x: auto; }
    }
</style>

<!-- ── HERO ── -->
<div class="pm-hero">
    <div class="pm-hero-inner">
        <div>
