                        <div class="schedule-slots">30 / 100 slots</div>
                        <span class="schedule-status status-active">Active</span>
                    </div>
                    <div class="schedule-date-card">
                        <button class="remove-date-btn" onclick="removeSchedule(this)">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="schedule-date">Feb 18, 2026</div>
                        <div class="schedule-slots">0 / 100 slots</div>
                        <span class="schedule-status status-inactive">Inactive</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Applications Tab -->
        <div class="tab-pane fade" id="applications" role="tabpanel">
            <div class="content-card">
                <h3 class="section-title">Student Applications</h3>

                <!-- Statistics -->
                <div class="stats-row">
                    <div class="stat-box">
                        <div class="stat-value">1,247</div>
                        <div class="stat-label">Total Applicants</div>
                    </div>
                    <div class="stat-box">
