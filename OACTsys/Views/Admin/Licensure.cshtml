                        <div class="schedule-slots">150 / 150 slots</div>
                        <span class="schedule-status status-full">Full</span>
                    </div>
                </div>

                <!-- Cebu Office Schedules -->
                <h5 style="color: var(--navy-blue); font-weight: 600; margin-top: 30px; margin-bottom: 15px;">
                    <i class="fas fa-building"></i> Regional Center - Cebu Schedule
                </h5>
                <div class="schedule-grid" id="cebuSchedule">
                    <div class="schedule-date-card">
                        <button class="remove-date-btn" onclick="removeSchedule(this)">
                            <i class="fas fa-times"></i>
                        </button>
