@{
    ViewBag.Title = "Licensure Examination Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --navy-blue: #001f3f;
        --light-navy: #0a2463;
        --text-dark: #2c3e50;
        --border-color: #dee2e6;
    }

    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        background: white;
        border: 2px solid var(--navy-blue);
        border-radius: 8px;
        padding: 25px;
        margin-bottom: 30px;
    }

        .page-header h1 {
            color: var(--navy-blue);
            font-weight: 700;
            margin: 0;
            font-size: 2rem;
        }

            .page-header h1 i {
                margin-right: 15px;
            }

        .page-header p {
            color: var(--text-dark);
            margin: 10px 0 0 0;
            font-size: 1rem;
        }

    /* Tabs Navigation */
    .nav-tabs-custom {
        border-bottom: 2px solid var(--navy-blue);
        margin-bottom: 30px;
    }

        .nav-tabs-custom .nav-link {
            color: var(--navy-blue);
            border: none;
            padding: 12px 25px;
            font-weight: 600;
            background: transparent;
        }

            .nav-tabs-custom .nav-link:hover {
                border: none;
                background: #f8f9fa;
            }

            .nav-tabs-custom .nav-link.active {
                color: white;
                background: var(--navy-blue);
                border: none;
                border-radius: 0;
            }

    /* Content Card */
    .content-card {
        background: white;
        border: 2px solid var(--navy-blue);
        border-radius: 8px;
        padding: 30px;
        margin-bottom: 30px;
    }

    .section-title {
        color: var(--navy-blue);
        font-weight: 600;
        font-size: 1.5rem;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--navy-blue);
    }

    /* Location Management */
    .location-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }

    .location-card {
        border: 2px solid var(--navy-blue);
        border-radius: 8px;
        padding: 20px;
        background: white;
    }

    .location-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .location-name {
        color: var(--navy-blue);
        font-weight: 700;
        font-size: 1.2rem;
        margin: 0;
    }

    .location-badge {
        background: var(--navy-blue);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .location-image-container {
        width: 100%;
        height: 200px;
        border: 2px dashed var(--border-color);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        background: #f8f9fa;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

        .location-image-container:hover {
            border-color: var(--navy-blue);
            background: #e9ecef;
        }

        .location-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .upload-placeholder {
        text-align: center;
        color: var(--navy-blue);
    }

        .upload-placeholder i {
            font-size: 2.5rem;
            margin-bottom: 10px;
            display: block;
        }

    .location-info {
        margin-bottom: 10px;
    }

        .location-info label {
            color: var(--navy-blue);
            font-weight: 600;
            font-size: 0.9rem;
            display: block;
            margin-bottom: 5px;
        }

        .location-info p {
            color: var(--text-dark);
            margin: 0;
            font-size: 0.95rem;
        }

    .location-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    /* Buttons */
    .btn-navy {
        background: var(--navy-blue);
        color: white;
        border: 2px solid var(--navy-blue);
        padding: 10px 20px;
        font-weight: 600;
        border-radius: 6px;
        transition: all 0.3s;
    }

        .btn-navy:hover {
            background: white;
            color: var(--navy-blue);
        }

    .btn-outline-navy {
        background: white;
        color: var(--navy-blue);
        border: 2px solid var(--navy-blue);
        padding: 10px 20px;
        font-weight: 600;
        border-radius: 6px;
        transition: all 0.3s;
    }

        .btn-outline-navy:hover {
            background: var(--navy-blue);
            color: white;
        }

    .btn-sm {
        padding: 6px 12px;
        font-size: 0.9rem;
    }

    /* Form Controls */
    .licensure-form-control, .licensure-form-select {
        border: 2px solid var(--border-color);
        border-radius: 6px;
        padding: 10px 15px;
        color: var(--navy-blue);
    }

        .licensure-form-control:focus, .licensure-form-select:focus {
            border-color: var(--navy-blue);
            box-shadow: 0 0 0 0.2rem rgba(0, 31, 63, 0.25);
        }

    .licensure-form-label {
        color: var(--navy-blue);
        font-weight: 600;
        margin-bottom: 8px;
    }

    /* Date Schedule Management */
    .schedule-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .schedule-date-card {
        border: 2px solid var(--navy-blue);
        border-radius: 8px;
        padding: 15px;
        text-align: center;
        background: white;
        position: relative;
    }

    .schedule-date {
        color: var(--navy-blue);
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    .schedule-slots {
        color: var(--text-dark);
        font-size: 0.9rem;
        margin-bottom: 10px;
    }

    .schedule-status {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-active {
        background: #d4edda;
        color: #155724;
    }

    .status-full {
        background: #f8d7da;
        color: #721c24;
    }

    .status-inactive {
        background: #e2e3e5;
        color: #383d41;
    }

    .remove-date-btn {
        position: absolute;
        top: 5px;
        right: 5px;
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.8rem;
    }

        .remove-date-btn:hover {
            background: #c82333;
        }

    /* Table Styles */
    .table-navy {
        width: 100%;
        margin-top: 20px;
    }

        .table-navy thead {
            background: var(--navy-blue);
            color: white;
        }

            .table-navy thead th {
                padding: 12px;
                font-weight: 600;
                border: none;
            }

        .table-navy tbody td {
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-dark);
        }

        .table-navy tbody tr:hover {
            background: #f8f9fa;
        }

    /* Modal Styles */
    .modal-header {
        background: var(--navy-blue);
        color: white;
        border-bottom: none;
    }

        .modal-header .btn-close {
            filter: invert(1);
        }

    .modal-title {
        font-weight: 700;
    }

    /* Statistics Cards */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-box {
        border: 2px solid var(--navy-blue);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        background: white;
    }

    .stat-value {
        color: var(--navy-blue);
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .stat-label {
        color: var(--text-dark);
        font-size: 0.95rem;
    }

    @@media (max-width: 768px) {
        .location-grid,
        .schedule-grid {
            grid-template-columns: 1fr;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="admin-container">
    <!-- Page Header -->
    <div class="page-header">
        <h1><i class="fas fa-certificate"></i>Licensure Examination Management</h1>
        <p>Manage examination centers, schedules, and monitor student applications</p>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs nav-tabs-custom" id="licensureTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="locations-tab" data-bs-toggle="tab" data-bs-target="#locations" type="button">
                <i class="fas fa-map-marker-alt"></i> Locations
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="schedule-tab" data-bs-toggle="tab" data-bs-target="#schedule" type="button">
                <i class="fas fa-calendar-alt"></i> Schedule Management
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="applications-tab" data-bs-toggle="tab" data-bs-target="#applications" type="button">
                <i class="fas fa-users"></i> Applications
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="licensureTabsContent">
        <!-- Locations Tab -->
        <div class="tab-pane fade show active" id="locations" role="tabpanel">
            <div class="content-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="section-title mb-0">Examination Centers</h3>
                    <button class="btn btn-navy" data-bs-toggle="modal" data-bs-target="#addLocationModal">
                        <i class="fas fa-plus"></i> Add New Location
                    </button>
                </div>

                <div class="location-grid">
                    <!-- Main Office - Navotas -->
                    <div class="location-card">
                        <div class="location-header">
                            <h4 class="location-name">Main Office - Navotas</h4>
                            <span class="location-badge">Main</span>
                        </div>

                        <div class="location-image-container" onclick="document.getElementById('imageUpload1').click()">
                            <img src="~/img/oact-main.jpg" alt="Main Office" id="locationImg1" style="display: none;">
                            <div class="upload-placeholder" id="placeholder1">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <p>Click to upload location image</p>
                            </div>
                        </div>
                        <input type="file" id="imageUpload1" accept="image/*" style="display: none;" onchange="previewImage(1)">

                        <div class="location-info">
                            <label>Address:</label>
                            <p>Orson Aerospace College, Navotas City, NCR</p>
                        </div>

                        <div class="location-info">
                            <label>Capacity:</label>
                            <p>150 examinees</p>
                        </div>

                        <div class="location-info">
                            <label>Operating Hours:</label>
                            <p>Mon-Thu: 8:00 AM - 4:00 PM<br>Fri: 8:00 AM - 11:00 AM</p>
                        </div>

                        <div class="location-actions">
                            <button class="btn btn-outline-navy btn-sm flex-fill" onclick="window.location.href='@Url.Action("EditLocation", "LicensureAdmin")'">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-outline-navy btn-sm">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Regional Center - Cebu -->
                    <div class="location-card">
                        <div class="location-header">
                            <h4 class="location-name">Regional Center - Cebu</h4>
                            <span class="location-badge">Regional</span>
                        </div>

                        <div class="location-image-container" onclick="document.getElementById('imageUpload2').click()">
                            <img src="~/img/oact-cebu.jpg" alt="Cebu Office" id="locationImg2" style="display: none;">
                            <div class="upload-placeholder" id="placeholder2">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <p>Click to upload location image</p>
                            </div>
                        </div>
                        <input type="file" id="imageUpload2" accept="image/*" style="display: none;" onchange="previewImage(2)">

                        <div class="location-info">
                            <label>Address:</label>
                            <p>Lapu-Lapu City, Mactan Island, Cebu</p>
                        </div>

                        <div class="location-info">
                            <label>Capacity:</label>
                            <p>100 examinees</p>
                        </div>

                        <div class="location-info">
                            <label>Operating Hours:</label>
                            <p>To be announced</p>
                        </div>

                        <div class="location-actions">
                            <button class="btn btn-outline-navy btn-sm flex-fill" onclick="window.location.href='@Url.Action("EditLocation", "LicensureAdmin")'">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-outline-navy btn-sm">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Schedule Management Tab -->
        <div class="tab-pane fade" id="schedule" role="tabpanel">
            <div class="content-card">
                <h3 class="section-title">Examination Schedule Management</h3>

                <!-- Add Schedule Form -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Select Location</label>
                        <select class="form-select" id="scheduleLocation">
                            <option value="">Choose location...</option>
                            <option value="navotas">Main Office - Navotas</option>
                            <option value="cebu">Regional Center - Cebu</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Exam Date</label>
                        <input type="date" class="form-control" id="examDate">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Available Slots</label>
                        <input type="number" class="form-control" id="availableSlots" placeholder="50">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="scheduleStatus">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <button class="btn btn-navy w-100" onclick="addScheduleDate()">
                            <i class="fas fa-plus"></i> Add Date
                        </button>
                    </div>
                </div>

                <!-- Main Office Schedules -->
                <h5 style="color: var(--navy-blue); font-weight: 600; margin-top: 30px; margin-bottom: 15px;">
                    <i class="fas fa-building"></i> Main Office - Navotas Schedule
                </h5>
                <div class="schedule-grid" id="navotasSchedule">
                    <div class="schedule-date-card">
                        <button class="remove-date-btn" onclick="removeSchedule(this)">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="schedule-date">Feb 10, 2026</div>
                        <div class="schedule-slots">45 / 150 slots</div>
                        <span class="schedule-status status-active">Active</span>
                    </div>
                    <div class="schedule-date-card">
                        <button class="remove-date-btn" onclick="removeSchedule(this)">
