    </div>
</div>

<!-- Add Location Modal -->
<div class="modal fade" id="addLocationModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Examination Center</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Location Name</label>
                        <input type="text" class="form-control" placeholder="e.g., Regional Center - Davao">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <textarea class="form-control" rows="2" placeholder="Full address"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Capacity</label>
                            <input type="number" class="form-control" placeholder="Number of examinees">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Type</label>
                            <select class="form-select">
                                <option value="main">Main Office</option>
                                <option value="regional">Regional Center</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Operating Hours</label>
                        <textarea class="form-control" rows="2" placeholder="e.g., Mon-Fri: 8:00 AM - 4:00 PM"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location Image</label>
                        <input type="file" class="form-control" accept="image/*">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-navy" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-navy">Save Location</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Image Preview Function
        function previewImage(locationId) {
            const input = document.getElementById('imageUpload' + locationId);
            const img = document.getElementById('locationImg' + locationId);
            const placeholder = document.getElementById('placeholder' + locationId);

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    img.style.display = 'block';
                    placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Add Schedule Date Function
        function addScheduleDate() {
            const location = document.getElementById('scheduleLocation').value;
            const date = document.getElementById('examDate').value;
            const slots = document.getElementById('availableSlots').value;
            const status = document.getElementById('scheduleStatus').value;

            if (!location || !date || !slots) {
                alert('Please fill all fields');
                return;
            }

            const formattedDate = new Date(date).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
            });

            const statusClass = status === 'active' ? 'status-active' : 'status-inactive';
            const statusText = status === 'active' ? 'Active' : 'Inactive';

            const scheduleCard = `
                <div class="schedule-date-card">
                    <button class="remove-date-btn" onclick="removeSchedule(this)">
                        <i class="fas fa-times"></i>
                    </button>
                    <div class="schedule-date">${formattedDate}</div>
                    <div class="schedule-slots">0 / ${slots} slots</div>
                    <span class="schedule-status ${statusClass}">${statusText}</span>
                </div>
            `;

            const targetContainer = location === 'navotas' ? 'navotasSchedule' : 'cebuSchedule';
            document.getElementById(targetContainer).insertAdjacentHTML('beforeend', scheduleCard);

            // Clear form
            document.getElementById('scheduleLocation').value = '';
            document.getElementById('examDate').value = '';
            document.getElementById('availableSlots').value = '';
            document.getElementById('scheduleStatus').value = 'active';

            alert('Schedule date added successfully!');
        }

        // Remove Schedule Function
        function removeSchedule(btn) {
            if (confirm('Are you sure you want to remove this schedule date?')) {
                btn.closest('.schedule-date-card').remove();
            }
        }
    </script>
}
