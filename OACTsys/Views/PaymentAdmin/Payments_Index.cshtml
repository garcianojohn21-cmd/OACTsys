@{
    ViewBag.Title = "Payment Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    decimal totalVerified  = ViewBag.TotalVerified  ?? 0;
    int     pendingCount   = ViewBag.PendingCount   ?? 0;
    decimal unpaidBalance  = ViewBag.UnpaidBalance  ?? 0;
    bool    isSuperAdmin   = (Context.Session.GetString("AdminRole") == "SuperAdmin");
}

@if (!isSuperAdmin)
{
    <div style="display:flex;align-items:center;justify-content:center;min-height:60vh;flex-direction:column;gap:1rem;background:var(--surface);">
        <div style="font-size:3rem;">🔒</div>
        <h3 style="color:var(--red);font-family:'Plus Jakarta Sans',sans-serif;">Access Restricted</h3>
        <p style="color:var(--text-3);">This page is only accessible to SuperAdmins.</p>
        <a href="/Admin/Dashboard" style="color:var(--navy);font-size:.9rem;font-weight:700;">← Back to Dashboard</a>
    </div>
    return;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    :root {
        --navy:        #051094;
        --navy-deep:   #030b72;
        --navy-soft:   #1a3fd4;
        --navy-tint:   #e8ebff;
        --navy-pale:   #f0f3ff;
        --accent-glow: rgba(59,130,246,.18);
        --green:       #16a34a;
        --green-bg:    #dcfce7;
        --amber:       #d97706;
        --amber-bg:    #fef3c7;
        --red:         #dc2626;
        --red-bg:      #fee2e2;
        --sky:         #0284c7;
        --sky-bg:      #e0f2fe;
        --purple:      #7c3aed;
        --purple-bg:   #ede9fe;
        --white:       #ffffff;
        --surface:     #f5f7ff;
        --border:      #e2e7ff;
        --text-1:      #0d1b4b;
        --text-2:      #4a5b8a;
        --text-3:      #8a97c0;
        --shadow-sm:   0 1px 3px rgba(5,16,148,.08);
        --shadow-md:   0 4px 16px rgba(5,16,148,.10);
        --shadow-lg:   0 12px 40px rgba(5,16,148,.14);
        --radius:      14px;
        --radius-sm:   9px;
        --radius-xs:   6px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--surface); }

    /* ── HERO ── */
    .pd-hero {
        background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 50%, var(--navy-soft) 100%);
        padding: 2rem 2rem 3.8rem; position: relative; overflow: hidden;
    }
    .pd-hero::before {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background:
            radial-gradient(ellipse 55% 70% at 85% -5%, rgba(59,130,246,.25) 0%, transparent 55%),
            radial-gradient(ellipse 35% 55% at -5% 105%, rgba(255,255,255,.07) 0%, transparent 50%);
    }
    .pd-hero::after {
        content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 44px;
        background: var(--surface); clip-path: ellipse(55% 100% at 50% 100%);
    }
    .pd-hero-inner {
        position: relative; z-index: 2;
        display: flex; align-items: flex-start; justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
    }
    .pd-hero-title {
        font-size: clamp(1.55rem, 3vw, 2.2rem); font-weight: 800;
        color: #fff; letter-spacing: -.5px; margin: 0 0 .3rem; line-height: 1.15;
    }
    .pd-hero-sub { font-size: .81rem; color: rgba(255,255,255,.62); margin: 0; font-weight: 500; line-height: 1.55; }
    .pd-hero-sub strong { color: rgba(255,255,255,.9); }
    .superadmin-pill {
        display: inline-flex; align-items: center; gap: .4rem;
        background: rgba(245,158,11,.2); border: 1px solid rgba(245,158,11,.4);
        border-radius: 50px; padding: .28rem .85rem; margin-top: .6rem;
        font-size: .7rem; font-weight: 800; color: #fcd34d;
        text-transform: uppercase; letter-spacing: .07em;
    }

    /* ── CONTENT ── */
    .pd-content { padding: 1.75rem 2rem 3rem; }

    /* ── ANALYTICS CARDS ── */
    .analytics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem; margin-bottom: 1.5rem;
    }
    .an-card {
        background: var(--white); border: 1.5px solid var(--border);
        border-radius: var(--radius); padding: 1.25rem 1.35rem;
        box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .an-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .an-card::before {
        content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
        border-radius: var(--radius) 0 0 var(--radius);
    }
    .an-card.green::before  { background: var(--green); }
    .an-card.amber::before  { background: var(--amber); }
    .an-card.red::before    { background: var(--red); }
    .an-card.navy::before   { background: var(--navy); }
    .an-card.sky::before    { background: var(--sky); }
    .an-card.purple::before { background: var(--purple); }
    .an-label { font-size: .7rem; font-weight: 700; color: var(--text-3); text-transform: uppercase; letter-spacing: .5px; margin-bottom: .45rem; }
    .an-value { font-size: 1.55rem; font-weight: 800; color: var(--text-1); line-height: 1.1; margin-bottom: .22rem; }
    .an-sub   { font-size: .71rem; color: var(--text-3); font-weight: 500; }
    .an-icon  { position: absolute; right: 1.1rem; top: 50%; transform: translateY(-50%); font-size: 1.6rem; opacity: .1; }
    .an-trend { display: inline-flex; align-items: center; gap: .25rem; font-size: .68rem; font-weight: 700; margin-top: .3rem; padding: .12rem .5rem; border-radius: 50px; }
    .an-trend.up   { background: var(--green-bg); color: var(--green); }
    .an-trend.down { background: var(--red-bg);   color: var(--red); }
    .an-trend.flat { background: var(--navy-pale); color: var(--text-3); }

    /* ── SECTION CARDS ── */
    .section-card {
        background: var(--white); border: 1.5px solid var(--border);
        border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);
        margin-bottom: 1.25rem;
    }
    .sc-head {
        display: flex; align-items: center; justify-content: space-between;
        gap: .65rem; padding: 1rem 1.35rem; border-bottom: 1.5px solid var(--border);
        background: var(--navy-pale); flex-wrap: wrap;
    }
    .sc-head-left { display: flex; align-items: center; gap: .6rem; }
    .sc-icon {
        width: 32px; height: 32px; border-radius: var(--radius-xs);
        background: var(--navy); color: #fff; font-size: .82rem;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .sc-title { font-size: .88rem; font-weight: 800; color: var(--text-1); margin: 0; }
    .sc-sub   { font-size: .71rem; color: var(--text-3); margin: 0; }
    .sc-body  { padding: 1.35rem; }

    /* Two-col layout inside section */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
    @@media (max-width: 900px) { .two-col, .three-col { grid-template-columns: 1fr; } }

    /* ── CHART WRAPPER ── */
    .chart-wrap { position: relative; height: 220px; }
    .chart-label { font-size: .72rem; font-weight: 700; color: var(--text-2); margin-bottom: .65rem; text-transform: uppercase; letter-spacing: .4px; }

    /* ── BREAKDOWN LIST ── */
    .breakdown-list { display: flex; flex-direction: column; gap: .55rem; }
    .bk-item { display: flex; align-items: center; gap: .65rem; }
    .bk-dot  { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .bk-label { font-size: .78rem; color: var(--text-2); flex: 1; font-weight: 600; }
    .bk-bar-wrap { flex: 2; height: 7px; background: var(--border); border-radius: 50px; overflow: hidden; }
    .bk-bar { height: 100%; border-radius: 50px; transition: width .6s ease; }
    .bk-val { font-size: .75rem; font-weight: 800; color: var(--text-1); white-space: nowrap; min-width: 70px; text-align: right; }

    /* ── GCASH CONFIG ── */
    .gcash-banner-inner {
        background: linear-gradient(135deg, var(--navy-deep), #1a3a5c);
        border-radius: var(--radius-sm); padding: 1.1rem 1.35rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    }
    .gcash-info-row { display: flex; align-items: center; gap: .9rem; }
    .gcash-icon-box { width: 42px; height: 42px; background: rgba(255,255,255,.1); border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .gcash-name   { color: #fff; font-size: .88rem; font-weight: 800; margin: 0 0 1px; }
    .gcash-number { color: #00d4aa; font-size: .85rem; font-weight: 700; font-family: monospace; }
    .gcash-desc   { color: rgba(255,255,255,.45); font-size: .71rem; margin: 0; }
    .qr-thumb {
        width: 80px; height: 80px; object-fit: contain; background: #fff;
        padding: 6px; border-radius: var(--radius-xs); border: 2px solid rgba(0,153,255,.3);
        cursor: pointer; transition: transform .2s; flex-shrink: 0;
    }
    .qr-thumb:hover { transform: scale(1.06); }
    .btn-ghost-white {
        background: rgba(255,255,255,.13); color: #fff; border: 1.5px solid rgba(255,255,255,.28);
        border-radius: var(--radius-sm); padding: .52rem 1rem; font-size: .78rem; font-weight: 700;
        font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: .4rem;
        white-space: nowrap; transition: background .2s;
    }
    .btn-ghost-white:hover { background: rgba(255,255,255,.23); }

    /* ── FORM FIELDS ── */
    .field-group { margin-bottom: 1rem; }
    .field-label { display: block; font-size: .76rem; font-weight: 700; color: var(--text-2); margin-bottom: .35rem; }
    .field-input {
        width: 100%; padding: .6rem .9rem; border: 1.5px solid var(--border);
        border-radius: var(--radius-sm); font-family: inherit; font-size: .83rem;
        color: var(--text-1); background: var(--surface); outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .field-input:focus { border-color: var(--navy); background: #fff; box-shadow: 0 0 0 3px var(--accent-glow); }
    .field-input::placeholder { color: var(--text-3); }
    .field-hint { font-size: .7rem; color: var(--text-3); margin-top: .28rem; }

    .btn-navy {
        background: var(--navy); color: #fff; border: none;
        border-radius: var(--radius-sm); padding: .62rem 1.25rem;
        font-size: .82rem; font-weight: 800; font-family: inherit;
        cursor: pointer; display: inline-flex; align-items: center; gap: .42rem;
        transition: background .2s, transform .2s; box-shadow: 0 3px 12px rgba(5,16,148,.28);
    }
    .btn-navy:hover { background: var(--navy-deep); transform: translateY(-1px); }
    .btn-outline-navy {
        background: transparent; color: var(--navy); border: 1.5px solid var(--navy);
        border-radius: var(--radius-sm); padding: .6rem 1.2rem;
        font-size: .82rem; font-weight: 700; font-family: inherit;
        cursor: pointer; display: inline-flex; align-items: center; gap: .42rem; transition: all .18s;
    }
    .btn-outline-navy:hover { background: var(--navy-pale); }
    .btn-green {
        background: var(--green); color: #fff; border: none;
        border-radius: var(--radius-sm); padding: .62rem 1.25rem;
        font-size: .82rem; font-weight: 800; font-family: inherit;
        cursor: pointer; display: inline-flex; align-items: center; gap: .42rem;
        transition: background .2s; box-shadow: 0 3px 10px rgba(22,163,74,.28);
    }
    .btn-green:hover { background: #15803d; }

    /* QR warning box */
    .qr-warning {
        background: var(--amber-bg); border: 1px solid #fcd34d;
        border-radius: var(--radius-xs); padding: .6rem .85rem;
        font-size: .74rem; color: var(--amber); line-height: 1.6; margin-top: .5rem;
    }
    .qr-preview-box { text-align: center; margin-top: .75rem; display: none; }
    .qr-preview-box img { width: 130px; height: 130px; object-fit: contain; background: #fff; padding: 8px; border-radius: var(--radius-sm); border: 2px solid rgba(5,16,148,.18); }

    /* ── EXPORT BUTTONS ── */
    .export-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap: .75rem; }
    .exp-btn {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: .5rem; padding: 1.1rem .9rem;
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        background: var(--surface); cursor: pointer; transition: all .18s;
        font-family: inherit; text-decoration: none;
    }
    .exp-btn:hover { border-color: var(--navy); background: var(--navy-pale); transform: translateY(-2px); box-shadow: var(--shadow-sm); }
    .exp-icon { font-size: 1.5rem; }
    .exp-label { font-size: .75rem; font-weight: 800; color: var(--text-1); }
    .exp-sub   { font-size: .66rem; color: var(--text-3); }

    /* ── MANUAL PAY TABLE ── */
    .mp-table { width: 100%; border-collapse: collapse; }
    .mp-table thead th { background: var(--navy); color: #fff; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; padding: .65rem 1rem; border: none; white-space: nowrap; }
    .mp-table thead th:first-child { padding-left: 1.25rem; }
    .mp-table tbody tr { border-bottom: 1px solid var(--border); transition: background .15s; }
    .mp-table tbody tr:last-child { border-bottom: none; }
    .mp-table tbody tr:hover { background: var(--navy-pale); }
    .mp-table td { padding: .65rem 1rem; font-size: .8rem; color: var(--text-1); vertical-align: middle; }
    .mp-table td:first-child { padding-left: 1.25rem; }

    /* ── MODAL OVERLAY ── */
    .modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(5,16,148,.18); backdrop-filter: blur(4px);
        z-index: 1000; align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
        background: var(--white); border: 1.5px solid var(--border);
        border-radius: var(--radius); width: 100%; max-width: 480px;
        max-height: 90vh; overflow-y: auto; padding: 1.75rem;
        box-shadow: var(--shadow-lg); animation: modalIn .22s ease;
    }
    @@keyframes modalIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
    .modal-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.35rem; }
    .modal-head h5 { font-size: .95rem; font-weight: 800; color: var(--text-1); margin: 0; }
    .modal-close { background: none; border: none; color: var(--text-3); font-size: 1.1rem; cursor: pointer; line-height: 1; }
    .modal-close:hover { color: var(--red); }

    /* QR fullscreen modal */
    #qrFullModal .modal-box { max-width: 360px; text-align: center; }
    .qr-full-img { width: 100%; max-width: 280px; background: #fff; padding: 14px; border-radius: var(--radius-sm); border: 2px solid var(--border); }
    .qr-tip { background: var(--sky-bg); border: 1px solid #bae6fd; border-radius: var(--radius-xs); padding: .65rem .9rem; font-size: .76rem; color: var(--sky); margin-top: .9rem; line-height: 1.6; }

    /* ── TOAST ── */
    #toast-rack { position: fixed; bottom: 1.4rem; right: 1.4rem; z-index: 9999; display: flex; flex-direction: column; gap: .45rem; }
    .toast-item { background: var(--white); border-radius: var(--radius-sm); padding: .72rem 1rem; font-size: .81rem; font-weight: 600; box-shadow: var(--shadow-lg); border-left: 4px solid var(--navy); display: flex; align-items: center; gap: .55rem; min-width: 235px; color: var(--text-1); animation: toastIn .22s ease; transition: opacity .35s; }
    .toast-item.success { border-color: var(--green); }
    .toast-item.danger  { border-color: var(--red); }
    .toast-item.warning { border-color: var(--amber); }
    .toast-item i { font-size: .9rem; flex-shrink: 0; }
    .toast-item.success i { color: var(--green); }
    .toast-item.danger  i { color: var(--red); }
    .toast-item.warning i { color: var(--amber); }
    .toast-item.info    i { color: var(--navy); }
    @@keyframes toastIn { from{opacity:0;transform:translateX(14px)} to{opacity:1;transform:none} }

    @@media (max-width: 768px) {
        .pd-hero { padding: 1.5rem 1.25rem 3.5rem; }
        .pd-content { padding: 1.25rem 1.25rem 3rem; }
        .pd-hero-inner { flex-direction: column; }
        .analytics-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 480px) {
        .analytics-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- ── HERO ── -->
<div class="pd-hero">
    <div class="pd-hero-inner">
        <div>
            <h1 class="pd-hero-title">
                <i class="bi bi-bar-chart-fill me-2" style="font-size:.8em;opacity:.75"></i>
                Payment Dashboard
            </h1>
            <p class="pd-hero-sub">Enrollment &amp; Licensure Fee Monitoring &bull; <strong>SuperAdmin View</strong></p>
            <div class="superadmin-pill"><i class="bi bi-shield-fill"></i> SuperAdmin Access</div>
        </div>
    </div>
</div>

<!-- ── CONTENT ── -->
<div class="pd-content">

    <!-- ── ANALYTICS CARDS ── -->
    <div class="analytics-grid">
        <div class="an-card green">
            <div class="an-label">Total Collected</div>
            <div class="an-value" id="acTotalCollected">₱—</div>
            <div class="an-sub">Verified payments</div>
            <div class="an-icon"><i class="bi bi-cash-coin"></i></div>
        </div>
        <div class="an-card amber">
            <div class="an-label">Pending Review</div>
            <div class="an-value" id="acPending">—</div>
            <div class="an-sub">Students awaiting verification</div>
            <div class="an-icon"><i class="bi bi-hourglass-split"></i></div>
        </div>
        <div class="an-card red">
            <div class="an-label">Rejected / Unpaid</div>
            <div class="an-value" id="acRejected">—</div>
            <div class="an-sub" id="acRejectedAmt">—</div>
            <div class="an-icon"><i class="bi bi-x-circle"></i></div>
        </div>
        <div class="an-card sky">
            <div class="an-label">GCash Payments</div>
            <div class="an-value" id="acGcash">—</div>
            <div class="an-sub" id="acGcashPct">of verified total</div>
            <div class="an-icon"><i class="bi bi-phone"></i></div>
        </div>
        <div class="an-card purple">
            <div class="an-label">Manual / Cash</div>
            <div class="an-value" id="acCash">—</div>
            <div class="an-sub" id="acCashPct">of verified total</div>
            <div class="an-icon"><i class="bi bi-wallet2"></i></div>
        </div>
        <div class="an-card navy">
            <div class="an-label">Avg. Payment</div>
            <div class="an-value" id="acAvg">₱—</div>
            <div class="an-sub">Per verified transaction</div>
            <div class="an-icon"><i class="bi bi-calculator"></i></div>
        </div>
    </div>

    <!-- ── REVENUE ANALYTICS ── -->
    <div class="section-card">
        <div class="sc-head">
            <div class="sc-head-left">
                <div class="sc-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div>
                    <p class="sc-title">Revenue Analytics</p>
                    <p class="sc-sub">Monthly trend & breakdown by program and method</p>
                </div>
            </div>
        </div>
        <div class="sc-body">
            <div class="two-col">
                <!-- Monthly chart -->
                <div>
                    <div class="chart-label">Monthly Collections</div>
                    <div class="chart-wrap">
                        <canvas id="monthlyChart"></canvas>
                    </div>
                </div>
                <!-- Breakdowns -->
                <div style="display:flex;flex-direction:column;gap:1.35rem;">
                    <div>
                        <div class="chart-label">By Payment Method</div>
                        <div class="breakdown-list" id="methodBreakdown">
                            <div style="color:var(--text-3);font-size:.78rem;">Loading…</div>
                        </div>
                    </div>
                    <div>
                        <div class="chart-label">By Purpose</div>
                        <div class="breakdown-list" id="purposeBreakdown">
                            <div style="color:var(--text-3);font-size:.78rem;">Loading…</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── GCASH CONFIG ── -->
    <div class="section-card">
            <div class="sc-head">
                <div class="sc-head-left">
                    <div class="sc-icon" style="background:#0284c7;"><i class="bi bi-qr-code"></i></div>
                    <div>
                        <p class="sc-title">GCash Configuration</p>
                        <p class="sc-sub">Recipient number, account name & QR code</p>
                    </div>
                </div>
            </div>
            <div class="sc-body">
                <!-- Current config banner -->
                <div class="gcash-banner-inner" id="gcashBannerWrap" style="margin-bottom:1.1rem;">
                    <div class="gcash-info-row">
                        <div class="gcash-icon-box">💳</div>
                        <div>
                            <p class="gcash-name"   id="gcashName">Loading…</p>
                            <div class="gcash-number" id="gcashNum">—</div>
                            <p class="gcash-desc"   id="gcashDesc">—</p>
                        </div>
                    </div>
                    <img id="gcashQrThumb" src="" alt="GCash QR" class="qr-thumb" style="display:none"
                         onclick="openQrFullscreen()">
                </div>
                <!-- Edit form -->
                <div class="field-group">
                    <label class="field-label">Account Name</label>
                    <input type="text" class="field-input" id="gcashAccName" placeholder="e.g. NORTHERN COLLEGE INC">
                </div>
                <div class="field-group">
                    <label class="field-label">GCash Number</label>
                    <input type="text" class="field-input" id="gcashNumber" placeholder="09171234567" maxlength="11">
                </div>
                <div class="field-group">
                    <label class="field-label">Payment Description</label>
                    <input type="text" class="field-input" id="gcashPayDesc" placeholder="School Fee Payment">
                </div>
                <div class="field-group">
                    <label class="field-label">Upload QR Code</label>
                    <input type="file" class="field-input" id="gcashQrFile" accept="image/*" onchange="previewQr(this)">
                    <div class="qr-warning">
                        ⚠️ <strong>Use official GCash QR only.</strong><br>
                        GCash app → Receive Money → My QR → Save screenshot.
                    </div>
                    <div class="qr-preview-box" id="qrPreviewBox">
                        <img id="qrPreviewImg" src="" alt="QR Preview">
                        <p style="font-size:.71rem;color:var(--text-3);margin-top:.4rem;">Preview — confirm clarity before saving.</p>
                    </div>
                </div>
                <div id="gcashSaveMsg" style="display:none;font-size:.78rem;font-weight:700;padding:.45rem .7rem;border-radius:var(--radius-xs);margin-bottom:.65rem;"></div>
                <button class="btn-navy" style="width:100%;" onclick="saveGCashConfig()">
                    <i class="bi bi-save2"></i> Save GCash Configuration
                </button>
            </div>
        </div>
    </div>

    <!-- ── EXPORT & REPORTS ── -->
    <div class="section-card">
        <div class="sc-head">
            <div class="sc-head-left">
                <div class="sc-icon" style="background:var(--purple);"><i class="bi bi-download"></i></div>
                <div>
                    <p class="sc-title">Export & Reports</p>
                    <p class="sc-sub">Download payment data for auditing or accounting</p>
                </div>
            </div>
        </div>
        <div class="sc-body">
            <!-- Date range filter -->
            <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:1.25rem;padding:.9rem 1rem;background:var(--navy-pale);border-radius:var(--radius-sm);border:1.5px solid var(--border);">
                <i class="bi bi-funnel-fill" style="color:var(--text-3);font-size:.85rem;"></i>
                <span style="font-size:.76rem;font-weight:700;color:var(--text-2);">Filter by date:</span>
                <input type="date" class="field-input" id="exportFrom" style="width:auto;padding:.45rem .75rem;font-size:.78rem;">
                <span style="font-size:.76rem;color:var(--text-3);">to</span>
                <input type="date" class="field-input" id="exportTo"   style="width:auto;padding:.45rem .75rem;font-size:.78rem;">
                <select class="field-input" id="exportStatus" style="width:auto;padding:.45rem .75rem;font-size:.78rem;">
                    <option value="">All Statuses</option>
                    <option value="Verified">Verified Only</option>
                    <option value="Pending">Pending Only</option>
                    <option value="Rejected">Rejected Only</option>
                </select>
            </div>
            <div class="export-grid">
                <button class="exp-btn" onclick="exportData('csv')">
                    <span class="exp-icon">📄</span>
                    <span class="exp-label">CSV Export</span>
                    <span class="exp-sub">All payment records</span>
                </button>
                <button class="exp-btn" onclick="exportData('pdf-summary')">
                    <span class="exp-icon">📊</span>
                    <span class="exp-label">PDF Summary</span>
                    <span class="exp-sub">Revenue report</span>
                </button>
                <button class="exp-btn" onclick="exportData('pdf-detailed')">
                    <span class="exp-icon">📑</span>
                    <span class="exp-label">PDF Detailed</span>
                    <span class="exp-sub">Per-student breakdown</span>
                </button>
                <button class="exp-btn" onclick="exportData('pending-list')">
                    <span class="exp-icon">⏳</span>
                    <span class="exp-label">Pending List</span>
                    <span class="exp-sub">Students awaiting payment</span>
                </button>
                <button class="exp-btn" onclick="exportData('gcash-log')">
                    <span class="exp-icon">📱</span>
                    <span class="exp-label">GCash Transactions</span>
                    <span class="exp-sub">GCash payments only</span>
                </button>
                <button class="exp-btn" onclick="exportData('manual-log')">
                    <span class="exp-icon">🧾</span>
                    <span class="exp-label">Manual Pay Log</span>
                    <span class="exp-sub">Office receipts log</span>
                </button>
            </div>
        </div>
    </div>

</div>

<div id="toast-rack"></div>

<!-- ── QR FULLSCREEN MODAL ── -->
<div class="modal-overlay" id="qrFullModal">
    <div class="modal-box" style="max-width:360px;text-align:center;">
        <div class="modal-head">
            <h5><i class="bi bi-qr-code me-2"></i>Scan QR Code</h5>
            <button class="modal-close" onclick="closeModal('qrFullModal')">✕</button>
        </div>
        <img id="qrFullImg" src="" alt="GCash QR" class="qr-full-img">
        <div class="qr-tip">
            📲 Open GCash → tap <strong>Pay QR</strong> → point camera at this QR.<br>
            Set screen brightness to <strong>maximum</strong> for best results.
        </div>
        <div style="display:flex;gap:.65rem;margin-top:1rem;">
            <a id="qrDownloadLink" href="#" download="gcash-qr.png" class="btn-navy" style="flex:1;justify-content:center;text-decoration:none;">
                <i class="bi bi-download"></i> Download QR
            </a>
            <button class="btn-outline-navy" style="flex:1;" onclick="closeModal('qrFullModal')">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // ── Modal helpers
    function openModal(id)  { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.modal-overlay').forEach(m =>
        m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); })
    );

    // ── Load everything
    async function initDashboard() {
        const [verified, pending, rejected] = await Promise.all([
            fetchPayments('Verified'),
            fetchPayments('Pending'),
            fetchPayments('Rejected')
        ]);
        buildAnalyticsCards(verified, pending, rejected);
        buildCharts(verified);
        buildBreakdowns(verified);
        loadGCashConfig();
        setDefaultDateRange();
    }

    async function fetchPayments(status) {
        try {
            const r = await fetch(`/PaymentAdmin/GetPayments?status=${status}`);
            const d = await r.json();
            return d.success ? d.data : [];
        } catch { return []; }
    }

    // ── Analytics cards
    function buildAnalyticsCards(verified, pending, rejected) {
        const total    = verified.reduce((s,r) => s + (r.amount||0), 0);
        const gcash    = verified.filter(r => (r.paymentMethod||'').toLowerCase() === 'gcash');
        const cash     = verified.filter(r => (r.paymentMethod||'').toLowerCase() !== 'gcash');
        const gcashAmt = gcash.reduce((s,r) => s + (r.amount||0), 0);
        const cashAmt  = cash.reduce((s,r)  => s + (r.amount||0), 0);
        const rejAmt   = rejected.reduce((s,r) => s + (r.amount||0), 0);
        const avg      = verified.length ? total / verified.length : 0;
        const pct      = v => total > 0 ? ((v/total)*100).toFixed(1)+'%' : '0%';

        document.getElementById('acTotalCollected').textContent = '₱' + total.toLocaleString('en-PH');
        document.getElementById('acPending').textContent        = pending.length;
        document.getElementById('acRejected').textContent       = rejected.length + ' records';
        document.getElementById('acRejectedAmt').textContent    = '₱' + rejAmt.toLocaleString('en-PH') + ' total value';
        document.getElementById('acGcash').textContent          = gcash.length + ' payments';
        document.getElementById('acGcashPct').textContent       = pct(gcashAmt) + ' of verified total';
        document.getElementById('acCash').textContent           = cash.length + ' payments';
        document.getElementById('acCashPct').textContent        = pct(cashAmt) + ' of verified total';
        document.getElementById('acAvg').textContent            = '₱' + Math.round(avg).toLocaleString('en-PH');
    }

    // ── Monthly chart
    function buildCharts(verified) {
        const months = {};
        verified.forEach(r => {
            if (!r.paymentDate) return;
            const d = new Date(r.paymentDate);
            if (isNaN(d)) return;
            const key = d.toLocaleString('en-PH', {month:'short', year:'2-digit'});
            months[key] = (months[key]||0) + (r.amount||0);
        });
        const labels = Object.keys(months).slice(-8);
        const data   = labels.map(l => months[l]);

        const ctx = document.getElementById('monthlyChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Collections (₱)',
                    data,
                    backgroundColor: 'rgba(5,16,148,.75)',
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 10 }, color: '#8a97c0' } },
                    y: { grid: { color: '#e2e7ff' }, ticks: { font: { size: 10 }, color: '#8a97c0',
                            callback: v => '₱' + (v >= 1000 ? (v/1000).toFixed(0)+'k' : v) } }
                }
            }
        });
    }

    // ── Breakdowns
    function buildBreakdowns(verified) {
        // By method
        const methodMap = {};
        verified.forEach(r => {
            const m = r.paymentMethod || 'Unknown';
            methodMap[m] = (methodMap[m]||0) + (r.amount||0);
        });
        const methodTotal = Object.values(methodMap).reduce((a,b) => a+b, 0);
        const methodColors = ['#051094','#0284c7','#16a34a','#d97706','#7c3aed'];
        renderBreakdown('methodBreakdown', methodMap, methodTotal, methodColors);

        // By purpose
        const purposeMap = {};
        verified.forEach(r => {
            const p = r.paymentType || 'Unknown';
            purposeMap[p] = (purposeMap[p]||0) + (r.amount||0);
        });
        const purposeTotal = Object.values(purposeMap).reduce((a,b) => a+b, 0);
        const purposeColors = ['#16a34a','#0284c7','#d97706','#7c3aed','#dc2626'];
        renderBreakdown('purposeBreakdown', purposeMap, purposeTotal, purposeColors);
    }

    function renderBreakdown(id, map, total, colors) {
        const el = document.getElementById(id);
        const sorted = Object.entries(map).sort((a,b) => b[1]-a[1]);
        if (!sorted.length) { el.innerHTML = '<div style="font-size:.75rem;color:var(--text-3);">No data.</div>'; return; }
        el.innerHTML = sorted.map(([k,v],i) => {
            const pct = total > 0 ? (v/total*100) : 0;
            return `<div class="bk-item">
                <div class="bk-dot" style="background:${colors[i%colors.length]}"></div>
                <span class="bk-label">${esc(k)}</span>
                <div class="bk-bar-wrap"><div class="bk-bar" style="width:${pct.toFixed(1)}%;background:${colors[i%colors.length]}"></div></div>
                <span class="bk-val">₱${v.toLocaleString('en-PH')}</span>
            </div>`;
        }).join('');
    }

    // ── GCash config load
    async function loadGCashConfig() {
        try {
            const r = await fetch('/PaymentAdmin/GetGCashConfig');
            const d = await r.json();
            if (d.success) {
                document.getElementById('gcashName').textContent  = d.accountName;
                document.getElementById('gcashNum').textContent   = fmtPhone(d.gcashNumber);
                document.getElementById('gcashDesc').textContent  = d.paymentDescription || '';
                document.getElementById('gcashAccName').value     = d.accountName;
                document.getElementById('gcashNumber').value      = d.gcashNumber;
                document.getElementById('gcashPayDesc').value     = d.paymentDescription || '';
                if (d.qrCodePath) {
                    const t = document.getElementById('gcashQrThumb');
                    t.src = d.qrCodePath; t.style.display = 'block';
                }
            } else {
                document.getElementById('gcashName').textContent = 'Not configured yet';
                document.getElementById('gcashNum').textContent  = '';
                document.getElementById('gcashDesc').textContent = 'Configure below';
            }
        } catch {}
    }

    async function saveGCashConfig() {
        const name = document.getElementById('gcashAccName').value.trim();
        const num  = document.getElementById('gcashNumber').value.trim().replace(/\D/g,'');
        const desc = document.getElementById('gcashPayDesc').value.trim();
        const qr   = document.getElementById('gcashQrFile').files[0];
        const msg  = document.getElementById('gcashSaveMsg');

        if (!name || !num) { showMsg(msg, 'Account name and number are required.', 'danger'); return; }
        if (num.length !== 11 || !num.startsWith('09')) { showMsg(msg, 'GCash number must be 11 digits starting with 09.', 'danger'); return; }

        const fd = new FormData();
        fd.append('AccountName', name);
        fd.append('GCashNumber', num);
        fd.append('PaymentDescription', desc || 'School Fee Payment');
        if (qr) fd.append('QrCodeFile', qr);

        showMsg(msg, 'Saving…', 'info');
        try {
            const r = await fetch('/PaymentAdmin/SaveGCashConfig', { method: 'POST', body: fd });
            const d = await r.json();
            if (d.success) { showMsg(msg, '✓ ' + d.message, 'success'); loadGCashConfig(); }
            else showMsg(msg, d.message, 'danger');
        } catch { showMsg(msg, 'Network error.', 'danger'); }
    }

    function showMsg(el, msg, type) {
        const colors = { success: [var_css('--green-bg'), var_css('--green')], danger: [var_css('--red-bg'), var_css('--red')], info: [var_css('--navy-pale'), var_css('--text-2')] };
        const [bg, color] = colors[type] || colors.info;
        el.style.cssText = `display:block;background:${bg};color:${color};border-radius:var(--radius-xs);padding:.45rem .7rem;font-size:.78rem;font-weight:700;margin-bottom:.65rem;`;
        el.textContent = msg;
    }
    function var_css(v) { return getComputedStyle(document.documentElement).getPropertyValue(v).trim(); }

    // ── QR preview & fullscreen
    function previewQr(input) {
        const f = input.files[0]; const box = document.getElementById('qrPreviewBox'); const img = document.getElementById('qrPreviewImg');
        if (!f) { box.style.display = 'none'; return; }
        const reader = new FileReader();
        reader.onload = e => { img.src = e.target.result; box.style.display = 'block'; };
        reader.readAsDataURL(f);
    }
    function openQrFullscreen() {
        const src = document.getElementById('gcashQrThumb').src;
        document.getElementById('qrFullImg').src        = src;
        document.getElementById('qrDownloadLink').href  = src;
        openModal('qrFullModal');
    }

    // ── Export
    function exportData(type) {
        const from   = document.getElementById('exportFrom').value;
        const to     = document.getElementById('exportTo').value;
        const status = document.getElementById('exportStatus').value;
        const params = new URLSearchParams({ type });
        if (from)   params.append('from', from);
        if (to)     params.append('to', to);
        if (status) params.append('status', status);
        toast('Preparing export…','info');
        window.location.href = `/PaymentAdmin/Export?${params}`;
    }

    // ── Date range defaults
    function setDefaultDateRange() {
        const now  = new Date();
        const from = new Date(now.getFullYear(), now.getMonth(), 1);
        document.getElementById('exportFrom').value = from.toISOString().split('T')[0];
        document.getElementById('exportTo').value   = now.toISOString().split('T')[0];
    }

    // ── Utils
    function fmtPhone(n) { return (n||'').replace(/\D/g,'').replace(/(\d{4})(\d{3})(\d{4})/,'$1-$2-$3'); }
    function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function toast(msg, type = 'info') {
        const rack  = document.getElementById('toast-rack');
        const icons = { success:'bi-check-circle-fill', danger:'bi-x-circle-fill', warning:'bi-exclamation-circle-fill', info:'bi-info-circle-fill' };
        const el    = document.createElement('div');
        el.className = `toast-item ${type}`;
        el.innerHTML = `<i class="bi ${icons[type]||icons.info}"></i>${esc(msg)}`;
        rack.appendChild(el);
        setTimeout(() => el.style.opacity = '0', 3200);
        setTimeout(() => el.remove(), 3600);
    }

    document.addEventListener('DOMContentLoaded', initDashboard);
</script>
}
