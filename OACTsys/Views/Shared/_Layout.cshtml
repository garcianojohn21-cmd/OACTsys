@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OACTsys — Orson Aerospace College and Technology</title>
    <link rel="icon" type="image/x-icon" href="~/images/logo.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">

    <style>
            :root {
                --navy: #051094;
                --navy-deep: #020b5c;
                --navy-mid: #0d2f6e;
                --accent: #ffffff;
                --accent-dim: rgba(255, 255, 255, 0.12);
                --accent-glow: rgba(255, 255, 255, 0.25);
                --white: #ffffff;
                --off-white: #e8edf8;
                --muted: rgba(255,255,255,0.50);
                --border-dim: rgba(255, 255, 255, 0.15);
                --surface: rgba(5, 16, 148, 0.35);
            }

            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: #040d4a;
                color: var(--off-white);
                overflow-x: hidden;
                min-height: 100vh;
            }

                /* ═══════════════════════════════════════
                               GRID OVERLAY — subtle aerospace grid
                            ═══════════════════════════════════════ */
                body::before {
                    content: '';
                    position: fixed;
                    inset: 0;
                    background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
                    background-size: 60px 60px;
                    pointer-events: none;
                    z-index: 0;
                }

            /* ═══════════════════════════════════════
                               BOOTSTRAP RESETS FOR HEADER
                            ═══════════════════════════════════════ */
            .oact-header .btn {
                --bs-btn-bg: transparent;
                --bs-btn-border-color: transparent;
            }

            .oact-header ul, .oact-header li {
                background: transparent !important;
            }

            .oact-header .nav-link,
            .oact-header .nav-link:hover,
            .oact-header .nav-link:focus {
                --bs-nav-link-hover-color: none;
                background: transparent !important;
                box-shadow: none !important;
                outline: none !important;
            }

            /* ═══════════════════════════════════════
                               HEADER / NAV
                            ═══════════════════════════════════════ */
            .oact-header {
                position: sticky;
                top: 0;
                z-index: 1000;
                background: rgba(3, 10, 80, 0.97);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-bottom: 1px solid var(--border-dim);
            }

                /* Top accent bar */
                .oact-header::before {
                    content: '';
                    display: block;
                    height: 2px;
                    background: linear-gradient(90deg, transparent 0%, var(--navy-mid) 20%, var(--white) 50%, var(--navy-mid) 80%, transparent 100%);
                }

            .header-inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 32px;
                height: 72px;
                max-width: 1400px;
                margin: 0 auto;
            }

            /* Logo area */
            .header-brand {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
            }

            /* ── CHANGE 1: logo bigger on desktop: 52px → 80px ── */
            .header-brand-logo {
                width: 80px;
                height: 80px;
                object-fit: contain;
                filter: brightness(0) invert(1);
                transition: opacity 0.3s;
            }

            .header-brand:hover .header-brand-logo {
                opacity: 0.85;
            }

            .header-brand-text {
                display: flex;
                flex-direction: column;
                line-height: 1.1;
            }

                .header-brand-text .brand-abbr {
                    font-family: 'Orbitron', monospace;
                    font-weight: 700;
                    font-size: 1rem;
                    color: var(--white);
                    letter-spacing: 3px;
                }

                .header-brand-text .brand-full {
                    font-size: 0.6rem;
                    color: var(--muted);
                    letter-spacing: 1.5px;
                    text-transform: uppercase;
                    font-family: 'Share Tech Mono', monospace;
                }

            /* Status indicator */
            .header-status {
                display: flex;
                align-items: center;
                gap: 6px;
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.65rem;
                color: rgba(255,255,255,0.6);
                letter-spacing: 1px;
                opacity: 0.8;
                margin-left: 20px;
            }

            .status-dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #4ade80;
                animation: pulse-dot 2s ease-in-out infinite;
            }

            @@keyframes pulse-dot {
                0%, 100% {
                    opacity: 1;
                    transform: scale(1);
                }

                50% {
                    opacity: 0.4;
                    transform: scale(0.7);
                }
            }

            /* Nav links */
            .header-nav {
                display: flex;
                align-items: center;
                gap: 4px;
                list-style: none;
                background: transparent !important;
            }

                .header-nav li {
                    background: transparent !important;
                }

            .nav-link-oact {
                font-family: 'DM Sans', sans-serif;
                font-size: 0.78rem;
                font-weight: 600;
                color: var(--muted) !important;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                padding: 6px 14px !important;
                border-radius: 4px;
                transition: color 0.2s;
                text-decoration: none;
                position: relative;
                background: transparent !important;
                --bs-nav-link-hover-color: transparent;
            }

                .nav-link-oact::after {
                    content: '';
                    position: absolute;
                    bottom: 2px;
                    left: 14px;
                    right: 14px;
                    height: 1px;
                    background: var(--white);
                    transform: scaleX(0);
                    transition: transform 0.2s;
                }

                .nav-link-oact:hover,
                .nav-link-oact:focus,
                .nav-link-oact:active,
                .nav-link-oact:focus-visible {
                    color: var(--white) !important;
                    background: transparent !important;
                    outline: none !important;
                    box-shadow: none !important;
                }

                    .nav-link-oact:hover::after {
                        transform: scaleX(1);
                    }

            /* Sign In button */
            .btn-oact-signin {
                font-family: 'Orbitron', monospace;
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 2px;
                color: var(--white) !important;
                background: transparent;
                border: 1.5px solid rgba(255,255,255,0.55);
                padding: 8px 20px;
                border-radius: 3px;
                text-decoration: none;
                transition: color 0.25s, background 0.25s, border-color 0.25s, box-shadow 0.25s;
                display: inline-block;
            }

                .btn-oact-signin:hover {
                    background: var(--white);
                    color: var(--navy) !important;
                    border-color: var(--white);
                    box-shadow: 0 0 16px rgba(255,255,255,0.2);
                }

            /* User dropdown */
            .dropdown-oact .dropdown-toggle {
                font-family: 'DM Sans', sans-serif;
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--white) !important;
                background: transparent !important;
                border: 1px solid rgba(255,255,255,0.3) !important;
                padding: 7px 16px;
                border-radius: 4px;
                transition: border-color 0.2s, box-shadow 0.2s;
                box-shadow: none !important;
            }

                .dropdown-oact .dropdown-toggle:hover,
                .dropdown-oact .dropdown-toggle:focus,
                .dropdown-oact .dropdown-toggle:active,
                .dropdown-oact .show > .dropdown-toggle {
                    border-color: rgba(255,255,255,0.7) !important;
                    box-shadow: none !important;
                    background: rgba(255,255,255,0.07) !important;
                    color: var(--white) !important;
                }

                .dropdown-oact .dropdown-toggle::after {
                    border-color: var(--white) transparent transparent;
                }

            .dropdown-menu-oact {
                background: #030a6e;
                border: 1px solid rgba(255,255,255,0.2);
                border-radius: 6px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 20px rgba(255,255,255,0.06);
                min-width: 220px;
                padding: 8px 0;
            }

                .dropdown-menu-oact .dropdown-item-text {
                    font-family: 'Share Tech Mono', monospace;
                    font-size: 0.72rem;
                    color: rgba(255,255,255,0.6);
                    padding: 6px 16px;
                    letter-spacing: 0.5px;
                }

                .dropdown-menu-oact .dropdown-divider {
                    border-color: var(--border-dim);
                    margin: 4px 0;
                }

                .dropdown-menu-oact .dropdown-item {
                    font-size: 0.82rem;
                    color: var(--off-white);
                    padding: 8px 16px;
                    transition: background 0.15s, color 0.15s;
                }

                    .dropdown-menu-oact .dropdown-item:hover {
                        background: rgba(0,212,255,0.08);
                        color: var(--white);
                    }

                    .dropdown-menu-oact .dropdown-item.text-danger {
                        color: #f87171 !important;
                    }

                        .dropdown-menu-oact .dropdown-item.text-danger:hover {
                            background: rgba(248,113,113,0.1);
                            color: #fca5a5 !important;
                        }

            /* Mobile hamburger */
            .nav-toggler {
                display: none;
                background: none;
                border: 1px solid rgba(255,255,255,0.2);
                color: var(--off-white);
                padding: 6px 10px;
                border-radius: 4px;
                font-size: 1.1rem;
                cursor: pointer;
            }

            /* ═══════════════════════════════════════
                               MAIN CONTENT
                            ═══════════════════════════════════════ */
            main {
                position: relative;
                z-index: 1;
                min-height: calc(100vh - 64px - 72px);
            }

            /* ═══════════════════════════════════════
                               FOOTER
                            ═══════════════════════════════════════ */
            .oact-footer {
                position: relative;
                z-index: 1;
                background: rgba(2, 6, 60, 0.98);
                border-top: 1px solid var(--border-dim);
                padding: 24px 32px;
                text-align: center;
            }

                .oact-footer::before {
                    content: '';
                    display: block;
                    height: 1px;
                    background: linear-gradient(90deg, transparent 0%, var(--navy-mid) 20%, var(--white) 50%, var(--navy-mid) 80%, transparent 100%);
                    margin-bottom: 24px;
                }

            .footer-logo-row {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                margin-bottom: 10px;
            }

                .footer-logo-row img {
                    width: 28px;
                    height: 28px;
                    object-fit: contain;
                    filter: brightness(0) invert(1);
                    opacity: 0.5;
                }

            .footer-abbr {
                font-family: 'Orbitron', monospace;
                font-size: 0.75rem;
                font-weight: 700;
                letter-spacing: 3px;
                color: rgba(255,255,255,0.3);
            }

            .footer-copy {
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.68rem;
                color: rgba(255,255,255,0.2);
                letter-spacing: 0.5px;
            }

            /* ═══════════════════════════════════════
                               UTILITY CLASSES FOR CHILD VIEWS
                            ═══════════════════════════════════════ */
            .text-cyan {
                color: var(--white) !important;
            }

            .text-admiral {
                color: var(--navy) !important;
            }

            .btn-admiral {
                background: var(--navy);
                color: white;
                border: none;
                font-family: 'DM Sans', sans-serif;
                font-weight: 600;
            }

                .btn-admiral:hover {
                    background: var(--navy-deep);
                    color: white;
                }

            /* Strip Bootstrap default white btn artifacts */
            .oact-header .btn:focus,
            .oact-header .btn:focus-visible,
            .oact-header .btn-check:focus + .btn {
                outline: none !important;
                box-shadow: none !important;
            }

            /* ═══════════════════════════════════════
                               SIDEBAR OVERLAY (mobile)
                            ═══════════════════════════════════════ */
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.55);
                backdrop-filter: blur(3px);
                z-index: 1100;
                opacity: 0;
                transition: opacity 0.3s;
            }

                .sidebar-overlay.open {
                    display: block;
                    opacity: 1;
                }

            /* ── CHANGE 2: transparent navy gradient + aerospace grid
                           same multi-layer technique as body::before ── */
            .sidebar {
                position: fixed;
                top: 0;
                right: 0;
                width: 270px;
                height: 100vh;
                background: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(180deg, rgba(4, 13, 74, 0.97) 0%, rgba(5, 16, 148, 0.93) 40%, rgba(2, 11, 92, 0.97) 100% );
                background-size: 60px 60px, 60px 60px, 100% 100%;
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-left: 1px solid var(--border-dim);
                z-index: 1200;
                transform: translateX(100%);
                transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
                display: flex;
                flex-direction: column;
                padding: 0;
                box-shadow: -8px 0 40px rgba(0,0,0,0.5);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .sidebar-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 18px 20px;
                border-bottom: 1px solid var(--border-dim);
            }

            .sidebar-head-brand {
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .sidebar-head-brand img {
                    width: 32px;
                    height: 32px;
                    object-fit: contain;
                    filter: brightness(0) invert(1);
                }

                .sidebar-head-brand span {
                    font-family: 'Orbitron', monospace;
                    font-size: 0.85rem;
                    font-weight: 700;
                    color: var(--white);
                    letter-spacing: 2px;
                }

            .sidebar-close {
                background: transparent;
                border: 1px solid var(--border-dim);
                color: var(--white);
                width: 32px;
                height: 32px;
                border-radius: 4px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 1rem;
                transition: background 0.15s;
            }

                .sidebar-close:hover {
                    background: rgba(255,255,255,0.1);
                }

            .sidebar-nav {
                flex: 1;
                display: flex;
                flex-direction: column;
                padding: 16px 12px;
                gap: 4px;
                list-style: none;
                margin: 0;
                background: transparent !important;
            }

                .sidebar-nav li {
                    background: transparent !important;
                }

            .sidebar-nav-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px 14px;
                font-family: 'DM Sans', sans-serif;
                font-size: 0.82rem;
                font-weight: 600;
                color: rgba(255,255,255,0.6) !important;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                text-decoration: none;
                border-radius: 6px;
                transition: background 0.15s, color 0.15s;
                background: transparent !important;
            }

                .sidebar-nav-link:hover {
                    background: rgba(255,255,255,0.08) !important;
                    color: var(--white) !important;
                }

                .sidebar-nav-link i {
                    font-size: 1rem;
                    opacity: 0.7;
                }

            .sidebar-divider {
                height: 1px;
                background: var(--border-dim);
                margin: 8px 14px;
            }

            .sidebar-foot {
                padding: 16px 12px;
                border-top: 1px solid var(--border-dim);
            }

            .sidebar-signin {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                width: 100%;
                padding: 12px;
                font-family: 'Orbitron', monospace;
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 2px;
                color: var(--navy) !important;
                background: var(--white);
                border: none;
                border-radius: 6px;
                text-decoration: none;
                transition: background 0.2s;
            }

                .sidebar-signin:hover {
                    background: var(--off-white);
                    color: var(--navy-deep) !important;
                }

            /* ═══════════════════════════════════════
                               RESPONSIVE
                            ═══════════════════════════════════════ */
            @@media (max-width: 768px) {
                .header-inner {
                    padding: 0 16px;
                }

                .header-status {
                    display: none;
                }

                .nav-toggler {
                    display: block;
                }

                .header-nav {
                    display: none !important;
                }

                .brand-full {
                    display: none;
                }
                /* Scale logo back for mobile header */
                .header-brand-logo {
                    width: 56px;
                    height: 56px;
                }
            }
    </style>
</head>
<body>

    <header class="oact-header">
        <div class="header-inner">

            <!-- Brand -->
            <a class="header-brand" asp-controller="Home" asp-action="Index" asp-fragment="welcome">
                <img src="~/images/logo.png" alt="OACT" class="header-brand-logo" />
                <div class="header-brand-text">
                    <span class="brand-abbr">OACT</span>
                    <span class="brand-full">Orson Aerospace College &amp; Technology</span>
                </div>
            </a>

            <!-- Live status badge -->
            <div class="header-status d-none d-lg-flex">
                <div class="status-dot"></div>
                PORTAL ONLINE
            </div>

            <!-- Mobile toggle -->
            <button class="nav-toggler d-md-none ms-auto me-3" onclick="toggleMobileNav()" aria-label="Toggle nav">
                <i class="bi bi-list"></i>
            </button>

            <!-- Nav -->
            <ul class="header-nav ms-auto" id="mainNav">
                <li>
                    <a class="nav-link-oact" asp-controller="Home" asp-action="Index" asp-fragment="welcome">Home</a>
                </li>
                <li>
                    <a class="nav-link-oact" asp-controller="Home" asp-action="Index" asp-fragment="about">About</a>
                </li>
                <li>
                    <a class="nav-link-oact" asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact</a>
                </li>
                <li style="background:transparent!important;margin-left:16px;">
                    @if (string.IsNullOrEmpty(Context.Session.GetString("UserEmail")))
                    {
                        <a class="btn-oact-signin" asp-controller="Account" asp-action="SignIn">SIGN IN</a>
                    }
                    else
                    {
                        <div class="dropdown dropdown-oact">
                            <button class="btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                @Context.Session.GetString("UserRole")
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-oact">
                                <li>
                                    <span class="dropdown-item-text">
                                        @Context.Session.GetString("UserEmail")
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger"
                                           asp-controller="Account" asp-action="SignOut">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </li>
            </ul>

        </div>
    </header>

    <!-- Sidebar overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-head">
            <div class="sidebar-head-brand">
                <img src="~/images/logo.png" alt="OACT" />
                <span>OACT</span>
            </div>
            <button class="sidebar-close" onclick="closeSidebar()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <ul class="sidebar-nav">
            <li>
                <a class="sidebar-nav-link" asp-controller="Home" asp-action="Index" asp-fragment="welcome">
                    <i class="bi bi-house-door"></i> Home
                </a>
            </li>
            <li>
                <a class="sidebar-nav-link" asp-controller="Home" asp-action="Index" asp-fragment="about">
                    <i class="bi bi-info-circle"></i> About
                </a>
            </li>
            <li>
                <a class="sidebar-nav-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">
                    <i class="bi bi-envelope"></i> Contact
                </a>
            </li>
        </ul>

        <div class="sidebar-foot">
            @if (string.IsNullOrEmpty(Context.Session.GetString("UserEmail")))
            {
                <a class="sidebar-signin" asp-controller="Account" asp-action="SignIn">
                    <i class="bi bi-box-arrow-in-right"></i> SIGN IN
                </a>
            }
            else
            {
                <div style="padding:8px 2px;">
                    <p style="font-family:'Share Tech Mono',monospace;font-size:0.7rem;color:rgba(255,255,255,0.5);margin-bottom:10px;">
                        @Context.Session.GetString("UserEmail")
                    </p>
                    <a class="sidebar-signin" asp-controller="Account" asp-action="SignOut"
                           style="background:transparent;border:1px solid rgba(248,113,113,0.5);color:#f87171!important;">
                        <i class="bi bi-box-arrow-right"></i> SIGN OUT
                    </a>
                </div>
            }
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="oact-footer">
        <div class="footer-logo-row">
            <img src="~/images/logo.png" alt="OACT" />
            <span class="footer-abbr">OACT</span>
        </div>
        <div class="footer-copy">
            &copy; @DateTime.Now.Year &mdash; ORSON AEROSPACE COLLEGE AND TECHNOLOGY, INC. &mdash; ALL RIGHTS RESERVED
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleMobileNav() {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('sidebarOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
        }
        function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('open');
        document.body.style.overflow = '';
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
