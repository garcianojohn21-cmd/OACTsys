@{
    ViewData["Title"] = "Enrollment Selection";
}

<!-- Page Header Banner -->
<div class="enroll-banner">
    <div class="enroll-banner__overlay"></div>
    <div class="container enroll-banner__content">
        <p class="enroll-banner__eyebrow">Student Portal</p>
        <h1 class="enroll-banner__title">Enrollment Category</h1>
        <p class="enroll-banner__sub">Select your current status to proceed with your application.</p>
    </div>
</div>

<!-- Cards Section -->
<section class="enroll-section">
    <div class="container">
        <div class="row g-4 justify-content-center">

            <!-- FRESHMEN -->
            <div class="col-lg-4 col-md-6">
                <a asp-action="FreshmenForm" class="enroll-card">
                    <div class="enroll-card__top">
                        <div class="enroll-card__icon-wrap">
                            <i class="bi bi-mortarboard-fill"></i>
                        </div>
                        <span class="enroll-card__badge">New Student</span>
                    </div>
                    <h3 class="enroll-card__title">FRESHMEN</h3>
                    <p class="enroll-card__desc">
                        New students entering college for the very first time.
                    </p>
                    <div class="enroll-card__footer">
                        <span class="enroll-card__cta">
                            Select <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>
                </a>
            </div>

            <!-- TRANSFEREE -->
            <div class="col-lg-4 col-md-6">
                <a asp-action="TransfereeForm" class="enroll-card">
                    <div class="enroll-card__top">
                        <div class="enroll-card__icon-wrap">
                            <i class="bi bi-arrow-left-right"></i>
                        </div>
                        <span class="enroll-card__badge">Transfer Student</span>
                    </div>
                    <h3 class="enroll-card__title">TRANSFEREE</h3>
                    <p class="enroll-card__desc">
                        Students transferring from another college or university.
                    </p>
                    <div class="enroll-card__footer">
                        <span class="enroll-card__cta">
                            Select <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>
                </a>
            </div>

            <!-- OLD STUDENT -->
            <div class="col-lg-4 col-md-6">
                <a asp-action="OldStudentForm" class="enroll-card">
                    <div class="enroll-card__top">
                        <div class="enroll-card__icon-wrap">
                            <i class="bi bi-person-check-fill"></i>
                        </div>
                        <span class="enroll-card__badge">Returning Student</span>
                    </div>
                    <h3 class="enroll-card__title">OLD STUDENT</h3>
                    <p class="enroll-card__desc">
                        Returning students enrolling for the current academic year.
                    </p>
                    <div class="enroll-card__footer">
                        <span class="enroll-card__cta">
                            Select <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>

<style>
    /* ── Variables (matching landing page) ── */
    :root {
        --admiral: #051094;
        --admiral-dark: #030a6e;
        --accent: #669bbc;
        --white: #ffffff;
        --off-white: #f4f6ff;
        --text-dark: #0d1b4b;
        --text-muted: #5a6a8a;
    }

    /* ══════════════════════════════════════════
           BANNER HEADER
        ══════════════════════════════════════════ */
    .enroll-banner {
        position: relative;
        background-image: url('/css/assets/images/bg-banner.jpg');
        background-size: cover;
        background-position: center;
        min-height: 220px;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .enroll-banner__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to right, rgba(5, 16, 148, 0.82) 0%, rgba(5, 16, 148, 0.55) 55%, rgba(102, 155, 188, 0.25) 100% );
        z-index: 1;
    }

    .enroll-banner__content {
        position: relative;
        z-index: 2;
        padding-top: 2.5rem;
        padding-bottom: 2.5rem;
    }

    .enroll-banner__eyebrow {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.65);
        margin-bottom: 0.3rem;
    }

    .enroll-banner__title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.5px;
        margin-bottom: 0.4rem;
    }

    .enroll-banner__sub {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.75);
        margin: 0;
    }

    /* ══════════════════════════════════════════
           CARDS SECTION
        ══════════════════════════════════════════ */
    .enroll-section {
        position: relative;
        padding: 4rem 0 5rem;
        background-image: linear-gradient( 135deg, rgba(255,255,255,0.97) 0%, rgba(244,246,255,0.92) 40%, rgba(102,155,188,0.18) 70%, rgba(5,16,148,0.10) 100% ), url('/css/assets/images/bg-banner.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* ── Individual Card ── */
    .enroll-card {
        display: flex;
        flex-direction: column;
        background: var(--white);
        border: 2px solid transparent;
        border-top: 4px solid var(--admiral);
        border-radius: 14px;
        padding: 2rem 1.75rem 1.5rem;
        text-decoration: none;
        height: 100%;
        transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
        box-shadow: 0 2px 12px rgba(5,16,148,0.07);
    }

        .enroll-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 16px 40px rgba(5,16,148,0.14);
            border-color: var(--admiral);
            text-decoration: none;
        }

    /* Accent variant removed — all cards are plain white */

    /* Top row: icon + badge */
    .enroll-card__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .enroll-card__icon-wrap {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: var(--off-white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: var(--admiral);
        flex-shrink: 0;
    }



    .enroll-card__badge {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        background: var(--off-white);
        color: var(--admiral);
        padding: 0.25rem 0.65rem;
        border-radius: 50px;
        border: 1px solid rgba(5,16,148,0.15);
    }


    /* Title */
    .enroll-card__title {
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
    }


    /* Description */
    .enroll-card__desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.65;
        flex: 1;
        margin-bottom: 1.5rem;
    }


    /* Footer CTA */
    .enroll-card__footer {
        margin-top: auto;
    }

    .enroll-card__cta {
        display: inline-flex;
        align-items: center;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        background: var(--admiral);
        color: var(--white);
        transition: background 0.2s;
    }

    .enroll-card:hover .enroll-card__cta {
        background: var(--admiral-dark);
    }


    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .enroll-banner {
            min-height: 160px;
        }

        .enroll-section {
            padding: 2.5rem 0 3rem;
        }
    }
</style>
