@model List<OACTsys.Models.EnrollmentField>
@{
    ViewData["Title"] = "Transferee Registration";
    var subjects = ViewBag.Subjects as List<OACTsys.Models.Subject>;
}

<style>
    /* ── CSS Variables ─────────────────────────────────────────── */
    :root {
        --admiral: #051094;
        --admiral-dark: #030a6e;
        --admiral-light: #e8ebff;
        --accent: #669bbc;
        --white: #ffffff;
        --off-white: #f4f6ff;
        --text-dark: #0d1b4b;
        --text-muted: #5a6a8a;
        --gray: #d2d2d2;
        --success: #198754;
        --border: rgba(5,16,148,0.15);
    }

    *, *::before, *::after { box-sizing: border-box; }

    /* ── Banner ────────────────────────────────────────────────── */
    .form-banner {
        position: relative;
        background-image: url("@Url.Content("~/css/assets/images/bg-banner.jpg")");
        background-size: cover; background-position: center;
        min-height: 180px; display: flex; align-items: center; overflow: hidden;
    }
    .form-banner__overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to right, rgba(5,16,148,0.88) 0%, rgba(5,16,148,0.62) 55%, rgba(102,155,188,0.25) 100%);
        z-index: 1;
    }
    .form-banner__content { position: relative; z-index: 2; padding: 2rem 1rem; width: 100%; }
    .form-banner__eyebrow { font-size: 0.65rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.2rem; }
    .form-banner__title   { font-size: clamp(1.5rem,4vw,2.4rem); font-weight: 800; color: var(--white); letter-spacing: -0.5px; margin-bottom: 0.25rem; line-height: 1.2; }
    .form-banner__sub     { font-size: 0.85rem; color: rgba(255,255,255,0.72); margin: 0; }

    /* ── Section ───────────────────────────────────────────────── */
    .form-section {
        padding: 2.5rem 0 5rem;
        background: linear-gradient(135deg, rgba(255,255,255,0.98) 0%, rgba(244,246,255,0.94) 40%, rgba(102,155,188,0.12) 75%, rgba(5,16,148,0.06) 100%);
        min-height: 60vh;
    }

    /* ── Program Cards ─────────────────────────────────────────── */
    .prog-card {
        background: var(--white); border: 2px solid transparent; border-top: 4px solid var(--admiral);
        border-radius: 14px; padding: 1.75rem 1.25rem; cursor: pointer;
        transition: transform .25s, box-shadow .25s, border-color .25s;
        box-shadow: 0 2px 12px rgba(5,16,148,0.07);
        height: 100%; position: relative; display: flex; flex-direction: column;
    }
    .prog-card:hover { transform: translateY(-5px); box-shadow: 0 12px 32px rgba(5,16,148,0.14); border-color: var(--admiral); }
    .prog-card__icon  { width: 52px; height: 52px; border-radius: 12px; background: var(--off-white); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--admiral); margin-bottom: 0.9rem; flex-shrink: 0; }
    .prog-card__badge { position: absolute; top: 1rem; right: 1rem; font-size: 0.6rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; background: var(--off-white); color: var(--admiral); padding: 0.2rem 0.55rem; border-radius: 50px; border: 1px solid var(--border); }
    .prog-card__title { font-size: 0.9rem; font-weight: 800; color: var(--text-dark); margin-bottom: 0.35rem; }
    .prog-card__sub   { font-size: 0.79rem; color: var(--text-muted); line-height: 1.55; margin-bottom: 1rem; flex: 1; }
    .prog-card__btn   { display: inline-flex; align-items: center; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; padding: 0.42rem 0.9rem; border-radius: 8px; background: var(--admiral); color: var(--white); transition: background .2s; width: fit-content; }
    .prog-card:hover .prog-card__btn { background: var(--admiral-dark); }

    /* ── Program Bar ───────────────────────────────────────────── */
    .prog-bar { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; background: var(--white); border: 1px solid var(--border); border-left: 4px solid var(--admiral); border-radius: 10px; padding: 0.75rem 1.1rem; box-shadow: 0 2px 8px rgba(5,16,148,0.06); }
    .prog-bar__label { font-size: 0.63rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 0.15rem; }
    .prog-bar__value { font-size: 0.88rem; font-weight: 700; color: var(--admiral); }

    /* ── Step Wizard ───────────────────────────────────────────── */
    .step-wizard-list { display: flex; padding: 1rem 0.5rem; list-style: none; justify-content: center; background: var(--white); border-radius: 12px; border: 1px solid rgba(5,16,148,0.08); box-shadow: 0 2px 8px rgba(5,16,148,0.05); margin: 0 0 1.25rem 0; overflow-x: auto; gap: 0; }
    .step-wizard-item { flex: 1; min-width: 55px; position: relative; display: flex; flex-direction: column; align-items: center; }
    .progress-count   { width: 32px; height: 32px; border-radius: 50%; background: var(--gray); display: flex; align-items: center; justify-content: center; font-weight: 700; color: white; font-size: 0.8rem; z-index: 2; transition: background .3s; flex-shrink: 0; }
    .step-wizard-item.current .progress-count, .step-wizard-item.completed .progress-count { background: var(--admiral); }
    .step-wizard-item::after { content: ""; position: absolute; width: 100%; height: 2px; background: var(--gray); top: 15px; left: 50%; z-index: 1; }
    .step-wizard-item:last-child::after { display: none; }
    .progress-label { font-size: 0.6rem; margin-top: 4px; font-weight: 700; color: #999; text-align: center; white-space: nowrap; }
    .step-wizard-item.current .progress-label, .step-wizard-item.completed .progress-label { color: var(--admiral); }

    /* ── Card Form ─────────────────────────────────────────────── */
    .card-oact-form { border-top: 4px solid var(--admiral) !important; border-radius: 14px !important; }

    /* ── Step heading ──────────────────────────────────────────── */
    .step-heading { color: var(--admiral); font-weight: 800; font-size: 0.95rem; letter-spacing: 0.4px; border-bottom: 2px solid var(--off-white); padding-bottom: 0.65rem; margin-bottom: 1.25rem; }

    /* ── Category block ────────────────────────────────────────── */
    .category-section { background: var(--off-white); border-left: 4px solid var(--admiral); border-radius: 8px; padding: 1.1rem 1rem 0.85rem; margin-bottom: 1rem; }
    .category-title   { color: var(--admiral); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.5px; margin-bottom: 0.85rem; text-transform: uppercase; }

    /* ── Year / Semester Group heading ────────────────────────── */
    .year-group-heading {
        background: var(--admiral); color: white;
        font-size: 0.72rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
        padding: 0.45rem 0.9rem; border-radius: 7px;
        margin: 1rem 0 0.5rem; display: flex; align-items: center; gap: 0.5rem;
    }

    /* ── Subject rows ──────────────────────────────────────────── */
    .subject-row { border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 0.9rem; margin-bottom: 6px; background: var(--white); transition: border-color .2s, background .2s; }
    .subject-row:hover { border-color: var(--admiral); background: var(--off-white); }
    .subject-row:has(.subject-item:checked) { border-color: var(--admiral); background: #e7f0ff; }
    .badge-units  { font-size: 0.68rem; font-weight: 700; background: var(--admiral); color: white; padding: 0.2rem 0.55rem; border-radius: 50px; white-space: nowrap; flex-shrink: 0; }
    .units-total  { background: var(--off-white); border: 1px solid var(--border); border-left: 4px solid var(--admiral); border-radius: 8px; padding: 0.65rem 1.1rem; font-size: 0.88rem; color: var(--text-dark); }

    /* ── Accreditation table ───────────────────────────────────── */
    .accred-section { background: var(--off-white); border-left: 4px solid #669bbc; border-radius: 8px; padding: 1.1rem 1rem 0.85rem; margin-top: 1rem; }
    .accred-title   { color: #2a5580; font-weight: 700; font-size: 0.78rem; letter-spacing: 0.5px; margin-bottom: 0.85rem; text-transform: uppercase; }
    .accred-table thead th { background: var(--admiral); color: white; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase; border: none; padding: 0.55rem 0.65rem; }
    .accred-table td { vertical-align: middle; padding: 0.4rem 0.45rem; font-size: 0.82rem; }
    .accred-table tbody tr:nth-child(even) { background: rgba(5,16,148,0.03); }
    .btn-add-row { font-size: 0.72rem; font-weight: 700; padding: 0.35rem 0.85rem; border-radius: 7px; }

    /* ── Buttons ───────────────────────────────────────────────── */
    .btn-admiral      { background: var(--admiral); color: white; border: none; }
    .btn-admiral:hover { background: var(--admiral-dark); color: white; }
    .border-admiral   { border: 1px solid var(--admiral) !important; }
    input:focus, select:focus, textarea:focus { border-color: var(--admiral) !important; box-shadow: 0 0 0 0.18rem rgba(5,16,148,0.12) !important; }

    /* ── Nav buttons ───────────────────────────────────────────── */
    .wizard-nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; padding-top: 1.25rem; border-top: 1px solid var(--off-white); }
    .wizard-nav .btn { min-width: 110px; }

    /* ════════════════════════════════════════════════════════════
       REVIEW — Document Style
    ════════════════════════════════════════════════════════════ */
    #reviewContent        { background: #fff; border: 1px solid #ccc; border-radius: 4px; overflow: hidden; }
    .doc-paper            { padding: 28px 32px 32px; font-family: 'Times New Roman', Times, serif; font-size: 10pt; color: #111; line-height: 1.4; }
    .doc-header           { text-align: center; margin-bottom: 14px; }
    .doc-logo             { height: 54px; width: auto; margin-bottom: 6px; }
    .doc-school-name      { font-size: 12pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin: 0 0 2px; }
    .doc-school-address   { font-size: 7.5pt; color: #444; margin: 0; }
    .doc-blue-bar         { background: #4a86b8; color: white; text-align: center; font-size: 10pt; font-weight: 700; letter-spacing: 1px; padding: 6px 8px; margin: 12px 0; text-transform: uppercase; }
    .doc-body             { display: flex; gap: 18px; align-items: flex-start; }
    .doc-info-col         { flex: 1; min-width: 0; }
    .doc-subjects-col     { width: 230px; flex-shrink: 0; }
    .doc-row              { display: flex; gap: 8px; margin-bottom: 8px; flex-wrap: wrap; }
    .doc-field            { display: flex; align-items: flex-end; flex: 1; min-width: 140px; gap: 3px; }
    .doc-field.full       { flex: 0 0 100%; }
    .doc-label            { font-size: 7.5pt; font-weight: 700; white-space: nowrap; color: #111; flex-shrink: 0; }
    .doc-value            { border-bottom: 1px solid #111; flex: 1; padding: 0 3px 1px; min-height: 16px; font-size: 9pt; word-break: break-word; }
    .doc-section-title    { font-size: 8.5pt; font-weight: 700; text-transform: uppercase; margin: 14px 0 6px; color: #111; }
    .doc-sig-row          { display: flex; justify-content: flex-end; margin-top: 20px; }
    .doc-sig-box          { text-align: right; min-width: 180px; }
    .doc-sig-line         { border-bottom: 1px solid #111; padding-bottom: 2px; font-size: 8.5pt; min-width: 180px; display: inline-block; }
    .doc-sig-caption      { font-size: 7pt; text-align: center; margin-top: 2px; color: #444; }
    .doc-subjects-box     { border: 1px solid #111; padding: 10px; min-height: 240px; font-size: 8.5pt; }
    .doc-subjects-title   { font-weight: 700; font-size: 8.5pt; text-align: center; border-bottom: 1px solid #111; padding-bottom: 6px; margin-bottom: 8px; text-transform: uppercase; line-height: 1.3; }
    .doc-subject-item     { border-bottom: 1px dotted #bbb; padding: 3px 0 4px; margin-bottom: 2px; }
    .doc-subject-code     { font-weight: 700; font-size: 8pt; }
    .doc-subject-name     { font-size: 7.5pt; color: #333; }
    .doc-subject-units    { text-align: right; font-size: 8pt; font-weight: 600; margin-top: 1px; }
    .doc-subjects-total   { border-top: 1.5px solid #111; padding-top: 6px; margin-top: 6px; font-weight: 700; text-align: right; font-size: 8.5pt; }
    .doc-accred-table     { width: 100%; border-collapse: collapse; font-size: 7.5pt; margin-top: 4px; }
    .doc-accred-table th  { background: #e8ebff; color: #051094; font-weight: 700; padding: 3px 5px; border: 1px solid #ccd; text-align: left; }
    .doc-accred-table td  { padding: 3px 5px; border: 1px solid #dde; }
    .doc-accred-table tr:nth-child(even) td { background: #f8f9ff; }
    .review-note          { font-size: 0.75rem; color: var(--text-muted); text-align: center; padding: 8px; background: var(--off-white); border-top: 1px solid var(--border); }

    /* ════════════════════════════════════════════════════════════
       UPLOADED DOCUMENTS PREVIEW
    ════════════════════════════════════════════════════════════ */
    .docs-preview-section      { margin-top: 0; padding: 1.25rem 1.25rem 1.1rem; background: var(--off-white); border-top: 2px dashed var(--border); }
    .docs-preview-header       { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
    .docs-preview-header-icon  { width: 32px; height: 32px; border-radius: 8px; background: var(--admiral); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; flex-shrink: 0; }
    .docs-preview-title        { color: var(--admiral); font-weight: 800; font-size: 0.82rem; letter-spacing: 0.5px; text-transform: uppercase; margin: 0; }
    .docs-preview-subtitle     { font-size: 0.7rem; color: var(--text-muted); margin: 0; }
    .doc-preview-grid          { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px,1fr)); gap: 0.75rem; }
    .doc-preview-card          { background: var(--white); border: 1.5px solid var(--border); border-radius: 10px; overflow: hidden; box-shadow: 0 2px 10px rgba(5,16,148,0.07); display: flex; flex-direction: column; transition: transform .2s, box-shadow .2s, border-color .2s; }
    .doc-preview-card:hover    { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(5,16,148,0.13); border-color: var(--admiral); }
    .doc-preview-img-wrap      { width: 100%; height: 115px; background: linear-gradient(135deg,#eef0ff 0%,#dde2ff 100%); display: flex; align-items: center; justify-content: center; overflow: hidden; border-bottom: 1.5px solid var(--border); position: relative; cursor: pointer; }
    .doc-preview-img-wrap img  { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .3s; }
    .doc-preview-card:hover .doc-preview-img-wrap img { transform: scale(1.05); }
    .doc-preview-img-wrap::after { content: "\F52A"; font-family: "bootstrap-icons"; position: absolute; inset: 0; background: rgba(5,16,148,0.45); color: white; font-size: 1.6rem; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .2s; }
    .doc-preview-img-wrap.is-image:hover::after { opacity: 1; }
    .doc-preview-icon-wrap     { width: 100%; height: 115px; background: linear-gradient(135deg,#eef0ff 0%,#dde2ff 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; border-bottom: 1.5px solid var(--border); }
    .doc-preview-icon          { font-size: 2.4rem; line-height: 1; }
    .doc-preview-icon.pdf      { color: #dc3545; }
    .doc-preview-icon.word     { color: #2b5797; }
    .doc-preview-icon.excel    { color: #1e7145; }
    .doc-preview-icon.other    { color: var(--admiral); opacity: 0.5; }
    .doc-preview-filetype-badge         { font-size: 0.58rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 0.15rem 0.5rem; border-radius: 50px; background: var(--admiral); color: white; }
    .doc-preview-filetype-badge.pdf     { background: #dc3545; }
    .doc-preview-filetype-badge.word    { background: #2b5797; }
    .doc-preview-filetype-badge.excel   { background: #1e7145; }
    .doc-preview-info          { padding: 0.55rem 0.65rem 0.6rem; flex: 1; display: flex; flex-direction: column; gap: 2px; }
    .doc-preview-label         { font-size: 0.62rem; font-weight: 800; color: var(--admiral); text-transform: uppercase; letter-spacing: 0.4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .doc-preview-filename      { font-size: 0.7rem; color: var(--text-muted); word-break: break-all; line-height: 1.3; }
    .doc-preview-empty         { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; padding: 1.5rem 1rem; color: var(--text-muted); font-size: 0.82rem; font-style: italic; text-align: center; }
    .doc-preview-empty i       { font-size: 2rem; opacity: 0.3; }

    /* ── Lightbox ──────────────────────────────────────────────── */
    #imgLightbox           { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 9999; align-items: center; justify-content: center; padding: 1rem; cursor: zoom-out; }
    #imgLightbox.active    { display: flex; }
    #imgLightbox img       { max-width: 92vw; max-height: 88vh; border-radius: 8px; box-shadow: 0 8px 48px rgba(0,0,0,0.6); object-fit: contain; cursor: default; }
    #imgLightbox .lb-close { position: absolute; top: 1rem; right: 1.25rem; font-size: 1.8rem; color: white; cursor: pointer; line-height: 1; opacity: 0.8; transition: opacity .2s; background: none; border: none; padding: 0; }
    #imgLightbox .lb-close:hover { opacity: 1; }
    #imgLightbox .lb-caption { position: absolute; bottom: 1.25rem; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.55); color: white; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.5px; padding: 0.35rem 0.9rem; border-radius: 50px; white-space: nowrap; text-transform: uppercase; }

    /* ── Terms scroll ──────────────────────────────────────────── */
    .terms-scroll { height: 180px; overflow-y: auto; font-size: 0.82rem; border: 1px solid var(--border); border-radius: 8px; padding: 1rem; background: white; margin-bottom: 1rem; }

    /* ── Field label ───────────────────────────────────────────── */
    .field-label      { font-size: 0.72rem; font-weight: 700; color: var(--text-dark); letter-spacing: 0.3px; margin-bottom: 4px; display: block; text-transform: uppercase; }
    .field-label .req { color: #dc3545; }

    /* ── Transferee info alert ─────────────────────────────────── */
    .alert-transferee-info { background: #e8f4fd; border-left: 4px solid var(--accent); border-radius: 8px; padding: 0.85rem 1rem; font-size: 0.82rem; color: var(--text-dark); margin-bottom: 1rem; }

    /* ── Mobile ────────────────────────────────────────────────── */
    @@media (max-width: 767px) {
        .doc-paper { padding: 16px 14px 20px; font-size: 8.5pt; }
        .doc-body  { flex-direction: column; gap: 14px; }
        .doc-subjects-col { width: 100%; }
        .doc-field        { min-width: 120px; }
        .card-oact-form .card-body { padding: 1.25rem !important; }
        .wizard-nav .btn  { min-width: auto; flex: 1; }
        .col-md-6         { flex: 0 0 100%; max-width: 100%; }
        .doc-preview-grid { grid-template-columns: repeat(auto-fill,minmax(130px,1fr)); }
        #subjectsList     { max-height: 55vh; overflow-y: auto; padding-right: 2px; }
    }
    @@media (max-width: 480px) {
        .doc-paper { padding: 12px 10px 16px; }
        .doc-row   { flex-direction: column; gap: 5px; }
        .doc-field { min-width: 0; }
        .doc-preview-grid { grid-template-columns: repeat(2,1fr); }
    }
</style>

<!-- ─── LIGHTBOX ─────────────────────────────────────────────── -->
<div id="imgLightbox" onclick="closeLightbox(event)">
    <button class="lb-close" onclick="closeLightbox(null,true)">&times;</button>
    <img id="lbImg" src="" alt="" />
    <div id="lbCaption" class="lb-caption"></div>
</div>

<!-- ─── BANNER ──────────────────────────────────────────────── -->
<div class="form-banner">
    <div class="form-banner__overlay"></div>
    <div class="container form-banner__content">
        <p class="form-banner__eyebrow">Enrollment · Transferee</p>
        <h1 class="form-banner__title">Transferee Registration</h1>
        <p class="form-banner__sub">Complete all steps below to submit your transfer application.</p>
    </div>
</div>

<!-- ─── FORM SECTION ─────────────────────────────────────────── -->
<section class="form-section">
    <div class="container">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- ── STEP 0: Program Selection ───────────────────────── -->
        <div id="programSelection">
            <p class="text-center mb-1" style="font-size:.65rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent)">Step 0 of 6</p>
            <h2 class="text-center mb-4" style="font-size:clamp(1.3rem,3.5vw,1.9rem);font-weight:800;color:var(--text-dark)">Select Your Program</h2>
            <div class="row g-3 justify-content-center">
                <div class="col-sm-10 col-md-5">
                    <div class="prog-card" onclick="selectProgram('AMT')">
                        <div class="prog-card__icon"><i class="bi bi-gear-wide-connected"></i></div>
                        <span class="prog-card__badge">AMT</span>
                        <h4 class="prog-card__title">Aircraft Maintenance Technology</h4>
                        <p class="prog-card__sub">Focuses on aircraft maintenance and repair, preparing students for careers in aviation maintenance and engineering.</p>
                        <div class="prog-card__btn">Transfer to AMT <i class="bi bi-arrow-right ms-1"></i></div>
                    </div>
                </div>
                <div class="col-sm-10 col-md-5">
                    <div class="prog-card" onclick="selectProgram('AVT')">
                        <div class="prog-card__icon"><i class="bi bi-cpu-fill"></i></div>
                        <span class="prog-card__badge">AVT</span>
                        <h4 class="prog-card__title">Aviation Electronics Technology</h4>
                        <p class="prog-card__sub">Specializes in avionics and electronics systems, training students in electronic systems used in modern aircraft.</p>
                        <div class="prog-card__btn">Transfer to AVT <i class="bi bi-arrow-right ms-1"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── WIZARD CONTAINER ─────────────────────────────────── -->
        <div id="wizardContainer" class="d-none">

            <!-- Program Bar -->
            <div class="prog-bar mb-3">
                <div>
                    <span class="prog-bar__label">Transferring To</span>
                    <span id="selectedProgramDisplay" class="prog-bar__value"></span>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="location.reload()">
                    <i class="bi bi-arrow-left-right me-1"></i> Change
                </button>
            </div>

            <!-- Step Tracker -->
            <ul class="step-wizard-list">
                <li class="step-wizard-item current"><span class="progress-count">1</span><span class="progress-label">Information</span></li>
                <li class="step-wizard-item"><span class="progress-count">2</span><span class="progress-label">Accreditation</span></li>
                <li class="step-wizard-item"><span class="progress-count">3</span><span class="progress-label">Subjects</span></li>
                <li class="step-wizard-item"><span class="progress-count">4</span><span class="progress-label">Review</span></li>
                <li class="step-wizard-item"><span class="progress-count">5</span><span class="progress-label">Terms</span></li>
                <li class="step-wizard-item"><span class="progress-count">6</span><span class="progress-label">Finish</span></li>
            </ul>

            <!-- Card -->
            <div class="card shadow border-0 card-oact-form">
                <div class="card-body p-3 p-md-4 p-lg-5">
                    <form id="transfereeForm"
                          asp-action="SubmitTransfereeRegistration"
                          asp-controller="Enrollment"
                          method="post"
                          enctype="multipart/form-data">

                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ChosenProgram" id="ChosenProgram" />
                        <input type="hidden" name="ApplicantType" value="Transferee" />

                        <!-- ══ STEP 1: Personal & Educational Info ════════ -->
                        <div class="wizard-step active" data-step="1">
                            <h4 class="step-heading">Step 1 &mdash; Personal &amp; Educational Information</h4>
                            <div class="alert-transferee-info">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>Transferee Applicant</strong> — Please fill in all required fields accurately.
                                Your previous school information will be used for subject accreditation in Step 2.
                            </div>

                            @if (Model != null && Model.Any())
                            {
                                var groupedFields = Model
                                    .GroupBy(f => string.IsNullOrEmpty(f.Category) ? "Other Information" : f.Category)
                                    .OrderBy(g => g.Key == "Personal Data" ? 0 :
                                                  g.Key == "Educational Background" ? 1 :
                                                  g.Key == "Contact Information" ? 2 :
                                                  g.Key == "Family Background" ? 3 :
                                                  g.Key == "For Transferees" ? 4 :
                                                  g.Key == "Documents" ? 5 : 6);

                                foreach (var group in groupedFields)
                                {
                                    <div class="category-section">
                                        <div class="category-title"><i class="bi bi-folder-fill me-2"></i>@group.Key</div>
                                        <div class="row g-2">
                                            @foreach (var field in group)
                                            {
                                                <div class="col-12 col-md-6">
                                                    <label class="field-label">
                                                        @field.FieldName.ToUpper()
                                                        @if (field.IsRequired) { <span class="req">*</span> }
                                                    </label>
                                                    @switch (field.FieldType.ToLower())
                                                    {
                                                        case "text":
                                                            <input type="text" name="Field_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-field"
                                                                   placeholder="@field.FieldName" required="@field.IsRequired" />
                                                            break;
                                                        case "number":
                                                            <input type="number" name="Field_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-field"
                                                                   placeholder="@field.FieldName" required="@field.IsRequired" />
                                                            break;
                                                        case "email":
                                                            <input type="email" name="Field_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-field"
                                                                   placeholder="email@example.com" required="@field.IsRequired" />
                                                            break;
                                                        case "phone":
                                                            <input type="tel" name="Field_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-field"
                                                                   placeholder="e.g. 09XX XXX XXXX" pattern="[0-9+\-\s()]+" title="Please enter a valid phone number"
                                                                   required="@field.IsRequired" />
                                                            break;
                                                        case "date":
                                                            <input type="date" name="Field_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-field"
                                                                   required="@field.IsRequired" />
                                                            break;
                                                        case "select":
                                                            var opts = !string.IsNullOrEmpty(field.Options)
                                                                ? Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(field.Options)
                                                                : new List<string>();
                                                            <select name="Field_@field.Id"
                                                                    data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                    class="form-select form-select-sm border-admiral enrollment-field"
                                                                    required="@field.IsRequired">
                                                                <option value="">-- Select @field.FieldName --</option>
                                                                @foreach (var opt in opts) { <option value="@opt">@opt</option> }
                                                            </select>
                                                            break;
                                                        case "file":
                                                        case "image":
                                                            <input type="file" name="File_@field.Id"
                                                                   data-field-id="@field.Id" data-field-name="@field.FieldName" data-category="@field.Category"
                                                                   class="form-control form-control-sm border-admiral enrollment-file"
                                                                   accept="@GetAcceptedFileTypes(field.AcceptedFileTypes)"
                                                                   required="@field.IsRequired" />
                                                            @if (!string.IsNullOrEmpty(field.HelperText))
                                                            {
                                                                <small class="text-muted d-block mt-1">@field.HelperText (Max: @field.MaxFileSize MB)</small>
                                                            }
                                                            break;
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    No enrollment fields configured. Please contact the administrator.
                                </div>
                            }
                        </div>

                        <!-- ══ STEP 2: Subject Accreditation ═════════════ -->
                        <div class="wizard-step" data-step="2" style="display:none">
                            <h4 class="step-heading">Step 2 &mdash; Subject Accreditation</h4>
                            <div class="alert-transferee-info">
                                <i class="bi bi-journal-check me-2"></i>
                                <strong>Optional</strong> — List subjects from your previous school for credit evaluation.
                                Leave blank if not applicable.
                            </div>
                            <div class="accred-section">
                                <div class="accred-title"><i class="bi bi-list-check me-2"></i>Previous School Subjects for Credit</div>
                                <div class="table-responsive">
                                    <table class="table table-bordered accred-table align-middle mb-2" id="accredTable">
                                        <thead>
                                            <tr>
                                                <th style="width:140px">Course Code</th>
                                                <th>Descriptive Title</th>
                                                <th style="width:85px">Units</th>
                                                <th style="width:85px">Grade</th>
                                                <th style="width:44px"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="accredBody">
                                            <tr>
                                                <td><input type="text"   name="AccredCode[]"  class="form-control form-control-sm border-admiral" placeholder="e.g. GEC101" /></td>
                                                <td><input type="text"   name="AccredTitle[]" class="form-control form-control-sm border-admiral" placeholder="Subject title" /></td>
                                                <td><input type="number" name="AccredUnits[]" class="form-control form-control-sm border-admiral" placeholder="3" min="0" max="9" step="0.5" /></td>
                                                <td><input type="text"   name="AccredGrade[]" class="form-control form-control-sm border-admiral" placeholder="1.25" /></td>
                                                <td><button type="button" class="btn btn-sm btn-outline-danger border-0 px-2" onclick="removeAccredRow(this)" title="Remove"><i class="bi bi-trash3"></i></button></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <button type="button" class="btn btn-sm btn-admiral btn-add-row mt-1" onclick="addAccredRow()">
                                    <i class="bi bi-plus-circle me-1"></i> Add Subject
                                </button>
                            </div>
                        </div>

                        <!-- ══ STEP 3: Subject Selection ═════════════════ -->
                        <div class="wizard-step" data-step="3" style="display:none">
                            <h4 class="step-heading">Step 3 &mdash; Select Your Subjects</h4>
                            <p class="text-muted" style="font-size:.82rem">
                                Select subjects for enrollment &nbsp;|&nbsp;
                                <strong>Program: <span id="subjectProgramDisplay">—</span></strong>
                            </p>
                            <div class="alert-transferee-info mb-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Subjects are grouped by Year Level and Semester. Please <strong>check the subjects</strong> you want to enroll in.

                            </div>

                            @if (subjects != null && subjects.Any())
                            {
                                @* Group by YearLevel → Semester for a clean layered display *@
                                var yearGroups = subjects
                                    .GroupBy(s => s.YearLevel)
                                    .OrderBy(g => g.Key);

                                <div id="subjectsList">
                                    @foreach (var yg in yearGroups)
                                    {
                                        var semGroups = yg.GroupBy(s => s.Semester).OrderBy(g => g.Key);
                                        foreach (var sg in semGroups)
                                        {
                                            string yLbl = yg.Key switch { 1 => "1st", 2 => "2nd", 3 => "3rd", _ => $"{yg.Key}th" };
                                            string sLbl = sg.Key  switch { 1 => "1st", 2 => "2nd", _ => $"{sg.Key}" };

                                            <!-- year/sem heading — JS shows/hides this based on program filter -->
                                            <div class="year-group-heading"
                                                 data-year="@yg.Key"
                                                 data-sem="@sg.Key"
                                                 style="display:none">
                                                <i class="bi bi-layers-fill"></i>
                                                @yLbl Year &mdash; @sLbl Semester
                                            </div>

                                            <!-- wrapper div lets JS detect whether any children are visible -->
                                            <div class="year-sem-group"
                                                 data-year="@yg.Key"
                                                 data-sem="@sg.Key">
                                                @foreach (var subject in sg)
                                                {
                                                    <!-- subject row starts HIDDEN; JS shows + checks matching ones -->
                                                    <div class="subject-row"
                                                         data-program="@subject.Program"
                                                         data-year="@subject.YearLevel"
                                                         data-sem="@subject.Semester"
                                                         style="display:none">
                                                        <div class="form-check d-flex align-items-start gap-2">
                                                            <input class="form-check-input subject-item mt-1 flex-shrink-0"
                                                                   type="checkbox"
                                                                   name="SelectedSubjects"
                                                                   value="@subject.SubjectId"
                                                                   id="subject_@subject.SubjectId"
                                                                   data-units="@subject.Units"
                                                                   data-program="@subject.Program"
                                                                   data-code="@subject.CourseCode"
                                                                   data-title="@subject.DescriptiveTitle" />
                                                            <label class="form-check-label w-100" for="subject_@subject.SubjectId">
                                                                <div class="d-flex justify-content-between align-items-start gap-2">
                                                                    <div style="min-width:0">
                                                                        <strong style="font-size:.85rem">@subject.CourseCode</strong>
                                                                        <span style="font-size:.85rem"> &ndash; @subject.DescriptiveTitle</span>
                                                                        <br />
                                                                        <small class="text-muted" style="font-size:.72rem">
                                                                            @subject.Program &nbsp;|&nbsp; Lec: @subject.LectureHours h &nbsp;|&nbsp; Lab: @subject.LaboratoryHours h
                                                                        </small>
                                                                    </div>
                                                                    <span class="badge-units">@subject.Units units</span>
                                                                </div>
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="units-total mt-3">
                                    Total Units Selected: <strong><span id="totalUnits">0</span></strong>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    No subjects available. Please contact the administrator.
                                </div>
                            }
                        </div>

                        <!-- ══ STEP 4: Review ════════════════════════════ -->
                        <div class="wizard-step" data-step="4" style="display:none">
                            <h4 class="step-heading">Step 4 &mdash; Review Your Information</h4>
                            <p class="text-muted mb-3" style="font-size:.8rem">
                                <i class="bi bi-info-circle me-1"></i>
                                Please verify all information below. This mirrors your official registration form.
                            </p>
                            <div id="reviewContent"></div>
                        </div>

                        <!-- ══ STEP 5: Terms ═════════════════════════════ -->
                        <div class="wizard-step" data-step="5" style="display:none">
                            <h4 class="step-heading">Step 5 &mdash; Terms &amp; Conditions</h4>
                            <div class="terms-scroll">
                                <h6 class="fw-bold mb-2" style="font-size:.85rem">TRANSFEREE ENROLLMENT TERMS AND CONDITIONS</h6>
                                <p style="font-size:.82rem">By submitting this enrollment form, you agree to:</p>
                                <ul style="font-size:.82rem;padding-left:1.2rem">
                                    <li>Provide accurate and truthful information regarding your previous school records</li>
                                    <li>Submit all required transferee documents within the prescribed period</li>
                                    <li>Comply with all school policies and regulations</li>
                                    <li>Pay all required fees on time</li>
                                    <li>Maintain academic standards as required by the institution</li>
                                    <li>Respect school property and personnel</li>
                                    <li>Accept that any falsification of documents is grounds for dismissal</li>
                                    <li>Understand that subject accreditation is subject to evaluation and approval</li>
                                </ul>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" id="agreeTerms" class="form-check-input border-admiral" required />
                                <label for="agreeTerms" class="fw-bold" style="font-size:.88rem">
                                    I have read and agree to the Terms and Conditions
                                </label>
                            </div>
                        </div>

                        <!-- ══ STEP 6: Finish ════════════════════════════ -->
                        <div class="wizard-step" data-step="6" style="display:none">
                            <h4 class="step-heading">Step 6 &mdash; Submit Enrollment</h4>
                            <div class="alert alert-success d-flex align-items-start gap-3">
                                <i class="bi bi-check-circle-fill fs-4 flex-shrink-0 mt-1"></i>
                                <div>
                                    <strong>You are almost done!</strong><br>
                                    <span style="font-size:.88rem">
                                        Click <strong>Submit Registration</strong> to finalize your transferee enrollment.
                                        An acknowledgment e-mail will be sent to the address you provided.
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Navigation -->
                        <div class="wizard-nav">
                            <button type="button" id="prevBtn" class="btn btn-secondary px-3" onclick="changeStep(-1)" style="display:none">
                                <i class="bi bi-arrow-left me-1"></i> Previous
                            </button>
                            <div class="d-flex gap-2 ms-auto">
                                <button type="button" id="nextBtn" class="btn btn-admiral px-4" onclick="changeStep(1)">
                                    Next <i class="bi bi-arrow-right ms-1"></i>
                                </button>
                                <button type="submit" id="submitBtn" class="btn btn-success px-4 d-none">
                                    <i class="bi bi-check-circle me-1"></i> Submit Registration
                                </button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div><!-- /wizardContainer -->

    </div><!-- /container -->
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        /* ════════════════════════════════════════════════════════════
           Wizard state
        ════════════════════════════════════════════════════════════ */
        let currentStep = 1;
        const totalSteps = 6;
        const MONTHS = ['January','February','March','April','May','June',
                        'July','August','September','October','November','December'];
        let _previewObjectUrls = [];

        /* ─── Program selection ─────────────────────────────────── */
        function selectProgram(program) {
            const label = program === 'AMT'
                ? 'Aircraft Maintenance Technology (AMT)'
                : 'Aviation Electronics Technology (AVT)';

            document.getElementById('programSelection').classList.add('d-none');
            document.getElementById('wizardContainer').classList.remove('d-none');
            document.getElementById('selectedProgramDisplay').innerText = label;
            document.getElementById('ChosenProgram').value = program;
            document.getElementById('subjectProgramDisplay').innerText = label;

            // ✅ Filter subjects immediately when program is chosen
            filterSubjectsByProgram(program);
            goToStep(1);
        }

        /* ─── Filter subjects by program ────────────────────────── *
         *  • Shows only subject rows whose data-program matches.     *
         *  • CHECKS  all visible rows (default enrolled).            *
         *  • UNCHECKS + HIDES all non-matching rows.                 *
         *  • Shows/hides the year-group headings accordingly.        */
        function filterSubjectsByProgram(program) {
            const p = program.toUpperCase().trim();

            // 1. Process every subject row
            document.querySelectorAll('.subject-row').forEach(row => {
                const rp   = (row.dataset.program || '').toUpperCase().trim();
                const show = (rp === p || rp.includes(p));
                row.style.display = show ? '' : 'none';
                const cb = row.querySelector('.subject-item');
                if (cb) cb.checked = false;   // student manually selects
            });

            // 2. Show/hide year-group headings
            document.querySelectorAll('.year-sem-group').forEach(grp => {
                const anyVisible = [...grp.querySelectorAll('.subject-row')]
                                       .some(r => r.style.display !== 'none');
                const yr  = grp.dataset.year;
                const sem = grp.dataset.sem;
                const hdr = document.querySelector(
                    `.year-group-heading[data-year="${yr}"][data-sem="${sem}"]`);
                if (hdr) hdr.style.display = anyVisible ? '' : 'none';
            });

            calcUnits();
        }

        /* ─── Unit total ────────────────────────────────────────── */
        function calcUnits() {
            let total = 0;
            document.querySelectorAll('.subject-item:checked')
                .forEach(cb => { total += parseFloat(cb.dataset.units) || 0; });
            const el = document.getElementById('totalUnits');
            if (el) el.textContent = total.toFixed(1);
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.subject-item')
                .forEach(cb => cb.addEventListener('change', calcUnits));
        });

        /* ─── Step navigation ───────────────────────────────────── */
        function changeStep(dir) {
            if (dir === 1 && !validateCurrentStep()) return;
            goToStep(currentStep + dir);
        }

        function goToStep(step) {
            step = Math.max(1, Math.min(totalSteps, step));
            currentStep = step;

            document.querySelectorAll('.wizard-step').forEach(el => el.style.display = 'none');
            const active = document.querySelector(`.wizard-step[data-step="${step}"]`);
            if (active) active.style.display = 'block';

            document.querySelectorAll('.step-wizard-item').forEach((item, i) => {
                item.classList.remove('current', 'completed');
                if      (i + 1 < step)  item.classList.add('completed');
                else if (i + 1 === step) item.classList.add('current');
            });

            const prev   = document.getElementById('prevBtn');
            const next   = document.getElementById('nextBtn');
            const submit = document.getElementById('submitBtn');
            prev.style.display = step > 1 ? 'inline-flex' : 'none';
            if (step === totalSteps) {
                next.style.display = 'none';
                submit.classList.remove('d-none');
            } else {
                next.style.display = 'inline-flex';
                submit.classList.add('d-none');
            }

            if (step === 4) buildReview();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        /* ─── Validation ────────────────────────────────────────── */
        function validateCurrentStep() {
            if (currentStep === 2) return true; // accreditation is optional

            const stepEl = document.querySelector(`.wizard-step[data-step="${currentStep}"]`);
            const fields = stepEl.querySelectorAll('[required]');
            for (const f of fields) {
                if (!f.checkValidity()) { f.reportValidity(); return false; }
            }
            if (currentStep === 3 && !document.querySelector('.subject-item:checked')) {
                alert('Please select at least one subject.'); return false;
            }
            return true;
        }

        /* ─── Accreditation rows ────────────────────────────────── */
        function addAccredRow() {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td><input type="text"   name="AccredCode[]"  class="form-control form-control-sm border-admiral" placeholder="e.g. GEC101" /></td>
                <td><input type="text"   name="AccredTitle[]" class="form-control form-control-sm border-admiral" placeholder="Subject title" /></td>
                <td><input type="number" name="AccredUnits[]" class="form-control form-control-sm border-admiral" placeholder="3" min="0" max="9" step="0.5" /></td>
                <td><input type="text"   name="AccredGrade[]" class="form-control form-control-sm border-admiral" placeholder="1.25" /></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger border-0 px-2"
                            onclick="removeAccredRow(this)" title="Remove">
                        <i class="bi bi-trash3"></i></button></td>`;
            document.getElementById('accredBody').appendChild(row);
        }

        function removeAccredRow(btn) {
            const tbody = document.getElementById('accredBody');
            if (tbody.rows.length > 1) btn.closest('tr').remove();
            else btn.closest('tr').querySelectorAll('input').forEach(i => i.value = '');
        }

        /* ─── Helpers ───────────────────────────────────────────── */
        function fmtDate(v) {
            if (!v) return '';
            const m = v.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (!m) return v;
            return `${MONTHS[parseInt(m[2],10)-1]} ${parseInt(m[3],10)}, ${m[1]}`;
        }

        function escHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        /* ════════════════════════════════════════════════════════════
           Build Document-Style Review (Step 4)
        ════════════════════════════════════════════════════════════ */
        function buildReview() {
            _previewObjectUrls.forEach(u => URL.revokeObjectURL(u));
            _previewObjectUrls = [];

            const now    = new Date();
            const month  = now.getMonth();
            const year   = now.getFullYear();
            const acYear = month >= 5 ? `${year}-${year+1}` : `${year-1}-${year}`;
            let semester = '1st Semester';
            if (month >= 10 || month <= 2) semester = '2nd Semester';
            else if (month >= 3 && month <= 4) semester = 'Summer';

            const prog  = document.getElementById('ChosenProgram').value || '';
            const today = `${MONTHS[month]} ${now.getDate()}, ${year}`;

            /* ── Collect fields by category ── */
            const byCategory = {};
            document.querySelectorAll('.enrollment-field, .enrollment-file').forEach(el => {
                const cat = el.dataset.category || 'Other Information';
                if (!byCategory[cat]) byCategory[cat] = [];
                let val = el.value || '';
                if (el.classList.contains('enrollment-file'))
                    val = (el.files && el.files.length > 0) ? el.files[0].name : '';
                else if (el.type === 'date') val = fmtDate(val);
                byCategory[cat].push({ name: (el.dataset.fieldName || '').toUpperCase(), value: val });
            });

            /* ── Build subject list ── */
            let subjectsHtml = '';
            let totalUnits   = 0;
            document.querySelectorAll('.subject-item:checked').forEach(cb => {
                const u = parseFloat(cb.dataset.units);
                totalUnits += u;
                subjectsHtml += `
                <div class="doc-subject-item">
                    <div class="doc-subject-code">${escHtml(cb.dataset.code)}</div>
                    <div class="doc-subject-name">${escHtml(cb.dataset.title)}</div>
                    <div class="doc-subject-units">${u.toFixed(1)} units</div>
                </div>`;
            });
            if (!subjectsHtml)
                subjectsHtml = '<div style="color:#888;font-size:8pt;font-style:italic">No subjects selected</div>';

            /* ── Build accreditation mini-table ── */
            let accredRows = '', hasAccred = false;
            const codes  = document.querySelectorAll('input[name="AccredCode[]"]');
            const titles = document.querySelectorAll('input[name="AccredTitle[]"]');
            const units  = document.querySelectorAll('input[name="AccredUnits[]"]');
            const grades = document.querySelectorAll('input[name="AccredGrade[]"]');
            for (let i = 0; i < codes.length; i++) {
                const c = codes[i].value.trim(), t = titles[i].value.trim();
                if (!c && !t) continue;
                hasAccred = true;
                accredRows += `<tr>
                    <td>${escHtml(c)}</td><td>${escHtml(t)}</td>
                    <td>${escHtml(units[i]?.value||'')}</td>
                    <td>${escHtml(grades[i]?.value||'')}</td></tr>`;
            }
            const accredSectionHtml = hasAccred ? `
                <div class="doc-section-title">Subject Accreditation (For Credit)</div>
                <table class="doc-accred-table">
                    <thead><tr><th>Code</th><th>Title</th><th>Units</th><th>Grade</th></tr></thead>
                    <tbody>${accredRows}</tbody>
                </table>` : '';

            /* ── Build field sections ── */
            const sectionOrder = [
                'Personal Data','Educational Background','For Transferees',
                "Parent's Information","Contact Information","Family Background","Documents"
            ];
            let sectionsHtml = '';
            sectionOrder.forEach(sec => {
                const fields = byCategory[sec];
                if (!fields || !fields.length) return;
                sectionsHtml += `<div class="doc-section-title">${escHtml(sec)}</div>`;
                for (let i = 0; i < fields.length; i += 2) {
                    const f1 = fields[i], f2 = fields[i+1];
                    if (f2) {
                        sectionsHtml += `<div class="doc-row">
                            <div class="doc-field"><span class="doc-label">${escHtml(f1.name)}:</span><span class="doc-value">${escHtml(f1.value)}</span></div>
                            <div class="doc-field"><span class="doc-label">${escHtml(f2.name)}:</span><span class="doc-value">${escHtml(f2.value)}</span></div>
                        </div>`;
                    } else {
                        sectionsHtml += `<div class="doc-row">
                            <div class="doc-field full"><span class="doc-label">${escHtml(f1.name)}:</span><span class="doc-value">${escHtml(f1.value)}</span></div>
                        </div>`;
                    }
                }
            });

            /* ── Build uploaded docs preview ── */
            let docsCardsHtml = '', uploadCount = 0;
            document.querySelectorAll('.enrollment-file').forEach(el => {
                if (!el.files || !el.files.length) return;
                const file      = el.files[0];
                const fieldName = (el.dataset.fieldName || 'Document').toUpperCase();
                const isImage   = file.type.startsWith('image/');
                const isPdf     = file.type === 'application/pdf';
                const isWord    = file.type.includes('word') || /\.docx?$/i.test(file.name);
                const isExcel   = file.type.includes('excel') || file.type.includes('spreadsheet') || /\.xlsx?$/i.test(file.name);
                uploadCount++;

                if (isImage) {
                    const objUrl = URL.createObjectURL(file);
                    _previewObjectUrls.push(objUrl);
                    docsCardsHtml += `
                    <div class="doc-preview-card">
                        <div class="doc-preview-img-wrap is-image" onclick="openLightbox('${objUrl}','${escHtml(fieldName)}')" title="Click to enlarge">
                            <img src="${objUrl}" alt="${escHtml(fieldName)}" loading="lazy" />
                        </div>
                        <div class="doc-preview-info">
                            <span class="doc-preview-label">${escHtml(fieldName)}</span>
                            <span class="doc-preview-filename">${escHtml(file.name)}</span>
                        </div>
                    </div>`;
                } else if (isPdf) {
                    docsCardsHtml += `<div class="doc-preview-card"><div class="doc-preview-icon-wrap"><i class="bi bi-file-earmark-pdf doc-preview-icon pdf"></i><span class="doc-preview-filetype-badge pdf">PDF</span></div><div class="doc-preview-info"><span class="doc-preview-label">${escHtml(fieldName)}</span><span class="doc-preview-filename">${escHtml(file.name)}</span></div></div>`;
                } else if (isWord) {
                    docsCardsHtml += `<div class="doc-preview-card"><div class="doc-preview-icon-wrap"><i class="bi bi-file-earmark-word doc-preview-icon word"></i><span class="doc-preview-filetype-badge word">WORD</span></div><div class="doc-preview-info"><span class="doc-preview-label">${escHtml(fieldName)}</span><span class="doc-preview-filename">${escHtml(file.name)}</span></div></div>`;
                } else if (isExcel) {
                    docsCardsHtml += `<div class="doc-preview-card"><div class="doc-preview-icon-wrap"><i class="bi bi-file-earmark-excel doc-preview-icon excel"></i><span class="doc-preview-filetype-badge excel">EXCEL</span></div><div class="doc-preview-info"><span class="doc-preview-label">${escHtml(fieldName)}</span><span class="doc-preview-filename">${escHtml(file.name)}</span></div></div>`;
                } else {
                    const ext = file.name.split('.').pop().toUpperCase() || 'FILE';
                    docsCardsHtml += `<div class="doc-preview-card"><div class="doc-preview-icon-wrap"><i class="bi bi-file-earmark doc-preview-icon other"></i><span class="doc-preview-filetype-badge">${escHtml(ext)}</span></div><div class="doc-preview-info"><span class="doc-preview-label">${escHtml(fieldName)}</span><span class="doc-preview-filename">${escHtml(file.name)}</span></div></div>`;
                }
            });

            const docsInnerHtml  = uploadCount > 0
                ? `<div class="doc-preview-grid">${docsCardsHtml}</div>`
                : `<div class="doc-preview-empty"><i class="bi bi-cloud-upload"></i>No documents or images uploaded.</div>`;
            const docsSectionHtml = `
            <div class="docs-preview-section">
                <div class="docs-preview-header">
                    <div class="docs-preview-header-icon"><i class="bi bi-images"></i></div>
                    <div>
                        <p class="docs-preview-title">Uploaded Documents &amp; Images</p>
                        <p class="docs-preview-subtitle">${uploadCount} file${uploadCount!==1?'s':''} attached &mdash; Images can be clicked to enlarge</p>
                    </div>
                </div>
                ${docsInnerHtml}
            </div>`;

            /* ── Assemble ── */
            document.getElementById('reviewContent').innerHTML = `
            <div>
                <div class="doc-paper">
                    <div class="doc-header">
                        <img src="/images/MainLogo.png" alt="OACT Logo" class="doc-logo">
                        <div class="doc-school-name">Orson Aerospace College and Technology, Inc.</div>
                        <p class="doc-school-address">RLW Building, MV Patalinghug Avenue, Barangay Basak, Lapu-Lapu City, Cebu 6015</p>
                        <p class="doc-school-address">oactech1953@gmail.com &nbsp;|&nbsp; (032) 326-4409 &nbsp;|&nbsp; (63) 977 381 0089</p>
                    </div>
                    <div class="doc-blue-bar">Transferee Registration Form</div>
                    <div class="doc-body">
                        <div class="doc-info-col">
                            <div class="doc-row">
                                <div class="doc-field"><span class="doc-label">ACADEMIC YEAR:</span><span class="doc-value">${acYear}</span></div>
                                <div class="doc-field"><span class="doc-label">SEMESTER:</span><span class="doc-value">${semester}</span></div>
                            </div>
                            <div class="doc-row">
                                <div class="doc-field"><span class="doc-label">COURSE:</span><span class="doc-value">${escHtml(prog)}</span></div>
                                <div class="doc-field"><span class="doc-label">APPLICANT TYPE:</span><span class="doc-value">Transferee</span></div>
                            </div>
                            ${sectionsHtml}
                            ${accredSectionHtml}
                            <div class="doc-sig-row">
                                <div class="doc-sig-box">
                                    <span class="doc-label" style="font-size:7pt;margin-right:6px">DATE:</span>
                                    <span class="doc-sig-line">${today}</span>
                                    <div class="doc-sig-caption">Date Signed</div>
                                </div>
                            </div>
                        </div>
                        <div class="doc-subjects-col">
                            <div class="doc-subjects-box">
                                <div class="doc-subjects-title">Selected Subjects<br>(Transferee Enrollment)</div>
                                ${subjectsHtml}
                                <div class="doc-subjects-total">Total Units: ${totalUnits.toFixed(1)}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="review-note">
                    <i class="bi bi-eye me-1"></i>
                    This is a preview of your registration form. Verify all details before proceeding.
                </div>
                ${docsSectionHtml}
            </div>`;
        }

        /* ════════════════════════════════════════════════════════════
           Lightbox
        ════════════════════════════════════════════════════════════ */
        function openLightbox(src, caption) {
            document.getElementById('lbImg').src = src;
            document.getElementById('lbCaption').textContent = caption;
            document.getElementById('imgLightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        function closeLightbox(event, force) {
            if (!force && event && event.target !== document.getElementById('imgLightbox')) return;
            document.getElementById('imgLightbox').classList.remove('active');
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(null, true); });

        /* ─── Submit guard ──────────────────────────────────────── */
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('transfereeForm').addEventListener('submit', function(e) {
                if (!document.getElementById('agreeTerms').checked) {
                    e.preventDefault();
                    alert('Please agree to the terms and conditions.');
                    return;
                }
                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting…';
            });
        });
    </script>
}

@functions {
    string GetAcceptedFileTypes(string fileTypes)
    {
        if (string.IsNullOrEmpty(fileTypes)) return "*";
        return fileTypes switch
        {
            "pdf"    => ".pdf",
            "doc"    => ".doc,.docx",
            "excel"  => ".xls,.xlsx",
            "ppt"    => ".ppt,.pptx",
            "images" => "image/*",
            "all"    => "*",
            _        => "*"
        };
    }
}
